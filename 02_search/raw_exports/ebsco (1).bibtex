 journal   = "Experimental Technology & Management",
 keywords  = "Engineering education; Intelligent tutoring systems; Intelligent transportation systems; Structural models; Process, Physical Distribution, and Logistics Consulting Services; Digital twin; Production planning; Production scheduling",
 pages     = "150-157",
