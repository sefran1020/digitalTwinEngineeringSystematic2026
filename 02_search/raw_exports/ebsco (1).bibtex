@article{18629467420250616,
 abstract  = "The article focuses on the international Digital Twins in Manufacturing Systems Symposium hosted by Mehran University of Engineering and Technology (MUET) as part of the EU-funded Capacity Building in Higher Education (CBHE) CATCH_VR Project. The event brought together researchers and industry experts from various countries to discuss advancements in augmented reality (AR), virtual reality (VR), artificial intelligence (AI), and immersive learning. Key presentations addressed topics such as digital transformation in manufacturing, real-time data integration with digital twins, and the design of resilient production lines. The symposium concluded with a panel discussion on the future of XR and AI in education and industry, highlighting the importance of collaboration in advancing technology-driven engineering education.",
 author    = "",
 number    = "12",
 title     = "Digital Twins in Manufacturing Systems.",
 volume    = "50",
