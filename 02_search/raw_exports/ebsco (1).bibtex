 year      = "2024",
 issn      = "00981354",
 journal   = "Computers & Chemical Engineering",
 keywords  = "Virtual work; Augmented reality; Chemical engineering education; Digital twin; System downtime; Teaching methods; Teleology",
 pages     = "N.PAG-N.PAG",
 note      = "",
}

@article{18772896420250903,
 abstract  = "The article focuses on the collaboration between CADFEM India Pvt. Ltd., an Ansys Elite Channel Partner, and the Indian Institute of Technology Roorkee (IIT-R) to establish a Digital Twin Simulation Lab, enhancing digital engineering education and research in India. Under the Memorandum of Understanding (MoU), IIT Roorkee will utilize Ansys’ advanced simulation technologies for academic research and skill development, while CADFEM will provide software licenses, workshops, and support. The partnership aims to integrate simulation into the curriculum, promote joint research, and serve as a model for similar initiatives across other Indian institutions, ultimately preparing students for industry challenges and fostering innovation in engineering.",
 author    = "",
 number    = "null",
 title     = "CADFEM India, IIT Roorkee Launch Digital Twin Lab for Simulation Innovation.",
 volume    = "null",
