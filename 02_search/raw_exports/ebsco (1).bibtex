@article{19039103720251201,
 abstract  = "The convergence of artificial intelligence, cloud analytics, and Internet of Things technologies has fundamentally transformed traditional manufacturing environments into intelligent, self-optimizing ecosystems known as smart factories. This article examines the practical implementation of AI-driven technologies in manufacturing contexts, focusing on digital twin applications, real-time process monitoring systems, and machine learning algorithms that enable predictive maintenance and production optimization. The article employs mixed-methods analysis combining case studies, performance metrics evaluation, and engineering workflow assessment to understand how these technologies reshape manufacturing operations and engineering practices. Key findings reveal significant improvements in operational efficiency, quality control, and resource utilization through the integration of predictive analytics and automated optimization systems. The article documents a fundamental shift in engineerin",
 author    = "Namdeo, Aditi",
 number    = "12",
 title     = "AI and Analytics for Smart Factories: Engineering Applications.",
 volume    = "7",
 url       = "https://research.ebsco.com/plink/755ab9cc-d2b4-3548-904b-9887f86f060c",
 year      = "2025",
 issn      = "2709104X",
 journal   = "Journal of Computer Science & Technology Studies",
 keywords  = "Artificial intelligence; Data analytics; Manufacturing industries; Condition-based maintenance; Automation; Mathematical optimization; Manufacturing processes; Industrial Process Furnace and Oven Manufacturing; Instruments and Related Products Manufacturing for Measuring, Displaying, and Controlling Industrial Process Variables; Digital twin",
 pages     = "192-200",
 note      = "",
}

@article{18047532420241101,
 abstract  = "Engineering education at the Institute for Information Management in Engineering integrates product lifecycle management (PLM), computer‐aided design (CAD), eXtended reality (XR), and artificial intelligence (AI) to enhance learning and prepare students for modern challenges. Our interdisciplinary approach, emphasizing digital twins and virtual twins, fosters immersive, hands‐on experiences. This paper reviews our strategies, comparing them with global initiatives, highlighting the transformative impact of our curriculum on preparing future engineers for complex industrial environments.",
 author    = "Bönsch, Jakob and Greif, Lucas and Hauck, Svenja and Kreuzwieser, Simon and Mayer, Anjela and Michels, Felix Longge and Ovtcharova, Jivka",
 number    = "11",
