  number={},
  pages={260-265},
  abstract={This document aims to explore the world of Learning Factories (LFs), intended as training and education environments for students and workers. An accurate analysis of the state of the art is offered with a morphological table divided into nine main dimensions and populated by the implementations of LFs now existing and present in the literature. The product and process dimensions were further characterized, by submitting the analysed cases. Then, an additional product definition table and two-dimensional positioning map were inserted. It was possible to note that it is still necessary to invest in the creation of highly customizable and modular smart products.},
  keywords={Training;Manufacturing processes;Electronic learning;Conferences;Focusing;Industrial engineering;Production facilities;Learning Factories;Smart Product;Innovation;State of the Art;Industrial Engineering Education 4.0},
  doi={10.1109/MELECON53508.2022.9843084},
  ISSN={2158-8481},
  month={June},}@INPROCEEDINGS{11091958,
  author={Shen, Guanjia and Wang, Shang and Gan, Xinhua},
  booktitle={2025 7th International Conference on Computer Science and Technologies in Education (CSTE)}, 
  title={Development and Application of Intelligent Tutoring System Based on AI-assisted Robots}, 
  year={2025},
  volume={},
  number={},
  pages={385-390},
  abstract={To enhance the quality of classroom teaching in vocational schools, particularly the students' engagement during classes, this study proposes a solution for the development of an intelligent tutoring system supported by AI-assisted robots. Taking the automotive drive shaft as a case study, we focus on the concept of polar moment of inertia. The research consists of three key steps. First, we determined the dimensional parameters of the automotive drive shaft and calculated the parameters for both hollow and solid shafts using mathematical calculus formulas. Second, we incorporated the concept of polar moment of inertia into the teaching content and developed an intelligent tutoring system using Python, based on the Qwen API. Third, we conducted teaching experiments and evaluations. The results indicated that the experimental group (students using the intelligent tutoring system) improved their unit test scores by an average of 0.66 points (out of a maximum of 10) compared to the control group (students not using the intelligent tutoring system). Additionally, engagement scores in the experimental group increased by 1.29 points (out of a maximum of 10). At a significance level of 0.05 (two-tailed), there were significant differences between the experimental and control groups regarding both unit test and engagement scores. This study demonstrates the positive impact of the Qwen-based AI robot on students' learning. There is an urgent need to prioritize the development of more AI-based intelligent tutoring systems to further enhance the overall educational quality in vocational schools.},
  keywords={Shafts;Computer science;Education;Focusing;Solids;Calculus;System software;Intelligent systems;Robots;Automotive engineering;AI-assisted robots;AI;intelligent tutoring system;software development},
  doi={10.1109/CSTE64638.2025.11091958},
  ISSN={},
  month={April},}@ARTICLE{10530967,
  author={Supriya, Y. and Bhulakshmi, Dasari and Bhattacharya, Sweta and Gadekallu, Thippa Reddy and Vyas, Pratik and Kaluri, Rajesh and Sumathy, S. and Koppu, Srinivas and Brown, David J. and Mahmud, Mufti},
  journal={IEEE Access}, 
  title={Industry 5.0 in Smart Education: Concepts, Applications, Challenges, Opportunities, and Future Directions}, 
  year={2024},
  volume={12},
  number={},
  pages={81938-81967},
  abstract={Industry 5.0 is one of the emerging stages of industrialization in which humans collaborate with cutting-edge technologies to enhance various workplace processes. The primary objective is to emphasize meeting the needs of people and provide enhanced resilience and understanding of sustainability. Industry 5.0 enables cooperation with such advanced technologies and the stakeholders in the education sector to ensure efficiency and effectiveness in the teaching-learning process. The present study provides an exhaustive review of the role of Industry 5.0 in smart education. At the outset, a brief overview of the present scenario in the education sector and its associated challenges is presented. This sets the stage for establishing the need for Education 1.0 and its progressive transition to Education 4.0. Further, the motivation to integrate Industry 5.0 with Education 4.0 and the related enabling technologies that support are discussed. The paper extensively provides a description of the application of Industry 5.0 in various educational sectors namely in medical education, further learning, distance education, engineering education, and shop floor training. The study also presents seven case studies highlighting the successful implementation of Industry 5.0 in versatile sectors and regions. Finally, the challenges of Industry 5.0 in education are discussed pointing to potential future directions of research.},
  keywords={Education;Fifth Industrial Revolution;Educational technology;Reviews;Surveys;Training;Collaboration;Sustainable development;Stakeholders;Engineering education;Employment;Education;industry 5.0;smart education},
  doi={10.1109/ACCESS.2024.3401473},
  ISSN={2169-3536},
  month={},}@INPROCEEDINGS{9453903,
  author={Plaza, Pedro and Castro, Manuel and Sáez-López, Jose Manuel and Sancristobal, Elio and Gil, Rosario and Menacho, Antonio and García-Loro, Félix and Quintana, Blanca and Martin, Sergio and Blázquez, Manuel and Macho, Alejandro and Baizán, Pablo and Mur, Francisco and Carro, German and Pérez, Clara and Carrasco, Ramón and López-Rey, África and Rodriguez-Artacho, Miguel and Ruipérez-Valiente, Jose A.},
  booktitle={2021 IEEE Global Engineering Education Conference (EDUCON)}, 
  title={Promoting Computational Thinking through Visual Block Programming Tools}, 
