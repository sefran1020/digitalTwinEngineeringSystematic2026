  booktitle={2025 IEEE 14th International Conference on Engineering Education (ICEED)}, 
  title={Facilitating Interactive Learning in Remote Engineering Education with the Help of Small Handcrafted Tools and E-Learning Technologies}, 
  year={2025},
  volume={},
  number={},
  pages={338-342},
  abstract={Online education has gained significant importance in recent years, especially in technical and practical fields. Despite the challenges posed by this type of education, such as the lack of practical equipment and limitations in face-to-face interaction, efforts to enhance the learning experience continue. This paper explores the use of handcrafted tools as practical instruments in online teaching of engineering concepts, particularly in the field of renewable energy. In this study, boost converter and solar tracker handcrafted tools were used to enhance students' understanding of engineering concepts in online classes. The results of a questionnaire survey conducted among 70 graduate students at Shahid Beheshti University over several academic terms showed that this approach contributed to increasing engagement, improving the understanding of complex concepts, and enhancing the retention of material. Additionally, the use of handcrafted tools had a positive impact on students' practical learning and their ability to solve engineering problems in the real world. This paper demonstrates that innovative educational methods based on handcrafted tools can effectively improve the learning process in online education.},
  keywords={Surveys;Solid modeling;Three-dimensional displays;Electronic learning;Renewable energy;Instruments;Solar tracking;Mobile applications;Engineering education;Monitoring;Handcrafted tools;Online education;Practical learning;Renewable energy},
  doi={10.1109/ICEED66794.2025.11400335},
  ISSN={},
  month={Sep.},}@INPROCEEDINGS{10343978,
  author={Klimo, M. and Kvassay, M. and Kvassayova, N.},
  booktitle={2023 21st International Conference on Emerging eLearning Technologies and Applications (ICETA)}, 
  title={Digital Twin and Modelling a 3D Human Body in Healthcare}, 
  year={2023},
  volume={},
  number={},
  pages={307-312},
  abstract={The digital technology has seen an overwhelming usage in various fields, where it improves every aspect of work. Digital Twin is a concept not that old, yet it brings a much needed advantage in many occupations. We briefly review the history of digital twin technology, its use in many fields, advantages and disadvantages in healthcare and how it may improve healthcare in the near future. Digital twins have various uses in the healthcare sector, including personalized medicine, the development of medical devices, surgical planning, drug discovery, remote patient monitoring, and optimization of healthcare facilities. Healthcare professionals are enabled to make treatment decisions that are highly individualized, improve the precision of surgical planning, and accelerate the process of medication development. Moreover, the utilization of digital twins facilitates the ongoing remote surveillance of patients' well-being, hence enhancing patient outcomes and the overall standard of healthcare provision. In this article, we overview the Digital Twin technology, how is it utilized, and what it presents in the future.},
  keywords={Electric potential;Three-dimensional displays;Precision medicine;Wearable computers;Surveillance;Surgery;Medical services},
  doi={10.1109/ICETA61311.2023.10343978},
  ISSN={},
  month={Oct},}@INPROCEEDINGS{10184383,
  author={Knyazev, Alexander and Cheremukhina, Julia},
  booktitle={2023 3rd International Conference on Technology Enhanced Learning in Higher Education (TELE)}, 
  title={Mining Standard Development in Information and Communication Technologies for Education}, 
  year={2023},
  volume={},
  number={},
  pages={120-123},
  abstract={The article addresses the issues of applying the methodology of intelligent process analysis (mining process) to the development of standards in information and communication technologies within the digital ecosystem of engineering education.},
  keywords={Ecosystems;Information and communication technology;Engineering education;Standards;process mining;digital production;digital twins;intelligent process analysis;industry 4.0;metaverse;blockchain},
  doi={10.1109/TELE58910.2023.10184383},
  ISSN={},
  month={June},}@INPROCEEDINGS{11256181,
  author={Idoko, Linus and Okojie, Daniel and Eneje, Samiel},
  booktitle={2025 World Engineering Education Forum - Global Engineering Deans Council (WEEF-GEDC)}, 
  title={Driving Digital Innovation: How Industry Partners are Reshaping Engineering Education}, 
  year={2025},
  volume={},
  number={},
  pages={1-9},
  abstract={Engineering education is rapidly evolving due to technological advancements and the demand for industry-ready professionals. While academia has long emphasized theory, digital technologies highlight the need for stronger collaboration with industry to bridge the skills gap and drive innovation. This paper explores how such partnerships transform engineering education by enhancing curricula, boosting employability, and fostering entrepreneurship. Using case studies from Stanford University with Google, the University of Sheffield with RollsRoyce, and the Indian Institute of Technology with Tata Consultancy Services, the study analyses partnership models and institutional records to assess their impact on innovation, engagement, and learning outcomes. Findings show that industry-academic collaborations enrich curricula and research, improve graduate readiness, strengthen faculty development, and expand entrepreneurial opportunities. By aligning education with industry needs, these partnerships create responsive, innovative learning environments that equip students for the digital era. Expanding such collaborations is vital to sustaining a skilled, adaptable workforce and advancing the modernization of engineering education.},
  keywords={Industries;Technological innovation;Analytical models;Adaptation models;Collaboration;Entrepreneurship;Transforms;Internet;Problem-solving;Engineering education;Digital innovation;engineering education;industryacademic partnerships},
  doi={10.1109/WEEF-GEDC66748.2025.11256181},
  ISSN={2837-5025},
  month={Sep.},}@INPROCEEDINGS{10551967,
  author={Telnov, Yury Filippovich and Diveev, Rustem Ilyasovitch},
  booktitle={2024 7th International Conference on Information Technologies in Engineering Education (Inforino)}, 
  title={Application of Multi-agent Technologies for Transforming Network Engineering Education}, 
  year={2024},
  volume={},
  number={},
  pages={1-7},
  abstract={The article substantiates the possibilities of implementing network programs of higher and additional professional education based on multi-agent technologies that transform all basic educational processes, ensuring their flexibility and adaptability to the dynamic needs of the labor market. The use of multi-agent technologies for engineering education, which is characterized by the use of complex and high-cost software, hardware and engineering systems that require the organization of collective sharing of resources, is becoming especially relevant. For multi-agent technologies, a method is chosen for representing agents in the form of asset administrative shells of fourth-generation industry systems, representing digital twins of information, educational, software, technical and organizational-methodological resources. The article proposes the structure of a multi-agent networked learning system; requirements for information representation of educational processes and the composition of key services in the asset administrative shells are defined. It introduces a multi-agent technology for the interaction of participants in the creation of networked educational programs. The software implementation of a multi-agent networked learning system based on the FIPA (Foundation for Intelligent Physical Agents) standards and the specifications of the asset administrative shells of the Platform Industry 4.0 project will enhance the adaptability of networked educational programs. This will be achieved through the individualization of the learning process, with the real-time involvement of resources from various educational institutions and the collective use of software, technical, and engineering complexes. The collection of big data on the execution of educational processes in the asset administrative shells will contribute to both the real-time adjustment of the multi-agent system to the evolving competency model of learners and the improvement of the educational content throughout the entire system. The research results presented in the article will be applicable in teaching the courses “Design of Intelligent Information Systems” (bachelor’s degree) and “Knowledge Engineering” (master’s degree) in the field of study “Applied Informatics.”},
  keywords={Learning systems;Educational programs;Standards organizations;Organizations;Software agents;Real-time systems;Hardware;Network Education;Digital Twin;Multi-Agent Technology;Asset Administrative Shell;Digital Platform;Services;Ontology},
  doi={10.1109/Inforino60363.2024.10551967},
  ISSN={},
  month={April},}@INPROCEEDINGS{11016345,
  author={Trestian, Ramona and Shayesteh, Homeira and Tims, Jack and Shah, Purav},
  booktitle={2025 IEEE Global Engineering Education Conference (EDUCON)}, 
  title={Enhancing Employability and Engagement in a Student-Centred Learning Environment: Insights from the MDX Internship Scheme}, 
  year={2025},
  volume={},
  number={},
  pages={1-10},
  abstract={The higher education sector faces significant challenges, including the need to enhance student employability, engagement, and financial accessibility. Universities must equip graduates with both academic knowledge and practical skills while addressing financial barriers that hinder many students' progress. The MDX Internship Scheme, launched at Middlesex University in January 2024, responds to these challenges by offering paid, discipline-specific internships that integrate practical work experience with academic learning. The scheme enhances students' career readiness by enabling them to apply theoretical knowledge in real-world settings, develop essential skills such as teamwork and problem-solving, and build confidence through project achievements. Moreover, the internships alleviate financial burdens and foster a sense of belonging. This paper showcases the experiences of engineering undergraduates, postgraduates, and doctoral candidates, who participated in the MDX Internship scheme and undertook diverse projects spanning academic research, industry placements, and collaborations with local authorities, deepening their understanding of engineering and transferable skills. Local businesses also benefited from the scheme, gaining access to innovative student talent that positively influenced workplace dynamics and project outcomes, while building long-term partnerships with the university. The MDX Internship Scheme serves as a model for enhancing employability, engagement, and financial support in higher education.},
  keywords={Industries;Local government;Engineering profession;Employment;Medical services;Teamwork;Problem-solving;Engineering education;Faces;STEM;Engineering Education;STEM;Internships;Higher Education;Employability Skills;Transferable Skills},
  doi={10.1109/EDUCON62633.2025.11016345},
  ISSN={2165-9567},
  month={April},}@INPROCEEDINGS{9637163,
  author={Chacón, Rolando and Estela, M. Rosa},
  booktitle={2021 IEEE Frontiers in Education Conference (FIE)}, 
  title={STEAM activities for civil engineering curricula. From Calculus to Digital Twins}, 
  year={2021},
  volume={},
  number={},
  pages={1-8},
  abstract={This full paper describes a set of pedagogical activities designed for students of all academic years in civil engineering programs. The pedagogical project has a twofold aim: i) exposing civil engineering students to Construction 4.0-related technologies and ii) fostering motivation and creativity among students by including STEAM by-design. In this paper, a set of STEAM activities designed for selected courses of this new degree in Civil Engineering Technologies is described. These activities are designed for the sake of promoting Construction 4.0-related skills to broad audiences in civil engineering by means of a learning pathway. This pathway is conceived using several branches of Construction 4.0. Namely, Industrial Production, Cyber-Physical Systems and Digital Technologies. All activities are designed using accessible and affordable Hardware and Software for scalability purposes. The selection includes a broad range of topics that are routinely taught in all academic years (1st to 4th) of the new degree.},
  keywords={Scalability;Digital twin;Conferences;Production;Software;Hardware;Calculus;STEAM;Civil Engineering;Construction 4.0},
  doi={10.1109/FIE49875.2021.9637163},
  ISSN={2377-634X},
  month={Oct},}@INPROCEEDINGS{8629689,
  author={Anand, Sam and Ghalsasi, Omkar and Zhang, Botao and Goel, Archak and Reddy, Srikanth and Joshi, Shriyanka and Morris, Gil},
  booktitle={2018 World Engineering Education Forum - Global Engineering Deans Council (WEEF-GEDC)}, 
  title={Additive Manufacturing Simulation Tools in Education}, 
  year={2018},
  volume={},
  number={},
  pages={1-6},
  abstract={Additive Manufacturing is becoming a strategic initiative to enable the transformation of today's business into a digital enterprise. This technology is increasing the rate of innovation with new lightweight and sustainable designs and dramatically reducing the time from product ideation (design) to realization (manufacturing). Makerspaces are being built all over the world, especially in academic settings and students have 3D printers readily available to design and produce innovative ideas on the spot. The University of Cincinnati (UC) is partnering with Siemens PLM Software to create students who are ready for the digital workforce of the future considering the entire product lifecycle. UC is developing curriculum to teach the fundamentals of Additive Manufacturing using Siemens PLM software as a foundation using a cradle to cradle approach. Students will realize the idea of a `digital thread' that connects a product design to its production environment using fast product/process simulations using a cradle to cradle approach. They will also become aware of simulation tools required for assessing and iterating the performance attributes of the process and the product between the ideation and realization phases to create a `digital twin' of that product. This will help prepare students for Industry 4.0.},
  keywords={Tools;Three-dimensional printing;Graphical user interfaces;Geometry;Visualization;Feature extraction;Surface treatment;Additive Manufacturing;Digital Thread;Digital Twin;Simulation Tools;Sustainable Design and Manufacturing},
  doi={10.1109/WEEF-GEDC.2018.8629689},
  ISSN={},
  month={Nov},}@INPROCEEDINGS{9125239,
  author={Jesus, Maria A. de and Estrela, Vania V. and Mamani, Wilma Dora Huacasi and Razmjooy, Navid and Plaza, Pedro and Peixoto, Aruquia},
  booktitle={2020 IEEE Global Engineering Education Conference (EDUCON)}, 
  title={Using Transmedia Approaches in STEM}, 
  year={2020},
  volume={},
  number={},
  pages={1013-1016},
  abstract={In Brazil, teaching STEM-related subjects is quite delicate. As math intensifies, the corresponding attention span decreases. Transmedia Educational Environments (TECs) can help engage students in such subjects, and it is evident that the learner’s attention span is longer and more focused when students employ mobile devices and other technologies than when they were not. Transmedia (TM) storytelling can render quotidian life as a vigorous constructivist didactic tool. Up to now, most of the efforts within classrooms are related to elementary school. The digital farm project introduces several class activities connected to the protagonist’s universe and a real-life rural community. The instructor can handle a multitude of optimization problems learners can relate to and solve them. The class and the instructor can interact with other subjects like programming and application development. In Brazil, this is paramount due to the high levels of anxiety felt by engineering students. The optimization problems from the digital farm can also relate to matters such as the establishment of sustainable practices and social responsibility. TM also applies to other educational scenarios.},
  keywords={Digital twin;Conferences;Anxiety disorders;Mobile communication;Mobile handsets;Engineering students;Optimization;math literacy;STEM;transmedia;project-based learning;optimization;constructivism},
  doi={10.1109/EDUCON45650.2020.9125239},
  ISSN={2165-9567},
  month={April},}@INPROCEEDINGS{10264045,
  author={Liu, Lu and Jiang, Yu and Zeng, Zhaoyang},
  booktitle={2023 IEEE 12th International Conference on Engineering Education (ICEED)}, 
  title={Exploring a New Model of Practice-Oriented Education Based on the Cultivation of Outstanding Engineering Talents}, 
  year={2023},
  volume={},
  number={},
  pages={117-121},
  abstract={Engineering training is a practical teaching platform for engineering education in Chinese universities. It is also an important educational segment for cultivating students' practical abilities and innovative consciousness. It is targeted at undergraduate students of various majors and has the largest number of students and the largest teaching scale. In response to the call of the new era to cultivate new generations of people who shoulder the great responsibility of national rejuvenation, and to address the insufficient adaptability of engineering education to the needs of modern engineering development, we will explore the “new model” of engineering education and talent cultivation worldwide, and create a new quality of outstanding engineering talent cultivation with an international vision and cross-cultural communication ability, to help complete the construction of a new model of practice-oriented education in engineering training.},
  keywords={Training;Adaptation models;Cross-cultural communication;Engineering education;Outstanding Engineering;Talent Cultivation;Practice-Oriented Education},
  doi={10.1109/ICEED59801.2023.10264045},
  ISSN={},
  month={Aug},}@INPROCEEDINGS{11129379,
  author={Sangchai, Krittep and Mhuadthongon, Nithizethe and Ruengwaree, Amnoiy},
  booktitle={2025 10th International STEM Education Conference (iSTEM-Ed)}, 
  title={Developing Cyber-Physical Systems Learning Material Using Minecraft and Micro:bit: A Case Study of Lower Secondary Students at Suwanprasit School}, 
  year={2025},
  volume={},
  number={},
  pages={1-6},
  abstract={This research developed and evaluated CyberPhysical Systems (CPS) learning materials that utilize Minecraft and Micro:bit, aiming to enhance the understanding of fundamental CPS concepts among lower secondary students and foster preparedness for the future in a digital world. Using a game-based learning approach, the research investigated the efficacy of these materials and their impact on students’ comprehension and future readiness. A purposive sample of ${3 0}$ students (grades 7-9) from Suwanprasit School, Nakhon Nayok Province, participated in the research. The research instruments included a tailored learning management plan, Minecraft-Micro:bit integrated activities, a CPS concept assessment test, and an opinion questionnaire. The results demonstrated high content validity for the learning tools, with an Index of Item-Objective Congruence (IOC) of ${0. 8 6}$ for the lesson plan and ${0. 9 0}$ for assessments. Student performance showed significant learning gains, with formative (E1) and summative (E2) assessment scores of 80.43 and 85.33, respectively, meeting and exceeding the expected 80/80 thresholds. Both student and community stakeholders expressed overwhelmingly positive perceptions across all evaluated dimensions, including content, usability, and development of 21st-century skills. The findings of this research will provide insights into the potential of Minecraft and Micro:bit as engaging learning materials for STEM education, specifically in CPS, and contribute to the development of effective educational resources that equip students with essential skills for the digital age.},
  keywords={Reviews;Instruments;Education;Information age;Smart systems;Digital twins;Stakeholders;Usability;Standards;Cyber-Physical Systems (CPS);Minecraft;Micro:bit;STEM Education;Digital Age},
  doi={10.1109/iSTEM-Ed65612.2025.11129379},
  ISSN={},
  month={July},}@INPROCEEDINGS{9657247,
  author={Chakrabarti, Soma and Caratozzolo, Patricia and Norgaard, Bente and Sjoer, Ellen},
  booktitle={2021 World Engineering Education Forum/Global Engineering Deans Council (WEEF/GEDC)}, 
  title={Preparing Engineers for Lifelong Learning in the Era of Industry 4.0}, 
  year={2021},
  volume={},
  number={},
  pages={518-523},
  abstract={With the rapid advancement in technology such as robotic automation, artificial intelligence and digital twins, the engineering jobs are continuously changing and will continue to change in the future. Thus, rapid reskilling and upskilling are necessary to help engineers enhance their abilities to continuously learn and use new knowledge for their own employability and for a sustainable world. It is vital for the engineers to develop a learner mindset that can easily adapt to the changes and transformation by always acquiring and updating necessary knowledge and skills to perform well in these constantly evolving situations. How will they do it? How will our engineering students be prepared for a lifetime of learning? How will we, the educators and administrators, help our engineers to become lifelong, continuous learners? This paper will examine the Industry 4.0 skills, the current status of development of these skills in engineering curriculum, and propose a framework where the university, industry and government collectively contribute and participate to foster this new concept “learn to learn” among engineering students and professionals to sustain their employability for lifetimes.},
  keywords={Industries;Knowledge engineering;Digital twin;Conferences;Bibliographies;Government;Curriculum development;lifelong learning;continuing education;employability;learner mindset;upskilling and reskilling},
  doi={10.1109/WEEF/GEDC53299.2021.9657247},
  ISSN={},
  month={Nov},}@INPROCEEDINGS{10343920,
  author={Colmenares-Quintero, Ramón Fernando and Ángel Guarín-García, Luis and Baquero-Almazo, Marieth and Villar-Villar, Salvador Segundo and Azmat, Freeha and Stansfield, Kim E. and Bilal Khan, Muhammad},
  booktitle={2023 World Engineering Education Forum - Global Engineering Deans Council (WEEF-GEDC)}, 
  title={Methodology for creating digital twins for green hydrogen production based on simulation and gamification}, 
  year={2023},
  volume={},
  number={},
  pages={1-7},
  abstract={The creation of digital twins offers a virtual environment that facilitates the understanding of technology in aspects of functionality and operation, as well as the validation of the performance of the same in several territories under different conditions. The methodology presented in this paper shows the stages for the creation of digital twins, from data processing, and simulations of the technology in the HOMER PRO software to the integration of these techniques in a 3D model within a virtual environment adding the gamification component to promote learning around the technology. A roadmap is presented for the evaluation and estimation, in this case, of the production of green hydrogen in the Wayuu Community La Paz, Manaure, Colombia using Digital Twins around the safety to treat hydrogen and the evaluation of the technology in the territory.},
  keywords={Solid modeling;Three-dimensional displays;Virtual environments;Estimation;Production;Green hydrogen;Data models;data processing;simulation;virtual reality;digital twins;green hydrogen},
  doi={10.1109/WEEF-GEDC59520.2023.10343920},
  ISSN={2837-5025},
  month={Oct},}@INPROCEEDINGS{10343756,
  author={Rodriguez-Padilla, Consuelo and Vazquez-Hurtado, Carlos and Ramirez-Cedillo, Erick},
  booktitle={2023 World Engineering Education Forum - Global Engineering Deans Council (WEEF-GEDC)}, 
  title={Manufacturing Cell Framework Based on TEC21 Educational Model: A Successful Case of Study}, 
  year={2023},
  volume={},
  number={},
  pages={1-6},
  abstract={This paper presents a teaching strategy for the course Automation of Manufacturing Systems (AMS). Within the TEC21 model, students are challenged to solve a real industrial problem in their classrooms. Even though it is a common practice nowadays, the novelty of this project lies in the awareness and self-assessment that the students submitted after completion of the challenge to enhance and embrace the evaluation of the competencies. Students must program a manufacturing cell using a vision system in the fulfillment of a packing industrial task. A challenge-based, team-based, game-based, and autonomy-oriented philosophy is adopted to motivate the students to solve the challenge by proposing innovative solutions. A survey on students’ satisfaction and skills acquired is reported at the end of the paper.},
  keywords={Surveys;Computer vision;Mechatronics;Engineering profession;Software;Fourth Industrial Revolution;Digital twins;educational innovation;higher education;smart manufacturing;problem-solving;challenge-based learning},
  doi={10.1109/WEEF-GEDC59520.2023.10343756},
  ISSN={2837-5025},
  month={Oct},}@INPROCEEDINGS{9782924,
  author={Ochkov, Valery F. and Stevens, Alan and Tikhonov, Anton I.},
  booktitle={2022 VI International Conference on Information Technologies in Engineering Education (Inforino)}, 
  title={Jupyter Notebook, JupyterLab – Integrated Environment for STEM Education}, 
  year={2022},
  volume={},
  number={},
  pages={1-5},
  abstract={The article deals with the application of integrated environments Jupyter Notebook and JupyterLab in the learning process together with STEAM (Science, Technology, Engineering, Art, Mathematics) technology. It is shown that these environments support basic learning activities including formulating problem statements with formulas and images, performing scientific and engineering calculations, computational experiments, creating graphical user interfaces, publishing interactive e-textbooks, and interactive web-applications. The article describes how to conduct classes using Jupyter Notebook and JupyterLab.},
  keywords={Visualization;Publishing;Debugging;Writing;Kernel;Information technology;Engineering education;STEM;STEAM;Jupyter project;JupyterLab;Jupyter Notebook;computational document;integrated environment;Python;Markdown;Latex},
  doi={10.1109/Inforino53888.2022.9782924},
  ISSN={},
  month={April},}@INPROCEEDINGS{10872652,
  author={Bin, Zheng and Siang, Yang Soo and Bai, Yan and Keng, Tan Min and Bo, Chen Hong and Bo, Wang Hao},
  booktitle={2024 IEEE 22nd Student Conference on Research and Development (SCOReD)}, 
  title={Development of Digital Twin Technology Based Intelligent System for the Manufacturing Processing Line}, 
  year={2024},
  volume={},
  number={},
  pages={427-432},
  abstract={This paper investigates the application of Digital Twin (DT) technology to enhance efficiency and intelligence in manufacturing, particularly within machine tool processing lines. DT seamlessly integrates physical and virtual systems, enabling realtime simulation, monitoring, and optimization of manufacturing operations. The proposed system features multi-axis motion control, real-time data collection, and simulation, structured in three layers: the physical layer (hardware), the DT engine (data and computation), and the virtual model (3D simulation). Key components such as intelligent warehousing, Automated Guided Vehicles (AGVs), and Radio Frequency Identification(RFID) technology automate material handling, reduce manual labor, and streamline material flow. The paper further discusses the hardware and software frameworks, with Plant Simulation used for process design and performance prediction through fuzzy neural networks. Ultimately, DT integration facilitates real-time monitoring, process optimization, and enhances the development of smart factories.},
  keywords={Solid modeling;Three-dimensional displays;Warehousing;Real-time systems;Hardware;Software;Digital twins;Optimization;Smart manufacturing;Radiofrequency identification;DT;RFID;Smart Factory},
  doi={10.1109/SCOReD64708.2024.10872652},
  ISSN={2643-2447},
  month={Dec},}@INPROCEEDINGS{11194857,
  author={Al Hakim, Vando Gusti and Yang, Su-Hang and Wang, Jen-Hang and Peng, Chih-Yang and Chen, Gwo-Dong},
  booktitle={2025 IEEE International Conference on Advanced Learning Technologies (ICALT)}, 
  title={AI-Powered Personalized Robots with Digital Companions: Leveraging LLMs for Frequent Engagement, Ownership, and Sustained Learning}, 
  year={2025},
  volume={},
  number={},
  pages={54-58},
  abstract={Robots are increasingly used in education, but challenges limit their effectiveness: limited numbers, interactions restricted to class time, uniform designs that prevent ownership, and difficulty maintaining engagement over a semester. To address these issues, we propose a novel AI-powered personalized robot framework. Each robot is paired with a digital companion, accessible via students' mobile devices and enhanced by large language models (LLMs) for dynamic, personalized interactions. Students nurture their digital companions by studying, earning virtual currency, and customizing the robot's appearance and behaviors. The nurtured companion's “spirit” is later embodied in a shared physical robot during class, integrating digital and physical learning experiences while using only one robot per classroom. A quasi-experimental study in Taiwan involved 90 Hospitality Management students training for Japanese restaurant service. Three groups were compared: AI-Powered Personalized Robots (with LLM-enhanced companions), Standardized Robots (non-personalized but accessible inside and outside class), and a Conventional Classroom (no robots). Results showed that students in the AI-Powered Personalized Robots group achieved higher learning outcomes, demonstrated greater ownership toward their studies, and engaged more frequently than other groups. This framework lays the groundwork for scalable, AI-integrated education by reimagining how learners interact with intelligent toys, fostering engagement across an entire semester.},
  keywords={Training;Online banking;Educational robots;Large language models;Toy manufacturing industry;Mobile handsets;Digital twins;Robots;educational robots;large language models;digital twins;personalization;long-term engagement},
  doi={10.1109/ICALT64023.2025.00021},
  ISSN={2161-377X},
  month={July},}@INPROCEEDINGS{8591460,
  author={David, Joe and Lobov, Andrei and Lanz, Minna},
  booktitle={IECON 2018 - 44th Annual Conference of the IEEE Industrial Electronics Society}, 
  title={Learning Experiences Involving Digital Twins}, 
  year={2018},
  volume={},
  number={},
  pages={3681-3686},
  abstract={Offering efficacious instruction for production based technical education to provide adequate hands-on training has always been a growing concern in technical universities. This paper proposes the use of Digital Twins as a tool for training students on production based systems and justifies the proposition by instantiating learning theories within a pedagogical digital twin framework. Further, the paper investigates how situational awareness can be beneficial in such an environment and its contribution to the overall learning experience.},
  keywords={Cognitive science;Cognition;Tools;Production facilities;Training;Digital Twins;Learning Theories;Situational Awareness;Pedagogy},
  doi={10.1109/IECON.2018.8591460},
  ISSN={2577-1647},
  month={Oct},}@INPROCEEDINGS{10578841,
  author={Niedźwiecki, Arthur and Jongebloed, Sascha and Zhan, Yanxiang and Kümpel, Michaela and Syrbe, Jörn and Beetz, Michael},
  booktitle={2024 IEEE Global Engineering Education Conference (EDUCON)}, 
  title={Cloud-Based Digital Twin for Cognitive Robotics}, 
  year={2024},
  volume={},
  number={},
  pages={1-5},
  abstract={The paper presents a novel cloud-based digital twin learning platform for teaching and training concepts of cognitive robotics. Instead of forcing interested learners or students to install a new operating system and bulky, fragile software onto their personal laptops just to solve tutorials or coding assignments of a single lecture on robotics, it would be beneficial to avoid technical setups and directly dive into the content of cognitive robotics. To achieve this, the authors utilize containerization technologies and Kubernetes to deploy and operate containerized applications, including robotics simulation environments and software collections based on the Robot operating System (ROS). The web-based Integrated Development Environment JupyterLab is integrated with RvizWeb and XPRA to provide real-time visualization of sensor data and robot behavior in a user-friendly environment for interacting with robotics software. The paper also discusses the application of the platform in teaching Knowledge Representation, Reasoning, Acquisition and Retrieval, and Task-Executives. The authors conclude that the proposed platform is a valuable tool for education and research in cognitive robotics, and that it has the potential to democratize access to these fields. The platform has already been successfully employed in various academic courses, demonstrating its effectiveness in fostering knowledge and skill development.},
  keywords={Training;Cloud computing;Operating systems;Tutorials;Robot sensing systems;Software;Real-time systems;Digital Twins;Remote Laboratories;Cognitive Robotics;Open Educational Resources},
  doi={10.1109/EDUCON60312.2024.10578841},
  ISSN={2165-9567},
  month={May},}@INPROCEEDINGS{9766542,
  author={Kleppe, Paul Steffen and Bjelland, Øystein and Hansen, Irina Emily and Mork, Ola-Jon},
  booktitle={2022 IEEE Global Engineering Education Conference (EDUCON)}, 
  title={Idea Lab: Bridging Product Design and Automatic Manufacturing in Engineering Education 4.0}, 
  year={2022},
  volume={},
  number={},
  pages={195-200},
  abstract={Industry 4.0 calls for new multidisciplinary skills, and universities have an essential role in supplying this competence. Engineering Education 4.0 has therefore been introduced as a means of meeting the demands of Industry 4.0, by making technology accessible in a pedagogic environment. This paper introduces an Industry 4.0 Idea Lab for bridging design and automatic manufacturing in Engineering Education 4.0. The Idea Lab is presented within the Learning-Factory-Curriculum-guide, including lab facilities and overview, teaching modules, and specific student development projects. Evaluation of the role of the Idea Lab with respect to design for automatic manufacturing is evaluated with a survey. It was found that a low entry level to the lab is important for students’ learning, and that the lab facilities tightens the interactions between local industry, students and university.},
  keywords={Industries;Conferences;Product design;Fourth Industrial Revolution;Engineering education;Testing;Industry 4.0;Engineering Education 4.0;RoboDK;Product Design;Automatic Manufacturing},
  doi={10.1109/EDUCON52537.2022.9766542},
