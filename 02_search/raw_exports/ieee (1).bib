  author={Arif, Yunifa Miftachul and Karami, Ahmad Fahmi and Rohma, Salma Ainur and Criollo-C, Santiago},
  journal={IEEE Access}, 
  title={Advancing Engineering Education Through Serious Games: A Systematic Literature Review of Technological Innovation, Challenges, and Future Directions}, 
  year={2026},
  volume={14},
  number={},
  pages={35225-35242},
  abstract={The rapid evolution of engineering education has intensified the demand for instructional approaches that can effectively support experiential learning, complex problem solving, and student engagement beyond traditional lecture-based methods. In this context, serious games have emerged as a promising pedagogical paradigm, particularly when combined with emerging technologies such as artificial intelligence (AI) and immersive environments. This study presents a systematic literature review (SLR) of serious games in engineering education, synthesizing peer-reviewed research published between 2020 and 2025 and indexed in Scopus and IEEE Xplore. Following the PRISMA 2020 framework, 63 primary studies were rigorously selected and analyzed to identify dominant technological innovations, application domains, game genres, research methodologies, and implementation challenges. The findings indicate that web- and mobile-based serious games remain the most prevalent due to their accessibility and scalability, while immersive technologies especially Virtual Reality (VR) demonstrate strong potential for enhancing spatial understanding and experiential learning in complex engineering domains. However, the integration of AI-driven adaptivity remains limited, with only a small subset of studies employing machine learning or computer vision techniques for personalized learning support. Key challenges include high development and infrastructure costs, limited pedagogical alignment, inconsistent evaluation frameworks, and insufficient attention to long-term learning outcomes and soft skill development. This review contributes a comprehensive cross-disciplinary perspective on technological trends and research gaps, highlighting the need for pedagogically grounded, AI-enhanced, and scalable serious game frameworks to support sustainable innovation in engineering education.},
  keywords={Games;Engineering education;Systematic literature review;Artificial intelligence;Technological innovation;Systematics;Solid modeling;Scalability;Databases;Software engineering;Serious games;engineering education;virtual reality;artificial intelligence;adaptive learning;game-based learning},
  doi={10.1109/ACCESS.2026.3669416},
  ISSN={2169-3536},
  month={},}@INPROCEEDINGS{10578714,
  author={Schaffland, Axel and Müller, Celina and Schöning, Julius},
  booktitle={2024 IEEE Global Engineering Education Conference (EDUCON)}, 
  title={Promoting the Digital Transformation of STEM Education with the Mechanical Neural Network, a Physical Model for Future-Oriented and Student-Centered AI Education}, 
  year={2024},
  volume={},
  number={},
  pages={1-10},
  abstract={Designed to bridge the artificial intelligence (AI) education gap within education systems, this paper introduces the Mechanical Neural Network (MNN), a pioneering tool for K-12 STEM education. The MNN, a physical representation of a Multilayer Perceptron (MLP) with Rectified Linear Units (ReLUs), engages students in hands-on experimentation via levers and pulleys. Together with a tablet app it forms an AI education system offering a personalized learning experience, allowing students to explore AI and their mathematical foundations at their own pace, regardless of programming background. In usability tests, this AI education system outperformed traditional teacher-centered approaches to AI education, with MNN-empowered education students correctly answering twice as many questions on AI and artificial neural networks. Subjective satisfaction levels were 1.5 times higher in the MNN group than in the teacher-centered group. Beyond its impact on AI education, the MNN promotes multidisciplinary learning, combining computer science with physics, mechanics, and additive manufacturing. The MNN serves as an educational tool and ignites student interest in STEM and AI research. Allowing students to construct the MNN themselves provides insights into pulley systems and levers, connecting mechanics to the functionality of ANNs. This model addresses contemporary AI research topics and contributes to the ongoing digital transformation of education. In conclusion, the AI education system combined from MNN and tablet app emerges as a promising concept for AI education, offering a unique blend of hands-on learning, multidisciplinary exploration, and student engagement in STEM and AI research.},
  keywords={Pulleys;Digital transformation;Education;Artificial neural networks;Three-dimensional printing;Artificial intelligence;Usability;artificial intelligence;education;physical neural network;educational game;mechanical computation},
  doi={10.1109/EDUCON60312.2024.10578714},
  ISSN={2165-9567},
  month={May},}@INPROCEEDINGS{11461076,
  author={Frank, Irina A. and Platunina, Galina P. and Salutina, Tatyana Y. and Benia, Milana T.},
  booktitle={2026 Systems of Signals Generating and Processing in the Field of on Board Communications}, 
  title={Formation of Competencies of Future Engineers in the Digital Economy: Integration of Business-Oriented Scenarios Into Educational Laboratories of Electrical Engineering and Electronics}, 
  year={2026},
  volume={},
  number={},
  pages={1-5},
  abstract={In the context of the transformation of the economy towards digital technologies and industry 4.0, the need for engineering personnel with not only technical, but also business-oriented competencies is increasing. The article presents an approach to the integration of business scenarios into educational laboratories as a mechanism for the formation of interdisciplinary competencies among future engineers. A methodology for designing simulation laboratory work based on real-world industrial applications is proposed. The integration of business-oriented scenarios into the laboratory practice helps to reduce the gap between academic education and the requirements of the labor market, and also increases the motivation of students by applying knowledge in the context of real production tasks. The proposed approach can be adapted for other engineering fields and serves as the basis for the formation of a digital transformation of engineering education.},
  keywords={Circuits;Feedback;Electronic circuits;Microcontrollers;Microprocessors;Circuits and systems;Product lifecycle management;Product development;Smart devices;Protocols;digital economy;engineering education;electrical engineering;business-oriented scenarios;electronics;industry 4.0},
  doi={10.1109/IEEECONF68869.2026.11461076},
  ISSN={2768-0118},
  month={March},}@INPROCEEDINGS{10125224,
  author={Ramirez, Hiram Maximiliano Muñoz and Hurtado, Carlos Vazquez},
  booktitle={2023 IEEE Global Engineering Education Conference (EDUCON)}, 
  title={Work in Progress: Design and implementation of a microservices architecture for project-based learning of software engineering patterns}, 
  year={2023},
  volume={},
  number={},
  pages={1-3},
  abstract={Industry 4.0 has revolutionized how factories operate, integrating new advanced technologies. This progress must be matched with innovation in engineering education, as these new technologies demand engineers with multidisciplinary skills. Microservices architecture offers a chance to implement project-based learning courses that cater to an individual's skills while exposing them to other disciplines' concepts and methods. This paper explores the implementation of such a project while implementing a security camera system for a Smart Factory, serving as a showcase of the strengths that project-based learning offers. Three microservices were successfully developed, with another three microservices pending further development. Project-based learning offered multidisciplinary learning opportunities during the construction of the services.},
  keywords={Technological innovation;Microservice architectures;Computer architecture;Cameras;Production facilities;Fourth Industrial Revolution;Security;microservice architecture;project-based learning;industry 4.0;professional education;educational innovation;higher education},
  doi={10.1109/EDUCON54358.2023.10125224},
  ISSN={2165-9567},
  month={May},}@INPROCEEDINGS{10578878,
  author={Khan, Fazeel and Singh, Kumar},
  booktitle={2024 IEEE Global Engineering Education Conference (EDUCON)}, 
  title={Work in Progress: Developing a Comprehensive Approach to Teaching Smart Factory Operations}, 
  year={2024},
  volume={},
  number={},
  pages={1-3},
  abstract={This Abstract presents the rationale, setup, and curriculum integration of a new smart factory lab as a significant component of a smart manufacturing engineering bachelor's degree program. For a new engineering graduate to enter the cyber-physical Industry 5.0 ecosystems of technologies with requisite skills and an adaptable mindset, the preparatory educational environment must adopt new tools and incorporate hands-on experiences applicable to smart manufacturing. A new small-scale smart factory is being developed for this purpose with features tailored to the educational environment, including reconfigurability, modern technologies (vision, sensing, AI, and robotics), and a manufacturing execution system to examine cybersecurity and reliability. The lab-factory, curriculum details, and proposed utilization, including professional training, are discussed in this paper.},
  keywords={Training;Ecosystems;Robot sensing systems;Reliability engineering;Sensors;Fifth Industrial Revolution;Engineering education;Automation;robotics;smart manufacturing;process design;lab development},
  doi={10.1109/EDUCON60312.2024.10578878},
  ISSN={2165-9567},
  month={May},}@INPROCEEDINGS{10551923,
  author={Kuvshinnikov, Vladimir and Kovshov, Evgeny and Korchagin, Valery},
  booktitle={2024 7th International Conference on Information Technologies in Engineering Education (Inforino)}, 
  title={Digital Educational Resources in Industrial Radiography}, 
  year={2024},
  volume={},
  number={},
  pages={1-5},
  abstract={Nowadays, the technological level of production is an important factor for all areas of modern economic development and life quality improvement. Neither in the informational, nor in the industrial sphere it is possible to produce in-demand, modern, and therefore high-tech and complex products without the establishment of an appropriate system of quality examination at multiple stages of production. This article deals with the problem of forming a comprehensive educational environment with the use of heterogeneous educational resources in the training of specialists in the radiation type of nondestructive testing. The purpose of the research and development is to address the shortcomings of classroom, remote digital learning, and laboratory practice listed in the article by developing a solution based on virtual reality technologies. The purpose stated lies in the pursuit of intensive solutions to the existing problems. Extensive development paths are not effective in improving the efficiency of training and checking students’ knowledge in the context of the rapidly growing demand for nondestructive testing specialists. The concept of a digital twin as an educational resource is considered. The structural approach to the formation of complex educational resources both at the level of organization and at the level of digital product is presented. The structure of interrelationships between data in the formation of a digital twin of a radiographic image is presented. The results of the radiographic image simulation and its quality verification are shown.},
  keywords={Training;Radiography;Nondestructive testing;Training data;Production;Organizations;Throughput;educational resources;x-ray testing;training simulator;virtual reality;digital and information technologies},
  doi={10.1109/Inforino60363.2024.10551923},
  ISSN={},
  month={April},}@INPROCEEDINGS{9657446,
  author={Neffke, Jens Palacios and Barquet, Ana Paula Bezerra},
  booktitle={2021 World Engineering Education Forum/Global Engineering Deans Council (WEEF/GEDC)}, 
  title={From the execution of transformation frameworks to the development of education strategies in organizations}, 
  year={2021},
  volume={},
  number={},
  pages={432-440},
  abstract={While engaging in Lean and/or digital transformations, one of the biggest challenges that organizations face is the acquisition and internal development of talents required to successfully drive change. For this reason, concrete approaches are currently needed to define the skills and competencies to be developed in order to achieve the strategic objectives outlined by transformation frameworks, as well as the most appropriate instructional approaches to convey them. In this contribution, it is established that bridging the gap between what business require in terms of technical knowledge and what education institutions provide (even internal academies), is fundamental to enable and accelerate a successful business transformation. A method to derive education objectives, strategies and content directly from organizational frameworks based on the Instructional Design Model for Engineering Education (IDMEE) will be provided. The proposed method aims to establish a virtuous cycle, in which the element “competencies building” is not only considered within transformation roadmaps as a paramount strategic objective for technological implementation and execution, but is also used to improve itself. The concept is best explained as an analogy to smart technologies systems, which use historic date to improve its performance.},
  keywords={Digital transformation;Buildings;Organizations;Engineering education;Faces;Transformation frameworks;Digital transformation;Lean;Instructional design},
  doi={10.1109/WEEF/GEDC53299.2021.9657446},
  ISSN={},
  month={Nov},}
