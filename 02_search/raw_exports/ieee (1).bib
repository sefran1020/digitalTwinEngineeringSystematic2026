@INPROCEEDINGS{11021192,
  author={Ahmed, Syed Waqas and Zaidi, Abbas K.},
  booktitle={2025 Systems and Information Engineering Design Symposium (SIEDS)}, 
  title={Advancing Digital Twin Development in Systems Engineering Education through Model-Based Systems Engineering}, 
  year={2025},
  volume={},
  number={},
  pages={473-478},
  abstract={This study investigates the use of Model-Based Systems Engineering (MBSE) principles in digital twin (DT) development to enhance systems engineering education programs. The increasing prominence of digital twins across industries necessitates academic initiatives to train undergraduate students in DT creation. By leveraging MBSE principles and tools, this work fills a gap in undergraduate curricula, providing a structured framework for implementing small-scale DT systems. The focus of this study is the development of a virtual twin (VT) for a remotely operated rover (Physical Twin or PT). Using System Modeling Language (SysML), the work emphasizes designing and implementing a VT that mimics the PT’s behavior, specifically predicting battery usage during operations. The VT integrates both structural and behavioral views and incorporates real-time data exchange with the PT. The methodology involves creating SysML diagrams for the VT, modeling the PT’s structure and functionality, and establishing a bi-directional data link between the VT and PT using Magic Systems of Systems Architect. The PT, equipped with sensors and a microcontroller, generates real-time data for the VT to simulate battery performance and validate operational feasibility. Initial results demonstrate that the VT predicts the rover’s capacity to complete specific trips based on its current battery state. This work contributes to DT education by presenting a scalable, hands-on case study, bridging academic learning with industry demands.},
  keywords={Industries;Microcontrollers;MIMICs;Real-time systems;Systems Modeling Language;Digital twins;Batteries;Systems engineering education;Sensors;System of systems;Digital Twin;MBSE;SysML;Systems Engineering;Engineering Education},
  doi={10.1109/SIEDS65500.2025.11021192},
  ISSN={2994-3531},
  month={May},}@INPROCEEDINGS{10819216,
  author={Tisza, Juan and Ortega, David},
  booktitle={2024 IEEE 4th International Conference on Advanced Learning Technologies on Education & Research (ICALTER)}, 
  title={Methodological Proposal for the Use of Digital Twins in Remote Engineering Education}, 
  year={2024},
  volume={},
  number={},
  pages={1-4},
  abstract={Virtual education and the development of practical experiences of virtual laboratories are gaining more and more importance and acceptance in education programs, having been emphasized in the post-pandemic stage, facing this new scenario it is required to create methods that strengthen learning in remote classes. To achieve this, the use of digital twins in the mixed reality modality is proposed, to generate an interactive virtual laboratory that promotes experimentation to improve the teaching process. For this proposal we will use as an example the digital twin of a pilot plant of green hydrogen generation, the digital twin will be designed and implemented using current technologies such as the internet of things (IoT), free software (Linux), and the Unity platform in which we will create the mobile application that will generate the virtual image.},
  keywords={Protocols;Linux;Laboratories;Mixed reality;Software;Digital twins;Mobile applications;Proposals;Internet of Things;Augmented reality;Digital Twins;Augmented Reality;Education 4.0;Green Hydrogen},
  doi={10.1109/ICALTER65499.2024.10819216},
  ISSN={},
  month={Dec},}@INPROCEEDINGS{9540196,
  author={Guc, Furkan and Viola, Jairo and Chen, YangQuan},
  booktitle={2021 IEEE 1st International Conference on Digital Twins and Parallel Intelligence (DTPI)}, 
  title={Digital Twins Enabled Remote Laboratory Learning Experience for Mechatronics Education}, 
  year={2021},
  volume={},
  number={},
  pages={242-245},
  abstract={Laboratory intensive assignments and hands-on skills are important components in Mechatronics and Control Engineering by their nature. Like many other educational services, lots of the contents including laboratory studies are switched to remote learning due to COVID-19. In this work, the need for remote laboratory assignments is transformed into an opportunity to use Digital Twins in the education effectively. Laboratory assignments are designed on top of the concept of Digital Twin applications for the course “ME-142: Mechatronics” at the University of California, Merced. Basic mechatronics simulation skills are enhanced using the foundational applications in MATLAB/Simulink. After students reached high confidence level in the simulation environment, the concept of Digital Twins is introduced for subsequent laboratory assignments consisting identification, modeling, analysis, controller design and validation. Through the end of the semester, students are expected to work in groups of six for the course project to create their own applications of Digital Twin for a variety of systems. Finally, Digital Twin applications are posted online using MATLAB Web App Server to enhance accessibility and compensate the lack of hardware interaction.},
  keywords={Remote laboratories;Analytical models;Mechatronics;Distance learning;Digital twin;Education;Switches;Digital Twins;Engineering Education;Mechatronics;Remote Laboratory},
  doi={10.1109/DTPI52967.2021.9540196},
  ISSN={},
  month={July},}@INPROCEEDINGS{11400233,
  author={Yuan, Jiayu and Pan, Xudong and Li, Yuefeng and Zhuang, Ruoqiao},
  booktitle={2025 IEEE 14th International Conference on Engineering Education (ICEED)}, 
  title={Exploration and Practice of Digital Twin Engineering Education for Complex Equipment}, 
  year={2025},
  volume={},
  number={},
  pages={250-253},
  abstract={Aiming at the multidisciplinary and crossintegration nature of digital twin technology for complex equipment, as well as the current challenges in cultivating digital twin talents in higher education, this study draws on practical engineering cases of digital twin systems to explore the application of the Project-Based Learning (PBL) teaching model in related engineering education. It demonstrates how the PBL approach helps develop students' practical skills, innovation capacity, and ability to solve complex engineering problems, thereby achieving the talent development goal of shifting the emphasis from knowledge transmission and skill training to mindset cultivation. This research provides a valuable practical case and contributes to the reform of engineering education in universities.},
  keywords={Training;Manufacturing industries;Knowledge engineering;Technological innovation;Digital transformation;Digital twins;Engineering education;digital twin;complex equipment;engineering education;project-based learning;talent cultivation},
  doi={10.1109/ICEED66794.2025.11400233},
  ISSN={},
  month={Sep.},}@INPROCEEDINGS{11420287,
  author={Norambuena, Nicolás and Muñoz-La Rivera, Felipe and Toledo Bórquez, Alexis and Valín Rivera, José Luis and Ignacio Galleguillos Ketterer, Cristóbal},
  booktitle={2025 LI Latin American Computer Conference (CLEI)}, 
  title={Integration of Digital Twins in Multi-User Virtual Reality Environments for Technical Education in Engineering}, 
  year={2025},
  volume={},
  number={},
  pages={1-7},
  abstract={This work presents a multi-user virtual reality (VR) system integrated with a real-time sensorized digital twin of an internal combustion engine, aimed at enhancing hands-on learning in mechanical engineering education. The virtual environment, developed in Unity and synchronized via IoT technologies (PLC, Node-RED, and Blynk), enables students to interact with a live virtual replica of the engine, visualize key variables such as RPM, temperature, and pressure, and adjust parameters collaboratively in real time. Through experimental validation with undergraduate students, the approach demonstrated increased engagement, improved data interpretation, and reduced operational risk compared to traditional lab methods. Results also showed enhanced collaboration and a better understanding of Industry 4.0 concepts. This solution bridges the gap between theoretical knowledge and industrial practice, offering a scalable model for modern engineering education.},
  keywords={Training;Knowledge engineering;Solid modeling;Collaboration;Virtual environments;Real-time systems;Digital twins;Fourth Industrial Revolution;Synchronization;Mechanical engineering;virtual reality;education;real-time sensing;combustion-less engine;Industry 4.0;IoT;digital twins;engineering education},
  doi={10.1109/CLEI67442.2025.11420287},
  ISSN={2771-5752},
  month={Oct},}@INPROCEEDINGS{11416921,
  author={Featherson, Dylan and Ghalamchi, Behnam},
  booktitle={2026 International Conference on Computing, Networking and Communications (ICNC)}, 
  title={Augmented Reality and Digital Twins in Engineering Education: Technological Enhancements and Applications}, 
  year={2026},
  volume={},
  number={},
  pages={379-383},
  abstract={This research explores the advantages of real-time simulation in augmented reality (AR), focusing on the simultaneous interaction with both physical and virtual environments. AR enables an intuitive understanding of simulated phenomena, offering more natural controls and reducing nausea compared to virtual reality (VR). By integrating AR simulations with physical models and digital twins (DT), the differences between simulation and reality are accentuated, allowing for further refinement of simulation models. These benefits are particularly impactful in engineering education, where students can engage with both theoretical and practical aspects simultaneously. The integration of AR, DT, and physical models can enhance the learning experience, providing a deeper understanding of complex concepts. Additionally, these advancements are applicable to various fields, including engineering design and validation, medical training, and construction planning. This research aims to demonstrate the significant potential of combining AR and DT in educational and professional settings, ultimately bridging the gap between simulation and reality.},
  keywords={Training;Solid modeling;Virtual environments;Focusing;Real-time systems;Digital twins;Planning;Engineering education;Augmented reality;Augmented Reality;Digital Twins;RealTime Simulation;Engineering Education},
  doi={10.1109/ICNC68183.2026.11416921},
  ISSN={2473-7585},
  month={Feb},}@INPROCEEDINGS{9376395,
  author={Rassudov, Lev and Akmurzin, Eduard and Korunets, Alina and Osipov, Dmitriy},
  booktitle={2021 28th International Workshop on Electric Drives: Improving Reliability of Electric Drives (IWED)}, 
  title={Engineering Education and Cloud-Based Digital Twins for Electric Power Drive System Diagnostics}, 
  year={2021},
  volume={},
  number={},
  pages={1-3},
  abstract={Industry 4.0 concept is associated with introducing the new digital technologies to increase the competitiveness of an industrial enterprise or of an industry sector where it is being implemented. One of the important technologies improving the competitiveness are those used for diagnostics before and after a failure occurs - predictive maintenance and fault diagnosis. These enable to increase reliability of the equipment by efficiently planning and scheduling service and this way reducing or even eliminating the downtime at minimal service costs. For this purposes the advanced simulation techniques - Digital twin technologies along with Cloud services and Big data processing are increasingly implemented. The paper focuses on introducing these technologies into the educational process of the electrical engineers. The demand on industry digitalization and the rapid developments of digital technologies require the academia to keep up and introduce the basics of the technologies into the training process of the future electrical engineers. In modern world the competitiveness of the national industry as well as the engineers themselves is based on the interdisciplinary competences in the sphere of electrical engineering and the emerging digital technologies.},
  keywords={Industries;Training;Electrical engineering;Service robots;Digital twin;Reliability engineering;Predictive maintenance;robotic systems;fault diagnosis;simulation;cloud services;digital twin},
  doi={10.1109/IWED52055.2021.9376395},
  ISSN={},
  month={Jan},}@INPROCEEDINGS{10348648,
  author={Tabunshchyk, Galyna and Arras, Peter and Wolff, Carsten},
  booktitle={2023 IEEE 12th International Conference on Intelligent Data Acquisition and Advanced Computing Systems: Technology and Applications (IDAACS)}, 
  title={Digital Twins in Engineering Education, Preparing Students for Industrial Digital Transformation}, 
  year={2023},
  volume={1},
  number={},
  pages={271-274},
  abstract={Digital twins, one of the new important technologies which started to be omnipresent in literature since Industry 4.0 got started, are becoming an essential part of the digital transformation processes in industry. Simply put, a digital twin is a virtual model designed to accurately reflect a physical object and is connected to the real asset with a bi-directional digital thread. Despite the different soft- and hardware architectures and applied fields digital twins are aimed to unify general architectural solutions, speed up design processes and provide reliable tools to provide safe, reliable and secure solutions for running physical systems. At the same time it is can be used as an educational tool, a framework to connect different technologies and it could be a bridge between Industry and Academia.},
  keywords={Industries;Analytical models;Software architecture;Data acquisition;Reliability engineering;Hardware;Digital twins;digital twin},
  doi={10.1109/IDAACS58523.2023.10348648},
  ISSN={2770-4254},
  month={Sep.},}@INPROCEEDINGS{9782999,
  author={Martynov, Vitaly and Filosova, Elena and Egorova, Yuliya},
  booktitle={2022 VI International Conference on Information Technologies in Engineering Education (Inforino)}, 
  title={Information Architecture to Support Engineering Education in the Era of Industry 4.0}, 
  year={2022},
  volume={},
  number={},
  pages={1-5},
  abstract={In order to meet the demands of Industry 4.0, the education system faces the task of forming the image of a student, which can be solved by creating his digital twin. The article discusses the existing approaches to the application of this technology in education. In the field of informatization of the educational process, they will form a development vector of student's educational trajectory. The technology of creating a digital twin of a student and the tasks that can be solved with its application are considered.},
  keywords={Engineering profession;Organizations;Predictive models;Prediction algorithms;Trajectory;Fourth Industrial Revolution;Digital twins;digital twin;education;industry 4.0;big data;student's digital twin;student's life trajectory},
  doi={10.1109/Inforino53888.2022.9782999},
  ISSN={},
  month={April},}@INPROCEEDINGS{9845301,
  author={Pan, Xudong and Fan, Hongwei and Zeng, Zhaoyang and Peng, Bo and Li, Jiaxin and Wang, Yuhong and Pan, Yuan and Yuan, Jiayu},
  booktitle={2022 IEEE 13th International Conference on Mechanical and Intelligent Manufacturing Technologies (ICMIMT)}, 
  title={Based on the Software RioD of Digital Twins of the Practice Teaching Research}, 
  year={2022},
  volume={},
  number={},
  pages={332-338},
  abstract={Harbin University of Technology Engineering Innovation Practice Center, in engineering training teaching, uses the teaching methods of virtual and reality, and inducts the digital twin software of RioD into the engineering practice teaching work. The digital twin software of RioD is used to build the intelligent manufacturing production line work scene, and completes the following four tasks: first the product leaves from the intelligent warehouse, then AGV transports the product to the transit platform, second, the robot grabs the product and completes the task of clamping and removing, and finally the work scene resets. Through virtual technology, the real production line is built in virtual space, which effectively solves the difficult problem that the practical teaching task can't be carried out, and significantly improves the quality of practical teaching, and stimulates student interest.},
  keywords={Training;Knowledge engineering;Technological innovation;Schedules;Production;Software;Digital twins;digital twins;engineering training;practical teaching;virtual combination;intelligent manufacturing;virtual simulation;virtual reality combination;talent training},
  doi={10.1109/ICMIMT55556.2022.9845301},
  ISSN={},
  month={May},}@INPROCEEDINGS{10784425,
  author={Butsanlee, Borihan and Pongaen, Watcharin and Rothong, Nuttapon and U-Thathong, Songkran},
  booktitle={2024 Research, Invention, and Innovation Congress: Innovative Electricals and Electronics (RI2C)}, 
  title={Design of Digital Twins for Collaborative Robots from Universal Robots}, 
  year={2024},
  volume={},
  number={},
  pages={206-210},
  abstract={This research is the design of the digital twin system for collaborative robots for Universal Robots. The aim is to design the digital twin system to analyze, track, maintain, predict and optimize production processes to help improve the efficiency of real systems and reduce waste. And increase productivity by creating a work environment model with the Unity 3D program and using RViz ROS and Gazebo programs to simulate the movement of virtual robots to work together with the movements of real robots. The results of digital twin system design can analyze the torque generated by modeling the robot's dynamics. It was found that the torque generated from the actual robot movement was 119.37 Newton meters, the torque generated from the robot movement from the dynamic model was 119.22 Newton meters, and the discrepancy between the torque generated and actual torque generated by the complete dynamic model was 0.125 %. The dynamic model of the digital twin system was found to be effective enough to be useful in analyzing movement postures or analyzing power consumption values collaborative robots.},
  keywords={Meters;Technological innovation;Analytical models;Solid modeling;Torque;Three-dimensional displays;Tracking;Collaborative robots;Digital twins;System analysis and design;Digital Twin;Dynamic Model;Robot Kinematic},
  doi={10.1109/RI2C64012.2024.10784425},
  ISSN={},
  month={Aug},}@INPROCEEDINGS{9766386,
  author={Salimi, Fabienne-Fariba and Salimi, Frederic and Taghipoor, Hosein and Mokhtarname, Reyhane and Safavi, Ali Akbar and Urbas, Leonhard},
  booktitle={2022 IEEE Global Engineering Education Conference (EDUCON)}, 
  title={Active Learning on the Collaborative Digital Twin of the Process Plants}, 
  year={2022},
  volume={},
  number={},
  pages={878-883},
  abstract={Digital twin is a valuable tool for the active training of engineers at both academic and professional levels. This is even more important if learners can experience any safe or unsafe scenarios on the safe environment of an accurate simulator combined with the systematic collaborative applications. This paper introduces a learning platform that is designed in compliance with ISO 10015 to be used following the individual initiatives or organizational competency management programs. The curriculum addresses the needs and expectations of Industry 4.0 engineers who should master not only the specialized subjects relevant to their discipline but also have a good grasp on system thinking, system engineering and complexity management skills. This active learning platform is called ADEPP Skill 4.0 and provides collaborative learning workspaces on a web-based operator training simulator (OTS) which interoperate with the SharePoint application.},
  keywords={Training;Systematics;Digital twin;ISO Standards;Conferences;Collaboration;Fourth Industrial Revolution;Digital Twin;Skill 4.0;ISO 1005;Active Learning;OTS;SharePoint;PSM;ADEPP},
  doi={10.1109/EDUCON52537.2022.9766386},
  ISSN={2165-9567},
  month={March},}@INPROCEEDINGS{9910286,
  author={Pexyean, Tanapeak and Saraubon, Kobkiat and Nilsook, Prachyanun},
  booktitle={2022 Research, Invention, and Innovation Congress: Innovative Electricals and Electronics (RI2C)}, 
  title={IoT, AI and Digital Twin For Smart Campus}, 
  year={2022},
  volume={},
  number={},
  pages={160-164},
  abstract={The objective of this research is to Present the use of Digital Twin. Internet of Things and Intelligence Technology to Intelligently Develop The Energy Management Potential of Campuses By using Digital Twin to manage energy consumption, it enables the creation of work and life on campus, whether it is personal. Teachers and students, including those with disabilities, have a better quality of life. Living on campus is more comfortable Collect energy consumption data, organizations to manage power management systems, reduce energy consumption, simplify management in all departments, and reduce campus costs. It can transparently monitor energy consumption and use educational equipment on campus, especially cost and expenditure management, and sustainable energy consumption, as well as management. Control usage data, energy consumption results, and budget allocations related to educational institutions can create reliability in managing information about electrical energy and energy competency assessment results, and can be recorded and controlled in Digital Twin that can be as if it were with a control center. IoT and Cloud Computing are also integrated with AI systems embedded in state-of-the-art equipment for use in environmental management and intelligent energy management. As well as creating new energy models and management that can resolve future emergencies by controlling virtual energy within the organization from outside anytime, anywhere.},
  keywords={Energy consumption;Technological innovation;Costs;Organizations;Strategic planning;Digital twins;Internet of Things;Internet of Things (IoT);Artificial Intelligence;Digital Twin;Smart Campus},
  doi={10.1109/RI2C56397.2022.9910286},
  ISSN={},
  month={Aug},}@INPROCEEDINGS{11088178,
  author={Kantabussabong, Ruj and Nantabut, Chinnawut and Pongaen, Watcharin and Rothong, Nuttapon and Butsanlee, Borihan},
  booktitle={2025 11th International Conference on Engineering, Applied Sciences, and Technology (ICEAST)}, 
  title={Energy-Efficient Motion Planning for Dual-Arm Collaborative Robots Using a Digital Twin}, 
  year={2025},
  volume={},
  number={},
  pages={239-242},
  abstract={The growing adoption of collaborative robots (cobots) in industrial applications has intensified the focus on optimizing energy efficiency. This study develops a digital twin for dual-arm ABB GoFa5 robots to estimate power consumption by integrating real-world sensor data for real-time monitoring and analysis. To understand how motion planning impacts energy usage, different algorithms, including CHOMP, RRT, and RRT*, were evaluated under no-load and loaded (2.5 kg) conditions. CHOMP demonstrated the highest energy efficiency, consuming up to 28% less power than RRT and 14% less than RRT* under no-load conditions, and up to 19% and 13% less, respectively, with a payload, confirming its effectiveness in optimizing cobot performance.},
  keywords={Torque;Power demand;Heuristic algorithms;Friction;Collaborative robots;Robot sensing systems;Energy efficiency;Planning;Digital twins;Payloads;Collaborative robots;digital twin;motion planning;energy efficiency},
  doi={10.1109/ICEAST64767.2025.11088178},
  ISSN={2768-4857},
  month={May},}@INPROCEEDINGS{10541032,
  author={Cao, Jianhua and Jiang, Zhigang and Hu, Wei and Xia, Xuhui and Liu, Xiang and Liu, Xiaoqin and Bao, Xiong},
  booktitle={2024 13th International Conference on Educational and Information Technology (ICEIT)}, 
  title={Research on Teaching Mode and Platform Construction of Intelligent Manufacturing Practical Training Based on Digital Twins Under the Background of New Engineering}, 
  year={2024},
  volume={},
  number={},
  pages={387-391},
  abstract={Aiming at the issues of high risks, high costs, and low efficiency in the training and teaching process of intelligent manufacturing, which seriously affect the quality of talent cultivation in intelligent manufacturing. By adopting digital twin technology, the intelligent manufacturing production line is mapped to virtual space, and a two-stage practical training teaching model that integrates virtual space simulation operations and physical space actual operations is constructed. And an intelligent manufacturing digital twin teaching platform was established to support the teaching model. The safe, efficient and economical operation of intelligent manufacturing practical training and teaching has been achieved.},
  keywords={Training;Costs;Welding;Transportation;Production;Real-time systems;Manufacturing;Intelligent manufacturing training;Teaching mode;Digital twin;Practical training and teaching platform},
  doi={10.1109/ICEIT61397.2024.10541032},
  ISSN={},
  month={March},}@INPROCEEDINGS{9249285,
  author={Rassudov, Lev and Korunets, Alina},
  booktitle={2020 XI International Conference on Electrical Power Drive Systems (ICEPDS)}, 
  title={COVID-19 Pandemic Challenges for Engineering Education}, 
  year={2020},
  volume={},
  number={},
  pages={1-3},
  abstract={The COVID-19 pandemic has impacted all the spheres human activities. The problems related with the forced self-isolation of people, closed borders between the countries as well as within the states push towards digitalization opening opportunities for bringing new technologies into everyday life. The paper focuses on the resulting dramatic changes in engineering education due to the current classical learning process paradigm shift. The brief overview of the problems is presented. The main challenge is to teach the future engineers to work with and to operate real hardware not available at home. The implementation of a Digital Twin concept for industrial equipment can partially solve the emerged problem related with hardware unavailability by the remote learning process as well as to improve the professional training quality as the pandemic is over.},
  keywords={Pandemics;Digital twin;Hardware;Computer aided instruction;COVID-19;Engineering education;Employment;Engineering education;industry applications;distance learning},
  doi={10.1109/ICEPDS47235.2020.9249285},
  ISSN={},
  month={Oct},}@INPROCEEDINGS{10456407,
  author={Zhang, Runfeng and Tang, Yuxin and Liu, Zhenzhong and Sun, Yanfang and Wu, Jianguo},
  booktitle={2023 4th International Conference on Information Science and Education (ICISE-IE)}, 
  title={Application of Digital Twin Technology in the Teaching of Engineering Drawing Course}, 
  year={2023},
  volume={},
  number={},
  pages={10-13},
  abstract={As an advanced technology that integrates virtuality and reality, digital twin technology has shown a wide range of application prospects in various fields. This paper aims to explore the potential application of digital twin technology in the teaching of engineering drawing courses, to improve students' theoretical knowledge and practical ability. By combining digital twin technology with traditional engineering drawing teaching, students can carry out practical operations and simulations in a virtual environment to better understand and apply drawing concepts and principles. Besides, taking the assembly drawing of thread connection as an actual teaching case, the specific application of digital twin technology in theoretical and experimental teaching is explained, respectively. The results show that digital twin technology is conducive to improving students' interest in engineering drawing courses and training students' spatial imagination ability, which is of great significance to reforming drawing courses.},
  keywords={Training;Knowledge engineering;Technological innovation;Information science;Engineering drawings;Education;Virtual environments;digital twin technology;engineering drawing;teaching reform;experimental teaching},
  doi={10.1109/ICISE-IE60962.2023.10456407},
  ISSN={},
  month={Dec},}@INPROCEEDINGS{11273634,
  author={Balbuzanov, T. and Beloev, I. and Topchu, D.},
  booktitle={2025 10th International Conference on Energy Efficiency and Agricultural Engineering (EE&AE)}, 
  title={Integrating Digital Tools in Transportation Engineering Education: From Formulas to Simulations}, 
  year={2025},
  volume={},
  number={},
  pages={1-4},
  abstract={The growing complexity of urban mobility systems and the increasing demand for sustainable transport solutions necessitate the integration of modern technologies into both transport planning and academic training. While digital tools alone cannot replace tested and proven practical approaches, their role as a support mechanism in optimizing mobility and educating future professionals is becoming increasingly significant. This paper explores the use of specialized simulation software and digital models in the context of higher education, with a focus on traffic engineering. Digital transformation in education provides opportunities for students to engage in realistic scenario analysis, traffic simulations, and system optimization without the need for interaction with real infrastructure. The implementation of such virtual environments allows for dynamic experimentation and promotes deeper understanding of complex traffic systems. By utilizing digital twins and simulation platforms such as PTV VISSIM and Data From Sky, students can gain insight into realtime data analysis, infrastructure design, and decision-making processes based on measurable parameters. The study emphasizes that while digitalization enhances learning, sustainable urban mobility ultimately depends on the application of effective strategies tested in real-world conditions.},
  keywords={Training;Transportation;Virtual environments;Organizations;Traffic control;Digital twins;Planning;Engineering education;Software tools;Optimization;Digital models;Transport simulation;Urban mobility;Traffic education;PTV VISSIM;Smart mobility},
  doi={10.1109/EEAE65901.2025.11273634},
  ISSN={},
  month={Nov},}@INPROCEEDINGS{11460342,
  author={Danzyuryun, Buyan},
  booktitle={2025 IEEE Integrated STEM Education Conference (ISEC)}, 
  title={Drones as a Platform for Integrated STEM Education: Bridging Engineering, Programming, and Real-World Applications}, 
  year={2025},
  volume={},
  number={},
  pages={1-3},
  abstract={The rapid evolution of unmanned aerial vehicles (drones) is revolutionizing various industrial applications, and their integration into education presents a unique opportunity for comprehensive STEM learning. This paper proposes a curriculum framework that harnesses drones as a versatile platform for integrated STEM education, bridging engineering design, computer programming, and real-world applications. Drawing inspiration from two industrial research projects—one on autonomous drone-based inspection systems for thermal power plant boilers and another on generating synthetic data using digital twins of industrial instruments—we demonstrate how advanced technologies can be adapted for classroom use. Our curriculum is structured into sequential modules that guide students through the process of assembling a modular drone kit, programming autonomous navigation in confined and challenging environments, and implementing computer vision algorithms for defect detection. In doing so, learners engage with fundamental STEM concepts such as aerodynamics, sensor integration, control systems, and machine learning. This hands-on, project-based approach not only cultivates technical proficiency and interdisciplinary problem solving but also fosters critical thinking, creativity, and collaborative skills among students. Furthermore, by simulating real-world industrial challenges, the framework provides educators with a robust model for professional development and curriculum integration. Ultimately, this integrated approach highlights the transformative potential of drone technology to make STEM education more engaging, relevant, and aligned with current industry practices, thereby preparing students to meet future technological challenges.},
  keywords={Protocols;HTTP;Network architecture;Internet;Linked data;Learning (artificial intelligence);Machine learning;Neural networks;Artificial intelligence;Autonomous robots;Autonomous Drone Systems;Computer vision;Digital twin technology;Neural network learning},
  doi={10.1109/ISEC64801.2025.11460342},
  ISSN={2473-7623},
  month={March},}@INPROCEEDINGS{10747951,
  author={Caribo, Onélia Fernanda and Sibomana, Louis and Byungura, Jean Claude and Asingwire, Barbara Kabwiga and Niyizamwiyitira, Christine},
  booktitle={2024 IEEE Digital Education and MOOCS Conference (DEMOcon)}, 
  title={Digital Twins Applications in STEM Education: Challenges and Implementation Opportunities in Developing Countries}, 
  year={2024},
  volume={},
  number={},
  pages={1-6},
  abstract={School laboratories generally offer opportunities to put the learned theoretical content into practice. In developing countries, not all secondary schools have access to laboratory classes for conducting laboratory experiments. In this study, we explore the opportunities and challenges of applying Digital Twins (DT) technology in the teaching process in developing countries, focusing on Mozambique and Rwanda. These challenges and opportunities will serve as means to analyze and inform the mechanisms needed to implement Internet of Things (IoT)-based technology to accommodate schools that do not have teaching laboratories. The interview-based questionnaire was administered in different secondary schools in Mozambique and Rwanda, and we applied the Yamane formula for the sample size. The cross-tabulation results showed that the application of DT technology in developing countries depends on factors such as infrastructure, connectivity, means of access and training of human resources. We also noticed through the study that some schools have such capabilities with which the integration of IoT, can be potential candidates for the application of DT. Similarly, those that do not have a physical laboratory, but have factors like connectivity and means of access, through DT they can access the web platforms.},
  keywords={Training;Computer aided instruction;Electronic learning;Laboratories;Focusing;Developing countries;Digital twins;Internet of Things;Artificial Intelligence;Digital Twins;Education;IoT;Laboratory},
  doi={10.1109/DEMOcon63027.2024.10747951},
  ISSN={},
  month={Oct},}@INPROCEEDINGS{10893435,
  author={Blackwell, Crystal and Rocke, Sean},
  booktitle={2024 IEEE Frontiers in Education Conference (FIE)}, 
  title={WIP: A Review of Digital Twin Technology in Undergraduate Control Engineering Education: Applications, Challenges, and Future Directions}, 
  year={2024},
  volume={},
  number={},
  pages={1-5},
  abstract={Contribution: This research, WIP paper describes a domain-specific, literature review on the use of Digital Twins (DTs) in undergraduate, Control Engineering Education (CEE). Such a body of work is currently absent from the scientific literature. The existing DT reviews were quantitatively assessed, and then the CEE applications, implementation possibilities, emerging opportunities, challenges, and future directions identified. Background: DTs are cutting-edge technologies, touted for their wide range of applications and services. As a result, domain-focused, DT reviews are often found in the scientific literature, to address the individual needs and challenges of various application domains. However, there is a need for such reviews in education and even CEE, which is itself tightly coupled to DT technology. Research Questions: 1. To what extent is education represented in recent, domain-specific, literature reviews on DTs as compared to other DT application domains? 2. What opportunities exist for the incorporation of DTs and their services into undergraduate, CEE and how can the challenges associated with their integration be addressed? Methodology: The methodology involved conducting a systematic literature review of peer-reviewed, domain-specific reviews published between 2019 and 2024 and then quantitatively as-sessing the representation of education and other application domains. Subsequently, peer reviewed, primary sources were syn-thesized into an integrative review on available DT services, CEE applications, emerging opportunities and challenges associated with DT implementations. Findings: This work has established that 1) there is a lack of application-focused, DT reviews in the field of education and its subdomain CEE 2) manufacturing and energy systems have the greatest prominence in existing DT reviews. 3) opportunities exist in learning theory-based DT design, novel enabling technologies, interacting DTs and sustainable education, and 4) challenges include the management of curricula, data, finances, change, and ethical issues, and 5) future works should develop frameworks that capitalise on the above opportunities.},
  keywords={Ethics;Education;Control engineering education;Digital twins;Manufacturing;Systematic literature review;control engineering;digital twins;educational technology;engineering education;engineering fields;laboratory;learning environment;technology applications;undergraduate},
  doi={10.1109/FIE61694.2024.10893435},
  ISSN={2377-634X},
  month={Oct},}@INPROCEEDINGS{10178517,
  author={Wilking, Fabian and Behringer, Marc and Fett, Michel and Goetz, Stefan and Kirchner, Eckhard and Wartzack, Sandro},
  booktitle={2023 18th Annual System of Systems Engineering Conference (SoSe)}, 
  title={Concept of a Modular and System Model Driven Digital Twin for Engineering Education}, 
  year={2023},
  volume={},
  number={},
  pages={1-7},
  abstract={Driven by the opportunities for condition monitoring and new business models, Digital Twins have become a popular topic within research and industrial application over the last years. Therefore, universities must integrate the development of Digital Twins into their educational program to enable future engineers to overcome the challenges concomitant with Digital Twins. While a theoretical basis for Digital Twins is crucial e.g., hardware-software integration, Internet of Things (IoT) or simulation models, a practical combination of these heterogeneous components is also necessary to introduce the Digital Twin as a whole concept. With Model-Based Systems Engineering (MBSE) an approach was introduced to grasp complexity by using system models e.g., through SysML diagrams. Digital Twins are an example for advanced systems shaped by high complexity. The usage of system models is therefore likely. With this contribution, a concept is presented to combine system models and Digital Twins to create a prototype for academic education and the conduction of student projects.},
  keywords={Condition monitoring;Educational programs;Prototypes;Digital twins;Complexity theory;Internet of Things;Modeling;Digital Twin;MBSE;Systems Engineering;System Model;SysML},
  doi={10.1109/SoSE59841.2023.10178517},
  ISSN={2835-3161},
  month={June},}@INPROCEEDINGS{10835590,
  author={Zhuming, Cao and Huanbo, Dong and Jide, Jia and Shouhua, Yi},
  booktitle={2024 3rd International Conference on Data Analytics, Computing and Artificial Intelligence (ICDACAI)}, 
  title={Research on Intelligent Manufacturing Production Lines for Automobile Wheel Hubs by Digital Twin Models}, 
  year={2024},
  volume={},
  number={},
  pages={825-829},
  abstract={Due to the complex geometric shapes, high precision design dimensions, and specific material characteristics of automobile wheel hubs, there are stringent requirements for processing procedures, efficiency, and stability. To meet these demands, enterprises commonly adopt intelligent manufacturing production lines. Key challenges include establishing adaptive intelligent capabilities for the "processing-measurement-compensation-processing" cycle, constructing digital twin models of wheel hub production lines for real-time synchronization in virtual reality production, optimizing equipment and process interfaces, and improving fixture systems. Integrating discrete CNC machining, inspection, and assembly organically is crucial for smart manufacturing engineers. This article provides targeted discussions on core technologies and development directions in this field.},
  keywords={Solid modeling;Shape;Wheels;Production;Virtual reality;Stability analysis;Digital twins;Automobiles;Synchronization;Smart manufacturing;Wheel Hubs;Intelligent Manufacturing;Key Technologies;Current Status;Prospects},
  doi={10.1109/ICDACAI65086.2024.00155},
  ISSN={},
  month={Oct},}@INPROCEEDINGS{9737170,
  author={Mokhtarname, Reyhane and Safavi, Ali Akbar and Urbas, Leonhard and Salimi, Fabienne and Taghipour, Hosein},
  booktitle={2022 8th International Conference on Control, Instrumentation and Automation (ICCIA)}, 
  title={A Typical Skill 4.0 Platform for Process Safety Management}, 
  year={2022},
  volume={},
  number={},
  pages={1-5},
  abstract={In the 20th century, the engineering curriculum aimed to educate the specialist engineers. Observation skills were enforced after learning the fundamental theory of the scientific and engineering topic in face-to-face classrooms where professors taught the subject matter. Students were engaged in the courses upon the available time and with the professor teaching style. Along the fourth industrial revolution, new engineering education platforms based on some new and desired skills are required to cope with the changes in production and quality assurance requirements. This paper proposes an active collaborative learning platform in which the learners can learn by doing and serious engagement. The developed platform provides the digital twin of process safety engineering and management systems for a real complex polymerization plant. This platform can be used for training of engineers at both academia and industry.},
  keywords={Industries;Training;Quality assurance;Digital twin;Collaboration;Safety management;Production;Industry 4.0;Skill 4.0;Digital Twin;Safety Analysis;Education Platform},
  doi={10.1109/ICCIA54998.2022.9737170},
  ISSN={},
  month={March},}@INPROCEEDINGS{10578843,
  author={Ballinas, Romeo and Urcid, Rodrigo and Medrano, Juan Pablo},
  booktitle={2024 IEEE Global Engineering Education Conference (EDUCON)}, 
  title={Photogrammetry as a Method of Educational Innovation. Civil Engineering Student Case Study}, 
  year={2024},
  volume={},
  number={},
  pages={1-6},
  abstract={Educational innovation is a daily challenge for both students and teachers. Over the years, new pedagogies and models have been developed so that both stakeholders can make the most of the spaces inside and outside the classroom. In response to this, there are various tools that not only facilitate student engagement in the class but also enable the instructor to use them to make sessions more active and raise the cognitive level. An example of what was described above is virtual or digital laboratories; these are interactive platforms that adapt to different styles of learning and teaching. In addition to this, they promote collaboration among students, motivate, nurture creativity, and allow for the repetition of experiences without the need to be physically present where the work is being done. This, in turn, results in the introduction of hybrid learning methods [1]. On the other hand, a tool that aids in the performance of these laboratories is photogrammetry, which is a remote information capture system. It includes remote sensing and photointerpretation, techniques that complement each other. However, it can be affirmed that photogrammetry is realized through a quantitative interpretation of aerial photographs and other aerial photographic materials to obtain maps [2]. Based on the elements described above, it is understood that educational innovation is at a point where, thanks to the appropriate use of technology, a teaching and learning process can be actively involving both teachers and students Urban heritage, encompassing both tangible and intangible heritage, is a valuable resource that can be effectively integrated into education. The digitization of historical and urban buildings through photogrammetry has become an innovative tool for transforming the way students interact with the built environment and cultural heritage. This combination of technology and education enables students to actively explore and learn about urban heritage, thereby contributing to its preservation. With the previous paragraphs as context, the aim of this article is to demonstrate the effectiveness of using photogrammetry to create digital twins of buildings and thus transform the concept of digital laboratories. The idea is that, using a technological tool, the learning process of undergraduate students can be enhanced by the digitization of buildings. The study presented here is conducted under a quantitative approach; specifically, a questionnaire consisting of five Likert scale items is administered to the students studying Civil Engineering at a private university in Puebla, Mexico. Finally, it must be acknowledged that virtual laboratories have transformed the educational process. Specifically, photogrammetry is a tool that helps students carry out various digital interventions on different buildings, enhancing their learning.},
  keywords={Technological innovation;Education;Laboratories;Buildings;Transforms;Digital twins;Information and communication technology;educative innovation;photogrammetry;digitalization;buildings;structures;digital twins},
  doi={10.1109/EDUCON60312.2024.10578843},
  ISSN={2165-9567},
  month={May},}@INPROCEEDINGS{9597748,
  author={Zhang, Xinan and Li, Ran and Wang, Yuxuan and Manandhar, Ujjal},
  booktitle={2021 31st Australasian Universities Power Engineering Conference (AUPEC)}, 
  title={Digital Twin Real-time Hybrid Simulation Platform for Engineering Education in Renewable Energy}, 
  year={2021},
  volume={},
  number={},
  pages={1-6},
  abstract={This paper proposes a very cost-effective digital twin real-time hybrid simulation platform for engineering education in renewable energy areas. Compared to many of the existing laboratory setups that are designed for renewable engineering education, the proposed platform provides greater flexibility, better skill training opportunities, and excellent system extendibility. Its power hardware-in-the-loop (PHIL) based hybrid simulation results are desirable for industry applications. Furthermore, the proposed platform can receive real-time information of renewable energy systems through ethernet based communication. The superior performance and flexibility of the proposed platform are verified by experiments.},
  keywords={Training;Renewable energy sources;Power engineering;Digital twin;Simulation;Industry applications;Real-time systems;digital twin;real-time simulation;power hardware-in-the-loop;engineering education;renewable energy},
  doi={10.1109/AUPEC52110.2021.9597748},
  ISSN={2474-1507},
  month={Sep.},}@INPROCEEDINGS{9942754,
  author={Bitsch, Günter and Senjic, Pascal and Kneip, Petra},
  booktitle={2022 IEEE German Education Conference (GeCon)}, 
  title={Hybrid individualized assistance-oriented learning system framework for STEM-Education}, 
  year={2022},
  volume={},
  number={},
  pages={1-5},
  abstract={The imparting of knowledge and skills in STEM education, especially under the influence of the Covid-19 pandemic, is increasingly taking place online and through digital formats. The partially asynchronous instruction eliminates, on the one hand, the social relation in the learning process and, on the other hand, the direct experience with physical objects. Here, the digital learning systems provide learning tools and controls to support the learning process on a general basis. Existing methods for simulating physical objects (digital twins) are also used to a minimal extent. The following approach presents a learning system framework that enables individualized learning, including all dimensions (social, physical). Implementing a concept that uses a personalized assistance system to orchestrate the individual learning steps enables efficient and effective learning. Applying the learning system framework exemplifies the STEM education at Reutlingen University in the logistics learning factory Werk150.},
  keywords={Learning systems;COVID-19;Pandemics;Education;Process control;Production facilities;Digital twins;Learning Framework;Individual Learning;assistance system},
  doi={10.1109/GeCon55699.2022.9942754},
  ISSN={},
  month={Aug},}@INPROCEEDINGS{10784437,
  author={Pexyean, Tanapeak and Saraubon, Kobkiat and Nilsook, Prachyanun},
  booktitle={2024 Research, Invention, and Innovation Congress: Innovative Electricals and Electronics (RI2C)}, 
  title={AI Simulation, IoT, and Digital Twin for Smart Campus}, 
  year={2024},
  volume={},
  number={},
  pages={176-182},
  abstract={The objective of this research is to Present the use of Artificial intelligence Simulation(AI Simulation), Internet of Things(IoT) and Digital Twin Technology to Intelligently To develop the energy management potential of the campus intelligently by using technology to improve the environment, making the system smarter and more connected. This helps to make living in an urban community or university more comfortable. The adoption of various technologies has led to development in many fields, such as smart cities, smart homes, smart robots, smart machines Smart cars, smart agriculture, smart healthcare, and smart traffic control systems have the challenge of developing systems that allow devices to connect to the system quickly. One of the interesting ideas is Smart Campus, which is an educational institution that creates learning to develop individuals to be able to improve the world. The use of Internet of Things (IoT) technology, artificial intelligence, simulation, and the creation of digital twins. The use of IoT helps collect and exchange data from various devices in the network, enabling effective monitoring and control of the operation of various systems. Simulation allows for the creation of different scenario models to experiment and improve the system before it is actually implemented. It is a virtual model of a system or device to be used to track electricity consumption and optimize electrical energy management in real time. The application of these technologies in smart campuses will help to manage resources more efficiently, such as electrical energy management. Improvement of the transportation system within the university Security, and enhancing modern learning experiences. Developing the university into a smart campus not only improves operational efficiency but also helps to use energy efficiently. Reduce energy costs Reduce carbon dioxide emissions and create a sustainable and environmentally friendly learning environment both now and in the future.},
  keywords={Temperature sensors;Energy consumption;Costs;Strategic planning;Digital twins;Internet of Things;Energy management;Artificial intelligence;Sustainable development;Monitoring;Artificial Intelligence Simulation (Ai Simulation);Internet of Things (IoT);Digital Twin;Smart Campus},
  doi={10.1109/RI2C64012.2024.10784437},
  ISSN={},
  month={Aug},}@INPROCEEDINGS{10578918,
  author={Palomés, Xavier Pi I and Verdaguer-Codina, Joan and Casas, Pau Fonseca I and Rubiés-Viera, José Luis},
  booktitle={2024 IEEE Global Engineering Education Conference (EDUCON)}, 
  title={Physical and Digital Twin with Computational Thinking to Foster STEM Vocations in Primary Education}, 
  year={2024},
  volume={},
  number={},
  pages={1-8},
  abstract={This work aims to explore the application of the physical and digital twin pair as a computational thinking instrument to support learning and exercise proportional reasoning at the ages at which pursuing STEM studies is decided. Diverse studies reveal that the initial decision about the vocation in studies is made towards the end of the primary education stage, also from 8–9 years old. The Digital Transformation Commission of the Engineering Associations of Catalonia is concerned about the low number of young people who decide to pursue STEM studies. STEM explorations in early childhood lay the foundation for lifelong learning. In addition, from age 5, children informally begin to practice proportional reasoning, and in the third year of primary school (8–9 years old), the subject is formally introduced into the Primary Education curriculum. The notion of proportionality is very transversal, and it is one of the fundamental concepts of the STEM field. The consequences of an incomplete understanding of it directly or indirectly affect the attitude of subjects toward mathematics and the STEM world. With the emergence of Industry 4.0, the digital twin concept is becoming one of the central instruments of Digital Transformation. In this paper, we propose using computational thinking to help the understanding of proportional thinking using a physical and digital twin pair. In 2022, computational thinking was introduced into the Spanish and Catalan educational system's early childhood, primary, and secondary education curricula. It includes programming with block languages such as Scratch or Snap!. A digital twin of the system has also been implemented in Snap!. Through the collaboration of a primary school, a workshop has been prepared in which they exercise the concepts of proportional reasoning, such as ratio, proportion, scale, or percentage. The approach followed has consisted of developing a physical system of a floating ball, controlling the electric motor's power with an electronic system based on low-cost elements from the maker world. We have designed a very easy-to-use system for any teacher, and its open-source nature ensures its transparency and documentation. The foam ball rises and remains floating at a height determined by the power supplied to the motor. The control of the system is carried out with Snap!. It will be assumed that the engine revolutions are proportional to the power setpoint. The physical system generates a high level of expectation and attention in the students, facilitating the process of its abstraction. The range of options of the developed system allows experimenting with the actual system and a schematic digital twin with sound effects. In all cases, the same computational thinking tools have been used to exercise the concepts and powerful ideas of proportional reasoning. At the end of the workshop, the understanding of the concepts exercised and the assessment of their personal experience were evaluated. This gave us helpful information to motivate students of these ages and below to maintain their STEM vocation.},
  keywords={Computers;Instruments;Conferences;Toy manufacturing industry;Documentation;Cognition;Digital twins;Microworlds;Digital Twin;STEM;Computational Thinking;Proportional Reasoning},
  doi={10.1109/EDUCON60312.2024.10578918},
  ISSN={2165-9567},
  month={May},}@INPROCEEDINGS{10895607,
  author={P, Valarmathie and G, Guruvarshni},
  booktitle={2024 International Conference on Emerging Research in Computational Science (ICERCS)}, 
  title={Revolutionizing Education through Digital Twin Technology: Key Techniques and Applications}, 
  year={2024},
  volume={},
  number={},
  pages={1-8},
  abstract={Digital Twin technology, which was first employed in industry, is now providing exciting opportunities for education. Imagine kids learning through interaction with virtual representations of real-world systems experimenting, making mistakes, and comprehending complex processes in a secure environment. However, today's Digital Twin educational applications often fall lacking when it comes of flexibility and differentiation. The study explores the key techniques used in the digital twin technology in education, includes Real-Time Data Integration, AI-Driver Feedback Mechanisms, Simulation and Interactive Learning, Personalization, Performance analytics and Learning Insights. The essential aspects of the framework, such as the data collection for gathering raw data, the data processing for preparing, the data transformation for formatting data for the Virtual Learning Environment (VLE), dashboard and data Visualization to provide feedback and insights for educators. Our platform is designed to be adaptable and scalable, making it easy to fit into various educational settings and adapt to different learning goals. This survey aims to make these powerful learning tools accessible to more students, enhancing their education in meaningful ways.},
  keywords={Industries;Surveys;Technological innovation;Scientific computing;Education;Real-time systems;Data models;Digital twins;Safety;Dynamical systems;Digital Twin Technology;AI Integration;Interactive Learning;Real-time Feedback;Personalized Education},
  doi={10.1109/ICERCS63125.2024.10895607},
  ISSN={},
  month={Dec},}@INPROCEEDINGS{9420037,
  author={Deng, Juan and Zheng, Qingbi and Liu, Guangyi and Bai, Jielin and Tian, Kaicong and Sun, Changhao and Yan, Yujie and Liu, Yitong},
  booktitle={2021 IEEE Wireless Communications and Networking Conference Workshops (WCNCW)}, 
  title={A Digital Twin Approach for Self-optimization of Mobile Networks}, 
  year={2021},
  volume={},
  number={},
  pages={1-6},
  abstract={Most of the methods in operators' current 5G networks use expert knowledge assisted by machine learning algorithms to generate optimization decisions. However, these methods are inadaptive to the dynamic changes of high-dimensional network states, thus the result is often suboptimal. Reinforcement learning can better cope with high-dimensional network state space and parameter space. However, when applied to real network, challenges arise such as difficult to obtain data samples, time-consuming and risky to explore real networks during model training. To solve these problems, this paper proposes a combined approach of expert knowledge, reinforcement learning and digital twin for the self-optimization of mobile networks. By constructing a digital twin of the current network, the future network state is predicted based on which optimization decisions are generated by expert knowledge and reinforcement learning respectively, and then input into the digital twin. Digital twin simulates their rewards and decides a final action for execution. Simulation results have confirmed that the proposed scheme can achieve higher rewards than either expert knowledge or reinforcement learning, and can avoid negative impact on real network performance. This paper also describes several potential application scenarios for the proposed approach in 6G networks and discusses key issues for future research.},
  keywords={Knowledge engineering;Training;6G mobile communication;Machine learning algorithms;Digital twin;Conferences;Simulation;mobile network self-optimization;digital twinning;reinforcement learning},
  doi={10.1109/WCNCW49093.2021.9420037},
  ISSN={},
  month={March},}@INPROCEEDINGS{9722375,
  author={Rassudov, Lev and Korunets, Alina},
  booktitle={2022 29th International Workshop on Electric Drives: Advances in Power Electronics for Electric Drives (IWED)}, 
  title={Virtual Labs: an Effective Engineering Education Tool for Remote Learning and not only}, 
  year={2022},
  volume={},
  number={},
  pages={1-4},
  abstract={operating real hardware is a fundamental engineering skill. For this reason, hands-on classes involving real equipment is an essential tool in engineering education. At the same time in many cases there are certain limitations related to in-person training of students: hardware availability, hardly modifiable functionality for each student and educational goal, the increased demand on remote learning and safety aspects. Modern information technologies enable various means for partially solving the mentioned issues by providing remote access, VR-technologies, digital twins, etc. The paper provides a brief overview of aspects related to introducing virtual labs into educational process, with the main focus on the requirement for the virtual hardware, such as an electric power drive system, should replicate processes with time resolution in order of several milliseconds. And the interaction of the equipment with the student should be done in a way there is a feeling of a real object, necessitating low response time in order of hundreds of milliseconds. This requires high priority of computational power allocation for mathematical model calculation as well as high communication channel bandwidth between the computation power source and the user interface. The paper presents an example of such a server deployed virtual laboratory. The functionality was inspired by that of real equipment installed at Energy saving electric power drive laboratory at the Department of Electric Drives of Moscow Power Engineering Institute. Apart from substantively replicating the functionality and feel of high-dynamic hardware real-time operation, it enables to provide each student with an individual virtual equipment set to be explored, tuned or diagnosed. Virtual labs of the kind proved to be an effective engineering education tool for remote learning, giving new opportunities in improving the in-person training process as well.},
  keywords={Training;Power engineering;Distance learning;User interfaces;Hardware;Real-time systems;Power systems;engineering education;industry applications;distance learning;robotic systems;fault diagnosis;simulation;cloud services;digital twin.},
  doi={10.1109/IWED54598.2022.9722375},
  ISSN={2767-7842},
  month={Jan},}@INPROCEEDINGS{11172534,
  author={Gallego, Jaime and Vallverdú, Francesc},
  booktitle={2025 11th International Conference on Virtual Reality (ICVR)}, 
  title={Low-Cost Digital-Twin VR Teleoperation of a 3D-Printed Robotic Arm for STEM Education}, 
  year={2025},
  volume={},
  number={},
  pages={351-356},
  abstract={The integration of Virtual Reality (VR) with robotic systems offers opportunities for enhancing STEM (Science, Technology, Engineering, and Mathematics) education. This paper presents the design, implementation, and evaluation of a low-cost teleoperation system for a 3D-printed robotic arm, specifically tailored for educational applications. The system uniquely combines VR for intuitive control, a real-time digital twin for system visualization and understanding, and accessible open-source hardware. Utilizing a Meta Quest 2 headset, the Unity 3D engine, an Arduino MEGA 2560 -based InMoov robotic arm, and a wireless communication architecture via an ESP32 module and UDP/IP, we demonstrate that this platform can be used for educational purposes. Experimental results validate the system’s effectiveness in providing an engaging, hands-on platform for students to explore concepts in robotics, programming, kinematics, and cyber-physical systems with an average operational latency of $\sim 700 \mathrm{~ms}$. The complete robotic arm materi-als-excluding the assembly-can be reproduced for under € 400, greatly lowering the barrier for adoption in resource-constrained classrooms. This work underscores the potential of affordable VRrobotic digital twin systems to democratize access to advanced technological learning experiences in STEM.},
  keywords={Wireless communication;Visualization;Education;Virtual reality;Manipulators;Three-dimensional printing;Digital twins;Robots;STEM;Robot programming;STEM Education;Virtual Reality;Digital Twin;Robotics;Teleoperation;Low-Cost Systems;3D Printing;Arduino;Unity;ESP32},
  doi={10.1109/ICVR66534.2025.11172534},
  ISSN={},
  month={July},}@INPROCEEDINGS{10536194,
  author={Fiore, Marco and Gattullo, Michele and Mongiello, Marina},
  booktitle={2024 IEEE Conference on Virtual Reality and 3D User Interfaces Abstracts and Workshops (VRW)}, 
  title={First Steps in Constructing an AI-Powered Digital Twin Teacher: Harnessing Large Language Models in a Metaverse Classroom}, 
  year={2024},
  volume={},
  number={},
  pages={939-940},
  abstract={This study proposes a ground-breaking idea at the intersection of Artificial Intelligence and virtual education: the creation of an AI-powered Digital Twin instructor in a Metaverse-based classroom using Large Language Models. We aim to build a teacher avatar capable of dynamic interactions with students, tailored teaching approaches, and contextual response inside a virtual world. The research aims to address two major issues for both students and teachers: the Digital Twin can provide feedbacks to resolve doubts about course content and material; also, it can improve student management and allow teachers to answer the trickiest questions raised by students.},
  keywords={Three-dimensional displays;Metaverse;Conferences;Avatars;Education;User interfaces;Digital twins;Social and professional topics—Professional topics—Computer education programs—Software engineering education;Computing methodologies—Artificial intelligence—Natural language processing—Discourse, dialogue and pragmatics Applied computing—Education—Computer-assisted instruction},
  doi={10.1109/VRW62533.2024.00266},
  ISSN={},
  month={March},}@INPROCEEDINGS{11384118,
  author={Zheng, Xiaobin and Pan, Yifei and Liu, Ziman and Wu, Chengwei and Zhang, Yijian and Wang, Yan and Liu, Chenchen},
  booktitle={2025 5th International Conference on New Energy and Power Engineering (ICNEPE)}, 
  title={Safety Management of Substation Construction Based on Digital Twin Technology}, 
  year={2025},
  volume={},
  number={},
  pages={156-164},
  abstract={As the scale of power grid construction expands and safety regulations become more stringent, traditional safety management for substation construction struggles to address complex challenges such as high-altitude work and high-risk environments. To resolve critical issues like poor risk identification and lagging control measures, this paper proposes a safety management method based on digital twin technology. The method involves creating a high-fidelity digital twin model that integrates BIM, IoT sensors, and multi-dimensional modeling techniques, allowing for the precise labeling of high-risk work zones. By deploying cameras and smart sensors, the system can capture and extract the behavioral features of construction personnel in real-time. These features can then be compared against a pre-set optimal working condition database to enable the intelligent identification of unsafe behaviors and trigger high-risk warnings. This approach facilitates applications such as dynamic monitoring, predictive risk warnings, and emergency drills, demonstrating its potential to enhance the precision and intelligence of substation construction safety management.},
  keywords={Industries;Visualization;Substations;Power system dynamics;Safety management;Feature extraction;Real-time systems;Digital twins;Monitoring;Intelligent sensors;Digital Twin;Substation Construction;Safety Management;Risk Warning;Behavior Recognition;3D Model},
  doi={10.1109/ICNEPE67923.2025.11384118},
  ISSN={},
  month={Nov},}@INPROCEEDINGS{11432280,
  author={Gordan, Meisam and Cabrera, David Ayala},
  booktitle={2026 18th International Conference on Knowledge and Smart Technology (KST)}, 
  title={Designing A Three-Layer Pedagogical Architecture for Integrating Digital Twin and Machine Learning in Engineering Education}, 
  year={2026},
  volume={},
  number={},
  pages={428-433},
  abstract={Digital Twin is a relatively new technology in education and there is a limited understanding of how it can effectively be used in teaching engineering. Data-driven modelling is now central to civil and infrastructure engineering, yet most early-stage programming modules still stop at generic exercises. Focusing on pedagogical design rationale and theoretical validation, this paper presents a methodological framework for integrating a Digital TwinMachine Learning (DT-ML) block into a second-year module, i.e., Computer Applications in Civil Engineering at University College Dublin. The redesign has two main contributions, i.e., a three-layer DT-ML pedagogical architecture is proposed, and design principles are derived. These principles connect constructive alignment and experiential, inquiry-based learning to the teaching of DT and ML content. In other words, the redesign aims to strengthen the relevance, coherence and pedagogical depth of the mentioned module as well as examining how DT concepts and introductory ML can be meaningfully incorporated into the module for civil engineering students.},
  keywords={Knowledge engineering;Uncertainty;Refining;Computer architecture;Machine learning;Computer applications;Digital twins;Sensors;Civil engineering;Programming profession;digital twin;digitalisation;curriculum design;inquiry-based learning;higher education},
  doi={10.1109/KST67832.2026.11432280},
  ISSN={2473-764X},
  month={Jan},}@INPROCEEDINGS{10552003,
  author={Dianova, Yulia and Stolbova, Irina and Tarasova, Lyubov},
  booktitle={2024 7th International Conference on Information Technologies in Engineering Education (Inforino)}, 
  title={From Assembly Drawing to Virtual Model: Manufacturing Technologies in Engineering Education}, 
  year={2024},
  volume={},
  number={},
  pages={1-4},
  abstract={The work demonstrates the possibilities of utilizing visualization of a digital model in the educational process of higher education in the training of engineers. As part of an educational design bureau, based on an assembly drawing, students need to develop an electronic model of a technical product, parameterize and visualize it, and prepare design documentation. The presentation of the project is carried out in a virtual reality system. Product design is carried out in T-FLEX CAD. This program is a professional design system for 2D and 3D modeling and is included in the package of the Russian PLM information system. Analysis of the content and effectiveness of educational activities on three-dimensional visualization of digital models, performed during group work, updates a number of traditional knowledge, skills and abilities for a qualified engineer. In the process of work, competencies of an advanced, innovative nature are also formed, related to both the professional and communicative spheres.},
  keywords={Knowledge engineering;Visualization;Solid modeling;Three-dimensional displays;Virtual reality;Product design;Engineering education;digital model;digital double;3D visualization;computer modeling;engineering graphics;T-FLEX CAD;virtual reality (VR)},
  doi={10.1109/Inforino60363.2024.10552003},
  ISSN={},
  month={April},}@INPROCEEDINGS{9766459,
  author={Rivera-Calderón, Samantha and Lázaro, Rafael Pérez-San and Vazquez-Hurtado, Carlos},
  booktitle={2022 IEEE Global Engineering Education Conference (EDUCON)}, 
  title={Online assessment of computer vision and robotics skills based on a digital twin}, 
  year={2022},
  volume={},
  number={},
  pages={1994-2001},
  abstract={This paper presents online simulation along with physical environments employing digital twins to develop robotic and computer vision applications, such as bin picking, by providing a virtual testing environment with real conditions for robotic systems and their surroundings. Particularly for situations such as the current COVID-19 pandemic, this approach permits the integration of knowledge and practice remotely without having the need of requiring a physical robot, increasing equity and inclusivity in the assessment, by reducing the gap between students from different institutions due to the lack of resources to buy the required robotic devices and even enabling remote connection to the classrooms. The proposed task can be performed as long as the educational center counts with basic computer equipment and internet connection. This paper presents a bin picker application based on mono and stereo vision to make the classification of cylinders of different colors and sizes and their arrangement in a base by using image processing and depth estimation algorithms. The performance of the classification was measured in terms of the error in millimeters from the difference of the desired and the obtained position. The images used for classification were taken in real life considering the environment conditions, and a digital twin of the bin picker and objects was made. The image classification and the overall instructions that the robot performed were generated on MATLAB, where the data from the real environment captured by cameras was sent. From here, the instructions were sent to URsim, which serves as the robot controller, and the final virtual simulation with the models of the base and cylinders was performed on Kuka-Sim Pro. This approach can then be utilized to implement different assessments based on personal results from simulation activities. As this assessment requires specialized knowledge regarding robotics, computer vision and classification algorithms, this methodology is intended to be applied for university students, at the level that is adequate according to the educational programs of each university.},
  keywords={Computer vision;Computational modeling;Digital twin;Virtual environments;Estimation;Classification algorithms;Stereo vision;Bin picker;digital twin;classification;computer vision;perception;educational innovation;higher education},
  doi={10.1109/EDUCON52537.2022.9766459},
  ISSN={2165-9567},
  month={March},}@INPROCEEDINGS{11403892,
  author={Hadi, Abdul and Motati, Lakshmi Reddy and Anasuri, Sunil and Enjam, Gowtham Reddy and Kumar Pappula, Kiran and Gupta, Deepak},
  booktitle={2025 International Conference on AI-Driven STEM Education and Learning Technologies (AISTEMEDU)}, 
  title={AI-Enabled Smart Infrastructure for Sustainable STEM Education Ecosystems: Leveraging Intelligent Systems to Support Renewable Energy, Resource Optimization, and Green Campuses}, 
  year={2025},
  volume={},
  number={},
  pages={1-7},
  abstract={The increased digitization of educational systems and the worldwide need to be sustainable require the implementation of artificial intelligence (AI) into campus life. Laboratories, computing clusters, smart classrooms, internet of things enabled devices all consume a lot of energy and resources and traditional methods of management are having a hard time balancing demand and optimizing the use of resources and ensuring efficiency. The paper presents a smart infrastructure design that uses AI, integrates renewable energy systems, and green technologies to aid in sustainable STEM campuses. Based on this contract, the framework incorporates predictive analytics, long short-term memory (LSTM) forecast, reinforcement learning-based optimization and graph-structured digital twin models for load predicting, multi-resource coordination in real-time and adaptive utility management. Prototype implementation and hybrid simulation validation demonstrate the effectiveness of the proposed optimization in terms of energy consumption (21.4%), amount of renewable energy consumed (18.7%) and carbon emission (15.3%) over the optimization rules-based and smart-grid baselines. These quantified results validate the framework’s scalability and real-world relevance for sustainable AI-driven learning environments.},
  keywords={Renewable energy sources;Energy consumption;Adaptive systems;Green products;Education;Ecosystems;Digital twins;Internet of Things;Optimization;Long short term memory;Smart Infrastructure;AI in Education;Renewable Energy;Green Campuses;Resource Optimization;Sustainable STEM Ecosystems;Digital Twins},
  doi={10.1109/AISTEMEDU67077.2025.11403892},
  ISSN={},
  month={Dec},}@INPROCEEDINGS{11477589,
  author={Chobanov, Veselin and Manukova, Aneliya and Zaharieva, Snezhinka},
  booktitle={2026 25th International Symposium INFOTEH-JAHORINA (INFOTEH)}, 
  title={Digital Twin Lab for PLC–Robot Integration}, 
  year={2026},
  volume={},
  number={},
  pages={1-6},
  abstract={The paper presents a structured practical exercise in the discipline “Industrial Electronic Systems” (summer semester), conducted with fourth-year students, Bachelor's degree program, majoring in Electronics at Angel Kanchev University of Ruse. The exercise is aimed at developing competencies for integrated management and verification of systems in industrial automation through simulation-based implementation (digital twin) of a robotic palletizing cell, including a Fanuc industrial robot, a gripper, a conveyor, discrete position sensors (pallet A/B), and PLC control. The methodology follows a step-by-step approach: I/O specification and tag structure, PLC mode logic with safety interlocks (emergency stop and door), modular robot programming, parameterization of $4 \times 4 \times 3$ arrangement via registers, network configuration and I/O mapping, as well as verification through functional and emergency test scenarios with acceptance criteria. The proposed approach provides a safe, reproducible, and scalable laboratory environment close to industrial integration and commissioning tasks with limited hardware resources.},
  keywords={Circuits;Protocols;Communication systems;IP networks;Telecommunications;HTTP;Computer networks;Couplers;Radio access networks;Regional area networks;digital twin;industrial automation;PLC;industrial robot;engineering education},
  doi={10.1109/INFOTEH68759.2026.11477589},
  ISSN={2767-9470},
  month={March},}@INPROCEEDINGS{11328634,
  author={Colace, Francesco and Ferrandino, Flavia and Lombardi, Marco and Lorusso, Angelo and Valentino, Carmine},
  booktitle={2025 IEEE Frontiers in Education Conference (FIE)}, 
  title={Digital Twin and Predictive Maintenance in Cultural Heritage: A Multidisciplinary Educational Experience with HBIM and IoT}, 
  year={2025},
  volume={},
  number={},
  pages={1-8},
  abstract={This Research to Practice Full Paper describes a project that combines different fields to include Heritage Building Information Modelling (HBIM), Internet of Things (IoT) sensor systems, and the digital twin (DT) concept into the hands-on learning experiences for construction engineering and architecture students at the university. This methodology was used in the “Computer Graphics” course at the University of Salerno, where third-year students engaged in a data-driven digital workflow concerning the genuine case study of Villa Regina, a Roman rural villa situated inside the archaeological site of Pompeii. The students engaged thoroughly in the complete digitization process, encompassing 3D surveying through terrestrial laser scanning and aerial photogrammetry and culminating in the development of HBIM models augmented with semantic and degradation metadata. Subsequently, they developed and executed IoT-based monitoring systems utilizing Raspberry Pi and Arduino platforms and constructed DT simulations to investigate predictive maintenance tactics. An interdisciplinary collaboration between architecture, computer science, and conservation supported the course, which was structured on a project-based learning framework. The assessment, which was conducted through structured surveys and project analysis, demonstrated substantial improvements in technical proficiency, data literacy, and systems thinking. Despite their little prior experience, the students have effectively learned the fundamentals of sensor integration and real-time data processing and indicated greater enthusiasm for using smart technologies in cultural heritage contexts. The results demonstrate the usefulness of combining digital heritage methods with practical engineering training for large-scale teaching. Authentic, cross-disciplinary, and digitally-based learning experiences can be used in a variety of academic and cultural settings that want to change their program.},
  keywords={Computational modeling;Semantics;Computer architecture;Predictive models;Digital twins;Cultural differences;Internet of Things;Environmental management;Engineering education;Predictive maintenance;Digital Twin;Predictive Maintenance;Multidisciplinary Learning;Master's students;Project based learning;Cultural Heritage Monitoring},
  doi={10.1109/FIE63693.2025.11328634},
  ISSN={2377-634X},
  month={Nov},}@INPROCEEDINGS{11136405,
  author={Bojita, Adrian and Buburuza, Alexandru and Purcar, Marius},
  booktitle={2025 34th Annual Conference of the European Association for Education in Electrical and Information Engineering (EAEEIE)}, 
  title={Advancing Electrical Engineering Education with Digital Tools for Electromagnetic Characterization}, 
  year={2025},
  volume={},
  number={},
  pages={1-4},
  abstract={Numerical analysis of electromagnetic processes is essential for the design and optimization of electronic systems, assuring their reliable and safe operation. Computer Aided Design (CAD) and Computer-Aided Engineering (CAE) tools are indispensable and have become fundamental skills for all engineers. Consequently, engineering students should be intensively trained towards mastering the modern design tools in order equip them with the necessary competencies to address contemporary challenges in electronic system design and optimization. This paper presents the Design Workflow of a DC-DC Buck converter that aims to familiarize students with a range of CAD-CAE tools — specifically SolidWorks PCB, Ansys SIwave, — and to teach them how to compute parameters related to power distribution (DC) and signal transmission (AC). The emphasis is put on identifying potential issues such as voltage drops, high impedance, and Electromagnetic Integrity (EMI).},
  keywords={Solid modeling;Design automation;Buck converters;Power distribution;Voltage;Reliability theory;Reliability engineering;Impedance;Optimization;System analysis and design;Digital Twin;Electromagnetic simulation;Engineering education;Power integrity analysis},
  doi={10.1109/EAEEIE65428.2025.11136405},
  ISSN={2472-7687},
  month={June},}@INPROCEEDINGS{11304849,
  author={Haba, Cristian-Győző},
  booktitle={2025 9th International Symposium on Electrical and Electronics Engineering (ISEEE)}, 
  title={Shaping the Future: IEEE’s Role in Emerging Trends in Electrical Engineering Education}, 
  year={2025},
  volume={CFP2593K-ART},
  number={},
  pages={1-4},
  abstract={Electrical Engineering education is entering a transformative era characterized by rapid technological evolution and the increasing convergence of disciplines such as artificial intelligence, renewable energy systems, embedded computing, and the Internet of Things. These developments necessitate a reconfiguration of educational paradigms to emphasize adaptive learning, interdisciplinary collaboration, and the cultivation of innovation-oriented competencies. The latest trends point toward the integration of digital pedagogies, simulation-based learning, and outcome-driven curricula designed to prepare engineers for an environment of constant technological renewal. Within this shifting landscape, the Institute of Electrical and Electronics Engineers (IEEE) plays a key role in advancing educational quality and professional development. Through its digital libraries, peer-reviewed journals, online courses, standards development, student programs, and community-driven initiatives, IEEE provides a comprehensive framework that supports lifelong learning and promotes global standards of engineering practice. Platforms such as IEEE Xplore, the IEEE Learning Network, and various specialized societies offer access to authoritative knowledge, fostering both academic inquiry and industry relevance.},
  keywords={Industries;Knowledge engineering;Technological innovation;Embedded computing;Market research;Libraries;Internet of Things;Standards;Electrical engineering education;Convergence;Electrical Engineering Education;new curricula trends;methodology},
  doi={10.1109/ISEEE67817.2025.11304849},
  ISSN={},
  month={Oct},}@INPROCEEDINGS{11255862,
  author={Leong, Wai Yie},
  booktitle={2025 IEEE International Conference on Computation, Big-Data and Engineering (ICCBE)}, 
  title={Technical and Vocational Education and Training Curriculum in Engineering Based on Digital Twin and Internet of Things Integration for Smart Industry}, 
  year={2025},
  volume={},
  number={},
  pages={937-942},
  abstract={The swift progression of Industry 5.0 technologies necessitates a significant re-evaluation of technical and vocational education and training (TVET), especially in engineering education. Therefore, it is necessary to investigate the integration of digital twin (DT) and Internet of Things (IoT) into TVET curricula in engineering to cultivate competencies for smart manufacturing, automation, and cyber-physical systems. Traditional engineering training models do not provide students with the skills required for modern industrial ecosystems, such as real-time system monitoring, predictive maintenance, and data-driven decision-making. By incorporating digital twin simulations and IoT-enabled infrastructure, students can gain immersive, hands-on experience in smart factories, energy grids, and intelligent transport systems. The curriculum model developed in this study emphasizes modular competency-based learning, live-data experimentation, and collaborative problem-solving. The model prepares graduates to excel in interconnected and automated environments, thereby enhancing student engagement, adaptability, and innovation. A case study was conducted to analyze the improved technical outcomes and readiness for Industry 5.0 based on the educational transformation. Strategic recommendations were proposed for policymakers, curriculum developers, and industry partners to institutionalize the TVET curriculum.},
  keywords={Industries;Training;Adaptation models;Technological innovation;Biological system modeling;Real-time systems;Digital twins;Internet of Things;Monitoring;Smart manufacturing;technical and vocational education and training (TVET);employability;curricula;sustainable manufacturing;artificial intelligence},
  doi={10.1109/ICCBE65177.2025.11255862},
  ISSN={},
  month={June},}@INPROCEEDINGS{11205706,
  author={Chacón, Edgar and Cruz Salazar, Luis Alberto and Cruz, Ernesto Monroy and Valdez-Cervantes, Libis and Sánchez-Gómez, Juan Sebastián and Larrondo-Petrie, Maria Mercedes},
  booktitle={2025 IEEE 30th International Conference on Emerging Technologies and Factory Automation (ETFA)}, 
  title={Towards a Digital Twin-Based Evaluation Framework for Cyber-Physical Production Systems: Latin America SMEs Guideline}, 
  year={2025},
  volume={},
  number={},
  pages={1-6},
  abstract={The evaluation of Cyber-Physical Production Systems (CPPS) using Digital Twin (DT) architectures and Asset Administration Shells (AAS) is critical for advancing flexible, autonomous, and human-centric manufacturing environments. However, small and medium-sized enterprises (SMEs), particularly in Latin America, face significant barriers to adopting and evaluating these technologies due to resource limitations, complexity, and lack of standardized frameworks. This paper proposes a scalable and modular evaluation framework specifically designed for SMEs, integrating DTs for real-time simulation and monitoring, AAS for semantic interoperability, and simulation-based assessment methods to measure CPPS autonomy, flexibility, and resilience. A comprehensive review of recent approaches, trends, challenges, and research gaps highlights the urgent need for dynamic, standardized, and cognitive-enabled evaluation methodologies. The proposed framework addresses these needs by formalizing production knowledge through ontologies, synchronizing physical systems with digital models, and enabling systematic performance evaluation across diverse production scenarios. A case study conducted in a Latin American manufacturing SME demonstrates the practical application of the framework, showing improvements in production efficiency, decision transparency, and system adaptability. The results underline the framework’s potential to democratize access to advanced Industry 4.0 solutions for SMEs, fostering more resilient and intelligent manufacturing ecosystems. By bridging current technological gaps, this work contributes to accelerating the digital transformation of SMEs and supports the broader goals of Industry 5.0. Future research will explore the integration of explainable AI techniques and expand the framework’s applicability to multi-site production networks.},
  keywords={Explainable AI;Scalability;Semantics;Ecosystems;Real-time systems;Fourth Industrial Revolution;Digital twins;Complexity theory;Interoperability;Resilience;Industry 4.0;Performance;Cyber-Physical Systems;Digital Twins;Engineering Education},
  doi={10.1109/ETFA65518.2025.11205706},
  ISSN={1946-0759},
  month={Sep.},}@INPROCEEDINGS{9942788,
  author={Behr, Alexander S. and Neuendorf, Laura M. and Sakthithasan, Piriyanth and Boettcher, Konrad E.R. and Kockmann, Norbert},
  booktitle={2022 IEEE German Education Conference (GeCon)}, 
  title={Process control using AI on a digital twin of an extraction column in VR}, 
  year={2022},
  volume={},
  number={},
  pages={1-6},
  abstract={In an extraction column, counter-current two-phase flow is generated. The value component is separated from a continuous liquid phase by conveying into a second non-miscible liquid. This work in progress presents a digital revision of this laboratory experiment. It consists of two pedagogically and technically flexible combinable parts. Both parts are inter-institutionally collaborative and are available as a package of executable files.In the first part, an extraction column is operated as a digital twin in virtual reality (VR) usable on home PCs with or without VR goggles. The flow diagram and real laboratory plant setup can be compared, individual plant elements controlled, and alternative control concepts evaluated. Simulated data and real experimental data of the real counterpart of the digital twin supplement the digital twin. The second part of the lab deals with the evaluation of the experiments to find the optimal operating point. Droplet sizes in the captured images are to be classified by applying AI-based image analysis. Students will develop the code using the open-source software Jupyter Notebook. Data-related AI competencies for the working world 4.0 are adressed as a learning outcome. This adresses interdisciplinary integration of teaching content in applied computer science and arbitrary engineering sciences.},
  keywords={Computer science;Liquids;Image analysis;Education;Process control;Virtual reality;Digital twins;laboratory education;engineering education;artificial intelligence;virtual reality;immersive laboratory;stem;digital twin},
  doi={10.1109/GeCon55699.2022.9942788},
  ISSN={},
  month={Aug},}@ARTICLE{10574314,
  author={Hakim, Vando Gusti Al and Yang, Su-Hang and Wang, Jen-Hang and Lin, Hung-Hsuan and Chen, Gwo-Dong},
  journal={IEEE Transactions on Learning Technologies}, 
  title={Digital Twins of Pet Robots to Prolong Interdependent Relationships and Effects on Student Learning Performance}, 
  year={2024},
  volume={17},
  number={},
  pages={1843-1857},
  abstract={The use of robots in education has the potential to engage students in learning activities and aims to form lasting relationships with them. To encourage sustainable, long-term human–robot interactions, a promising approach is to cultivate a pet-like, interdependent relationship. However, the potential of such relationships in education remains unclear, and the limited availability of robots in classrooms necessitates flexible and scalable designs. To address these challenges, this study leverages digital twin technology to facilitate ubiquitous engagement with pet robots, thereby prolonging interdependent relationships through a SeamlessPet robot learning approach. Here, students engaged with both virtual and physical pet robots, enabling realistic and continuous interactions akin to communicating directly with a physical robot. This integration ensured consistent availability and authentic interactions, enhancing educational outcomes demonstrated in situational presentations. An experiment with 70 university students in a Japanese Hospitality Management Program in Taiwan demonstrated that this approach resulted in better learning achievements and fostered a positive learning experience. The pet-like features embedded within the digital twin robots played a vital role in fostering prolonged learning participation, empowering students to take ownership of their learning, stay motivated, and feel supported at any time and from anywhere in the learning process. Educators and curriculum developers are encouraged to consider this approach, particularly in courses with a final project presentation that uses a robot to demonstrate study results.},
  keywords={Robots;Digital twins;Education;Robot sensing systems;Collaboration;Service robots;Task analysis;Digital twin;educational robot;interdependent relationship;long-term interaction;pet robot},
  doi={10.1109/TLT.2024.3416209},
  ISSN={1939-1382},
  month={},}@INPROCEEDINGS{11154576,
  author={Alghamdi, Samia and Yoon, Hee Young and Song, Yeong-Tae},
  booktitle={2025 IEEE/ACIS 23rd International Conference on Software Engineering Research, Management and Applications (SERA)}, 
  title={Digital Twins in Education Applications, Challenges, and Future Directions}, 
  year={2025},
  volume={},
  number={},
  pages={225-232},
  abstract={Digital Twins (DTs) are transforming education by creating immersive, data-driven learning environments that integrate theoretical knowledge and practical application. In the current educational landscape, traditional teaching methods often struggle to engage diverse learners, adapt to individual needs, and provide hands-on experiences. While existing literature highlights DT potential in specific domains like engineering, comprehensive analyses of recent advancements and cross-disciplinary applications remain scarce. This systematic literature review addresses this gap by analyzing 25 peer-reviewed studies, identifying the current applications and implementation approaches of DTs in educational settings, their distribution across different educational disciplines, and emerging trends in educational DT development. Our analysis reveals four dominant trends: (1) AI-driven cognitive modeling for personalized learning, (2) immersive technology integration, (3) gamification mechanisms, and (4) cross-domain convergence. Researchers are leveraging these trends to address critical challenges, such as enhancing student engagement, enabling adaptive learning, and optimizing campus operations. However, critical gaps persist, including limited scalability in non-technical fields, insufficient longitudinal validation, and heterogeneous data integration challenges. Future research should prioritize empirical validation, scalability across diverse educational contexts, and ethical frameworks to ensure inclusive and sustainable adoption of DTs in education.},
  keywords={Ethics;Adaptive learning;Scalability;Education;Data integration;Market research;Digital twins;Systematic literature review;Convergence;Software engineering;Digital Twins;Educational Technology;Immersive Learning;Virtual Laboratories;Smart Campus Management;Personalized Learning},
  doi={10.1109/SERA65747.2025.11154576},
  ISSN={2770-8209},
  month={May},}@INPROCEEDINGS{11016611,
  author={Risso, Nathalie and Saavedra, Matias and Zhang, Jinhong},
  booktitle={2025 IEEE Global Engineering Education Conference (EDUCON)}, 
  title={Mine2Twin: a Synergistic Industry-Academia Collaboration to Improve Engineering Skills for Industry 5.0}, 
  year={2025},
  volume={},
  number={},
  pages={1-5},
  abstract={Industry 5.0 is reshaping workforce requirements by emphasizing the integration of human creativity with advanced technologies, such as automation and artificial intelligence. Teaching engineering skills within the context of Industry 5.0 and large industrial applications has become increasingly complex. Active learning and hands-on experimentation are critical to improving understanding and skill development in this rapidly evolving environment. This paper presents the development of a set of scenario-based learning experiences using an industry-validated digital twin to address these challenges, specifically in the context of mineral processing. While based on a small test group, preliminary results indicate that these scenario-based experiences significantly improve students' understanding of complex mineral processing concepts. Additional testing and validation is still ongoing. Feedback from testers suggests that the tool could also enhance other coursework, research, and capstone projects by offering a practical, interactive approach to learning. The study builds on industry-accepted tools to improve engineering curricula by integrating real-world applications into academic programs. Furthermore, it provides a model for incorporating advanced technologies, such as digital twins, into engineering coursework, aligning with the needs of Industry 5.0.},
  keywords={Surveys;Industries;Software;Minerals;Materials processing;Digital twins;Teamwork;Fifth Industrial Revolution;Interviews;Testing},
  doi={10.1109/EDUCON62633.2025.11016611},
  ISSN={2165-9567},
  month={April},}@INPROCEEDINGS{11322249,
  author={Curcio, Elio Matteo and Gencarelli, Giuseppe and Rodinò, Stefano and Lago, Francesco and Felicetti, Francesco and Carbone, Giuseppe and Lamonaca, Francesco},
  booktitle={2025 IEEE 13th International Conference on Intelligent Data Acquisition and Advanced Computing Systems: Technology and Applications (IDAACS)}, 
  title={Development of a Virtual Laboratory for Simulating Real Experiences: The Case of a Hybrid Drone in Complex Urban Environments}, 
  year={2025},
  volume={},
  number={},
  pages={1057-1061},
  abstract={The increasing complexity of modern urban environments needs innovative solutions for experimentation and education in STEM fields. This paper presents the development of a virtual laboratory based on the concept of a digital twin, focusing on the simulation of a hybrid drone capable of both flying and ground movements, operating in complex urban contexts. The benefits of using digital twins for practical training and research are discussed, as well as the challenges faced in modeling realistic urban environments.},
  keywords={Training;Computational modeling;Urban areas;Laboratories;Data acquisition;Focusing;Digital twins;Complexity theory;Drones;STEM;Drone;Control;Virtual laboratory;STEM},
  doi={10.1109/IDAACS68557.2025.11322249},
  ISSN={2770-4254},
  month={Sep.},}@INPROCEEDINGS{11151834,
  author={Ramírez-Cedillo, Erick and Ortiz-Espinoza, Alexandro and Vargas-Martínez, Adriana},
  booktitle={2024 World Engineering Education Forum - Global Engineering Deans Council (WEEF-GEDC)}, 
  title={Integrating Human Factors in Automation: Educational Study on Cyber-Physical Systems and Emotional Responses}, 
  year={2024},
  volume={},
  number={},
  pages={1-7},
  abstract={This study explores the integration of Industry 5.0 principles into mechatronics engineering education, focusing on a human-centric approach. The European Commission’s leadership in Industry 5.0 highlights the significance of emotional intelligence in the workplace, showing that emotionally intelligent leaders can enhance employee engagement and performance. Utilizing human digital twin (HDT), digital twin (DT), and cyber-physical systems (CPS), this research addresses the interaction between humans (students) and environmental challenges in the workspace. The primary objective is to propose and evaluate a CPS simulation for teaching sustainable manufacturing practices. The methodology includes a mixed-methods approach, combining quantitative cycle time measurements and qualitative emotional analyses using facial expression recognition technology. Results indicate varied emotional responses among students, with significant levels of anger, fear, and sadness, suggesting that repetitive tasks were stressful. This study emphasizes the need for emotional intelligence training and adaptive technologies to improve workplace well-being, aligning with Industry 5.0’s human-centered vision.},
  keywords={Training;Emotion recognition;Mechatronics;Employment;Collaborative robots;Time measurement;Digital twins;Emotional responses;Fifth Industrial Revolution;Engineering education;Industry 5.0;Human digital twins;Mechatronics education;Innovation in education;Higher education;Manufacturing systems;Emotional intelligence;Emotion recognition;Human-robot collaboration;Collaborative robots;Cobot;Human-machine interaction;Work engagement},
  doi={10.1109/WEEF-GEDC63419.2024.11151834},
  ISSN={2837-5025},
  month={Dec},}@INPROCEEDINGS{9766587,
  author={Wan, Chenhui and Huang, Tao and Zhang, Xi and Zhang, Xin and Hu, Youmin and Wang, Di},
  booktitle={2022 IEEE Global Engineering Education Conference (EDUCON)}, 
  title={Application of Somatosensory Camera in Robot Remote Experimental Teaching}, 
  year={2022},
  volume={},
  number={},
  pages={652-655},
  abstract={This article proposes a method to remotely control the robot in the laboratory through the Kinect camera to solve the impact of the Covid-19 epidemic on the laboratory teaching experience which allows users to remotely control robots through their own body movements to understand the principles of robots. It is used to solve the problem of fewer students willing to participate in robot remote education. In this study, the Azure Kinect DK camera was used to collect the motion posture of the upper limbs of the human body. The Kinect camera calculates the frames of human arm joints’ motion. The control system calculates the direction of motion of each joint of the human body based on the quaternion by mapping the heterogeneous human joints with the robot joints. Make the posture of the human arm swing correspond to the posture of the robot’s movement. Thus, the robot in the laboratory can be driven remotely through Azure Kinect DK. By using the method described in this article, students use the camera’s motion capture system to remotely manipulate the robot to grab some simple objects. Through the method described in this research, students can carry out some simple operations on the robots in the laboratory from remote. So it is convenient for students to understand the basic principles of robots and achieve the purpose of better remote experimental teaching. At the same time, students can get practical application of motor servo control, ergonomics, physical simulation engine, digital twin system, etc.},
  keywords={Ergonomics;Digital twin;Quaternions;Robot vision systems;Arms;Cameras;Manipulators;Kinect;robot;teleoperation;remote education},
  doi={10.1109/EDUCON52537.2022.9766587},
  ISSN={2165-9567},
  month={March},}@INPROCEEDINGS{10295113,
  author={Mayer, Anjela and Kastner, Kevin and Reichwald, Julian and Chardonnet, Jean-Rémy and Ovtcharova, Jivka},
  booktitle={2023 IEEE 2nd German Education Conference (GECon)}, 
  title={Comparing Avatar and Face-to-Face Collaboration in VR Education: Concept and Preliminary Insights}, 
  year={2023},
  volume={},
  number={},
  pages={1-5},
  abstract={Virtual education is gaining prominence, providing opportunities for dynamic interactive content, such as Digital Twins, and novel collaboration modalities, including options for remote classrooms. In this work, we present a concept that leverages Digital Twins for interactive group work in engineering education through the use of Virtual Reality technology. We propose an experimental investigation to compare diverse collaboration alternatives facilitated by Virtual Reality, specifically face-to-face and avatar-based interaction. Preliminary findings are discussed, along with their implications for the design and implementation of future experiments in this emerging field.},
  keywords={Avatars;Collaboration;Digital twins;Engineering education;collaboration;digital twins;education;virtual reality},
  doi={10.1109/GECon58119.2023.10295113},
  ISSN={},
  month={Aug},}@INPROCEEDINGS{11328395,
  author={Osunbunmi, Ibukun and Cutler, Stephanie and Feyijimi, Taiwo},
  booktitle={2025 IEEE Frontiers in Education Conference (FIE)}, 
  title={Special Session: Artificial Intelligence for Research and Teaching: Adopting Emerging Technologies in Engineering Education}, 
  year={2025},
  volume={},
  number={},
  pages={1-4},
  abstract={Emerging technologies such as artificial intelligence (AI), digital twins, internet of things (IoT), extended reality (XR), and Robotics have the potential to enhance engineering education. The rapid integration of generative artificial intelligence into the workplace and daily life calls for engineering educators to leverage these tools in research and teaching. During this interactive workshop, we will introduce some AI tools for educational purposes that can enhance research and teaching in the engineering discipline. Additionally, participants will have the opportunity to gain hands-on experience using AI to assist with literature review and their research work. They will also learn to leverage generative AI as an assistive technological tool in instructional design and to achieve higher-order levels of Bloom's Taxonomy. We propose that when engineering educators who facilitate learning are equipped with the requisite skill set for using generative AI for teaching and research, the engineering students they teach and mentor will be better positioned to develop AI literacy and leverage these AI tools. AI literacy is an essential workforce readiness skill set to develop in the artificial intelligence age, as industries increasingly integrate AI into their processes.},
  keywords={Industries;Generative AI;Extended reality;Taxonomy;Employment;Learning (artificial intelligence);Internet of Things;Engineering students;Robots;Systematic literature review;Generative Artificial Intelligence;Research;Learning;Universal Design of Learning},
  doi={10.1109/FIE63693.2025.11328395},
  ISSN={2377-634X},
  month={Nov},}@INPROCEEDINGS{9125409,
  author={Caeiro-Rodríguez, Manuel and Nistal, Martín Llamas and Cristobal, Elio San and Pérez, Francisco Mur and Sánchez, José Ángel and Castro, Manuel and Plaza, Pedro and Muñoz-Merino, Pedro and Bonastre, Óscar Martínez and Solsona, Francisco Javier Arcega and Zubía, Javier García},
  booktitle={2020 IEEE Global Engineering Education Conference (EDUCON)}, 
  title={Activities of the Spanish Chapter of the IEEE Education Society}, 
  year={2020},
  volume={},
  number={},
  pages={1932-1936},
  abstract={This paper introduces the Spanish Chapter of the IEEE Education Society, the CESEI, and its main activities. Along the years since its appearance, the CESEI has developed several initiatives devoted to promote the development of engineering education using new information and communication technologies. Publications and participation in relevant conferences have attracted the main efforts, but also the awards provided to the best student academic works is a remarkable action. It deserves special attention the activities performed in cooperation with the student branches, because they have been very fruitful. The paper describes all these initiatives and discusses about future actions.},
  keywords={Conferences;Information and communication technology;Engineering education;IEEE Chapter;Education Society;Publications;Conferences;Activities},
  doi={10.1109/EDUCON45650.2020.9125409},
  ISSN={2165-9567},
  month={April},}@INPROCEEDINGS{11400335,
