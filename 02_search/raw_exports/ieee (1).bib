  title={Information Architecture to Support Technical Education Training for Industry 4.0}, 
  year={2020},
  volume={},
  number={},
  pages={1-6},
  abstract={The article describes the prospects for the development of technologies that can contribute to the transition to Industry 4.0, by making appropriate changes in the enterprise architecture. A formal description of the enterprise is given based on the architectural approach, which allows increasing the efficiency of business information support for the organization of the digital industry. Changes in the approach of training of personnel of engineering education which are necessary for transition of the enterprises to the Industry 4.0 are considered.},
  keywords={Training;Measurement;Computer architecture;Organizations;Fourth Industrial Revolution;Planning;Personnel;enterprise architecture;training;education;Industry 4.0},
  doi={10.1109/Inforino48376.2020.9111792},
  ISSN={},
  month={April},}@INPROCEEDINGS{10355994,
  author={Pexyean, Tanapeak and Saraubon, Kobkiat and Nilsook, Prachyanun},
  booktitle={2023 Research, Invention, and Innovation Congress: Innovative Electricals and Electronics (RI2C)}, 
  title={IoT, 6G and Digital Twin For Smart Campus}, 
  year={2023},
  volume={},
  number={},
  pages={46-50},
  abstract={Smart Campus This research aims to present the use of the Internet of Things and smart technologies that work with 6G networks to intelligently improve the energy management capabilities of campuses. Whether it's personal. Teachers and students, including those with disabilities, have a better quality of life. Within the university, energy consumption data is collected. Organizations to manage energy management systems Reduce energy consumption Reduce management by using technology to manage and reduce campus costs, transparently monitor energy consumption and use of campus educational equipment, especially cost and expense management, and sustainable energy use. Control usage data, energy consumption results, and estimate budget allocation related to educational institutions. IoT and Cloud Computing are also integrated into 6G networks embedded in state-of-the-art devices for use in environmental management and intelligent energy management, as well as creating new energy models and management that can solve future emergencies with external on-premises virtual energy control anytime, anywhere. Smart Building Management with twin technologies helps to intelligently manage and control indoor energy systems, such as automation for temperature control in buildings. Air conditioner energy consumption control system Electricity consumption control in lighting system This saves energy and increases the usability of buildings within smart campuses.},
  keywords={6G mobile communication;Temperature sensors;Temperature measurement;Energy consumption;Technological innovation;Power system management;Organizations;Internet of Things (IoT);6G;Digital Twin;Smart Campus},
  doi={10.1109/RI2C60382.2023.10355994},
  ISSN={},
  month={Aug},}@INPROCEEDINGS{9782154,
  author={Altamirano-Avila, Edison and Valdivia-Puga, Abraham and Vázquez-Hurtado, Carlos},
  booktitle={2022 IEEE World Engineering Education Conference (EDUNINE)}, 
  title={Work in Progress: Implementation of a Digital Twin as Technology to support Discrete Event Control Teaching}, 
  year={2022},
  volume={},
  number={},
  pages={1-4},
  abstract={Cyberlearning factories struggle to be implemented for teaching into digital world environments, complex manufacturing systems require multiple systems such as vision cameras, plc programming, or AGV’s (Autonomous Intelligent Vehicles). This work depicts the integration of emerging technologies for simulating multiple systems such as industrial cameras, programmable logic controllers, and robots into a simulated world environment. The proposed method shows a solution to test the performance of a factory based on the interaction and data provided by systems such as Datalogic cameras for industrial vision, CODESYS for plc programming, and process simulate to create virtual environments. The result is the development of an efficient industrial simulation environment with robust mathematical modeling for planning the process behavior inside a manufacturing station. This research exemplifies educational innovation by assisting in the creation of a costeffective method for teaching industrial skills.},
  keywords={Technological innovation;Machine vision;Education;Robot vision systems;Virtual environments;Cameras;Production facilities;Teaching technology;Industrial skills;OPC;Vision systems;Process Simulate;PLC;Industry 4.0;Educationalinnovation},
  doi={10.1109/EDUNINE53672.2022.9782154},
  ISSN={},
  month={March},}@INPROCEEDINGS{11273603,
  author={Hristov, Georgi and Kinaneva, Diyana and Zahariev, Plamen and Georgiev, Georgi and Beloev, Ivan},
  booktitle={2025 10th International Conference on Energy Efficiency and Agricultural Engineering (EE&AE)}, 
  title={Digital Industrial Solutions for Enhancing Student Motivation and Prepare Them for Industry 4.0}, 
  year={2025},
  volume={},
  number={},
  pages={1-7},
  abstract={The contemporary digital industry is faced with the serious challenge of finding experts who can respond to dynamically evolving technologies, have multidisciplinary skills, and have the ability to adapt in a rapidly changing environment. This is a prerequisite for rethinking traditional learning approaches and implementing innovation, interactivity, and digitalization in modern learning methods. In this context, the paper explores the integration of digital industrial solutions into engineering curricula with the goal to increase student engagement and motivation and to prepare them for Industry 4.0 demands. The digitalization of industrial processes is a key moment for the successful development, optimization, and productivity of modern industry. This paper presents an interdisciplinary educational approach that integrates digital industrial solutions-such as robotic manufacturing, 3D modeling, and virtual process simulation-into the engineering curriculum to enhance student motivation and preparedness for Industry 4.0. The study discusses the implementation of this approach at the University of Ruse “Angel Kanchev,” highlighting its impact on student engagement, teamwork, and acquisition of Industry $\mathbf{4. 0}$ competencies. A case study based on the Shell Eco-marathon project demonstrates how collaborative learning and digital technologies foster practical skills, innovation, and deeper understanding of real-world industrial processes. The results suggest that the integration of digital industrial tools into education bridges the gap between theory and practice and motivates students to pursue engineering careers.},
  keywords={Industries;Productivity;Learning systems;Technological innovation;Three-dimensional displays;Service robots;Education;Fourth Industrial Revolution;Teamwork;Optimization;education;collaborative robots;digital twins;Industry 4.0;modernization,},
  doi={10.1109/EEAE65901.2025.11273603},
  ISSN={},
  month={Nov},}@ARTICLE{9576059,
  author={Fuertes, Juan José and Prada, Miguel Ángel and Rodríguez-Ossorio, José Ramón and González-Herbón, Raúl and Pérez, Daniel and Domínguez, Manuel},
  journal={IEEE Access}, 
  title={Environment for Education on Industry 4.0}, 
  year={2021},
  volume={9},
  number={},
  pages={144395-144405},
  abstract={A new industrial production model based on digitalization, system interconnection, virtualization and data exploitation, has emerged. Upgrade of production processes towards this Industry 4.0 model is one of the critical challenges for the industrial sector and, consequently, the training of students and professionals has to address these new demands. To carry out this task, it is essential to develop educational tools that allow students to interact with real equipment that implements, in an integrated way, new enabling technologies, such as connectivity with standard protocols, storage and data processing in the cloud, machine learning, digital twins and industrial cybersecurity measures. For that reason, in this work, we present an educational environment on Industry 4.0 that incorporates these technologies reproducing realistic industrial conditions. This environment includes cutting-edge industrial control system technologies, such as an industrial firewall and a virtual private network (VPN) to strengthen cybersecurity, an Industrial Internet of Things (IIoT) gateway to transfer process information to the cloud, where it can be stored and analyzed, and a digital twin that virtually reproduces the system. A set of hands-on tasks for an introductory automation course have been proposed, so that students acquire a practical understanding of the enabling technologies of Industry 4.0 and of its function in a real automation. This course has been taught in a master’s degree and students have assessed its usefulness by means of an anonymous survey. The results of the educational experience have been useful both from the students’ and faculty’s viewpoint.},
  keywords={Protocols;Cloud computing;Industries;Digital twin;Standards;Computer security;Solid modeling;Engineering education;industry 4.0;industrial Internet of Things;IIoT;cyber-physical system},
  doi={10.1109/ACCESS.2021.3120517},
  ISSN={2169-3536},
  month={},}@ARTICLE{9580538,
  author={Martin, Sergio and Lopez-Martin, Esther and Moreno-Pulido, Alexis and Meier, Russ and Castro, Manuel},
  journal={IEEE Transactions on Learning Technologies}, 
  title={The Future of Educational Technologies for Engineering Education}, 
  year={2021},
  volume={14},
  number={5},
  pages={613-623},
  abstract={This article analyzes a survey delivered in 2019 to 259 experts in engineering education that asked them to forecast information and communication technologies, which were most likely to impact the practice of engineering education based on the expert&#x0027;s discipline (electrical, electronics, mechanical, telecommunications engineering, computer science, etc.) and region. The analysis was performed from different perspectives. First, a descriptive approach was used to analyze technologies that are considered as the most important for the experts and a nonparametric perspective approach was adopted to evaluate variation in the responses according to discipline, region, and years of experience. Second, a decision tree technique was used to establish technology profiles based on when the experts expected that the technologies will impact mass engineering education and the challenges or requirements needed to get widespread use. Third, the Spearman correlation coefficient was used to determine the value of social interest, measured through Google Trends, as a predictor of expert ratings of different technologies. Results indicate adaptive and personalized learning technologies, learning analytics, and open educational resources are the three most promising technologies that will impact engineering education in the short term. Results also show a relation between the predictions made by the experts in 2019 and the social interest in the Google Trends education category.},
  keywords={Engineering education;Market research;Internet;Games;Conferences;Tools;Europe;Engineering education trends;Google Trends;technology-enhanced learning;technology meta-trends.},
  doi={10.1109/TLT.2021.3120771},
  ISSN={1939-1382},
  month={Oct},}@INPROCEEDINGS{10551932,
  author={Ochkov, Valery F. and Tikhonov, Anton I.},
  booktitle={2024 7th International Conference on Information Technologies in Engineering Education (Inforino)}, 
  title={What the Heck is STEM in Engineering Education}, 
  year={2024},
  volume={},
  number={},
  pages={1-7},
  abstract={The article discusses the application of STEM technologies in the educational process on the example of the discipline “Scientific, Technical and Engineering Calculations”. The main applied pedagogical approaches, examples of solved problems, requirements to educational materials are analyzed. It is shown that storytelling, solving a large number of interesting, understandable to students’ problems, scientific visualization, statistical modeling and solving inverse problems (design problems) give the maximum effect, allow to keep students’ attention and interest. The questions of reducing the labor intensity of the educational process are discussed in detail. It is shown that the necessary condition for students to absorb the educational material is the preliminary publication of video recordings of lectures, practical classes, source code of solved problems, reference information and interactive web-applications for homework and mini-projects.},
  keywords={Visualization;Inverse problems;Social networking (online);Publishing;Source coding;Online services;Engineering education;STEM;STEAM;STREAM;MINT;Python ecosystem;storytelling;scientific calculations;engineering education},
  doi={10.1109/Inforino60363.2024.10551932},
  ISSN={},
  month={April},}@INPROCEEDINGS{10253555,
  author={Liyanawaduge, N.N and Kumarasinghe, E.M.H.K. and Iyer, Smirthya Somaskantha and Kulatunga, A.K. and Lakmal, Gihan},
  booktitle={2023 IEEE 17th International Conference on Industrial and Information Systems (ICIIS)}, 
  title={Digital Twin & Virtual Reality Enabled Conveyor System to Promote Learning Factory Concept}, 
  year={2023},
  volume={},
  number={},
  pages={85-90},
  abstract={Manufacturing and industrial engineering education has encountered several challenges in addressing the educational demands of rapidly advancing technologies such as Industry 4.0, virtual reality (VR), digital twin (DT), etc. On the one hand, conventional laboratory facilities are unable to cope with this demand due to their nature of isolated operations. On the other, there is also a need to expose the students to concepts like Industry 4.0 and DT, where a virtual replica of the physical system is created and connected in real time. Therefore, this study aimed to establish DT connectivity between the physical and digital models of a conveyor available in a manufacturing system in a learning factory (LF). The integration of existing hardware with a simulated platform, utilizing an IoT-enabled environment and operating the hardware through VR setups, enabled seamless interaction between the physical and virtual realms, enhancing control, visualization, and optimization of hardware systems. Moreover, in addition to facilitating the DT, a VR platform has been integrated with the digital model of the conveyor system, enabling control of the physical system through a VR setup. The positioning accuracy of the conveyor carried pallet was tested for several locations, and results revealed that the digital model indicates the pallet position to the accuracy level of the nearest 2.5 mm. Furthermore, it could be concluded that the setup developed in this research could be used as an LF for engineering undergraduates to learn new concepts such as Industry 4.0, DT, and VR-enabled digital-physical integration.},
  keywords={Solid modeling;Education;Industrial engineering;Control systems;Hardware;Production facilities;Common Information Model (computing);Digital Twin;Virtual Reality;Learning Factory;Industry 4.0},
  doi={10.1109/ICIIS58898.2023.10253555},
  ISSN={2164-7011},
  month={Aug},}@INPROCEEDINGS{11371219,
  author={Amoda, Niket and Jolly, Lochan and Rawankar, Arpit},
  booktitle={2025 2nd International Conference on Integration of Computational Intelligent System (ICICIS)}, 
  title={A Comprehensive Review of Remote Laboratories in Engineering Education: Evolution, Challenges, and Future Directions}, 
  year={2025},
  volume={},
  number={},
  pages={1-6},
  abstract={The increasing demand for flexible, scalable, and skill-oriented engineering education has accelerated the development of remote laboratories (RALs) that provide internet-based access to real experimental setups. This paper presents a comprehensive review and comparative analysis of remote laboratories in communication engineering and related domains. Early implementations demonstrated feasibility but suffered from limitations in interactivity, scalability, and security. Over the past two decades, landmark initiatives such as VISIR, MIT iLabs, LabShare, and India's Virtual Labs have expanded the scope of RALs across electronics, control, signal processing, photonics, and embedded systems. Despite significant progress, persistent challenges remain, including inadequate real-time feedback, limited multi-user collaboration, insufficient data acquisition (DAQ) integration, and security vulnerabilities. Recent advancements such as cloud computing, Internet of Things (IoT)-enabled smart laboratories, and artificial intelligence (AI)-driven support systems show promise in addressing these issues. This study identifies key research gaps and proposes design directions for next-generation intelligent remote laboratories that are secure, scalable, pedagogically integrated, and sustainable. Emphasis is placed on incorporating cloud-native architectures, multi-user concurrency, and immersive technologies (AR/VR, digital twins) to enhance authenticity and accessibility. The findings highlight that with appropriate design and institutional collaboration, remote laboratories can democratize access to “anytime, anywhere” experimentation, bridging the experiential gap in modern engineering education.},
  keywords={Remote laboratories;Cloud computing;Reviews;Scalability;Data acquisition;Collaboration;Computer architecture;Real-time systems;Engineering education;Sustainable development;Remote Laboratories;Engineering Education;Real-Time Control;Multi-User Collaboration;Data Acquisition Systems;Cloud Computing;AI Integration;IoT;Educational Technology;Security;Scalability;Pedagogical Integration;Future Directions},
  doi={10.1109/ICICIS65613.2025.11371219},
  ISSN={},
  month={Sep.},}@INPROCEEDINGS{10510786,
  author={Peng, Chao-Chung},
  booktitle={2024 IEEE 7th Eurasian Conference on Educational Innovation (ECEI)}, 
  title={Microprocessor-based Virtual Control System Framework for Control Engineering Education}, 
  year={2024},
  volume={},
  number={},
  pages={414-419},
  abstract={In control engineering, a range of disciplines is used including mathematics, physics, and mechanical, electrical, and software engineering. Its interdisciplinary nature enables university students to acquire knowledge and the ability to cope with complex problems. For control engineering education, lecturers teach classical control theory, modern control theory, and non-linear control courses. However, most students are unable to apply the basis of control theory to physical systems. In addition, in practical control engineering courses, it is necessary to purchase expensive control system equipment to train students. This raises the cost of implementing control education and makes students not familiar with the physical construction and engineering integration of control systems. To address these problems, a low-cost and high-safety design framework was developed in this study for control engineering education. This framework provides low cost, safety, and a high degree of flexibility for the digital generation of different physical systems, allowing students to learn controller design and tuning for different complex virtual physical systems under the same framework. The proposed architecture has significant potential for enhancing control engineering education for college students.},
  keywords={Technological innovation;Costs;Control engineering;System dynamics;Education;Control engineering education;Control theory;virtual control system;control system design;embedded system realization;digital twin},
  doi={10.1109/ECEI60433.2024.10510786},
  ISSN={},
  month={Jan},}@INPROCEEDINGS{9454130,
  author={Kooli-Chaabane, Hanen and Peyret, Nicolas and Hammadi, Moncef and Lanthony, Antoine},
  booktitle={2021 IEEE Global Engineering Education Conference (EDUCON)}, 
  title={Virtual Design Office: Proposition of Problem- and Project-Based Learning Solution in the COVID-19 Era and Beyond}, 
  year={2021},
  volume={},
  number={},
  pages={1527-1531},
  abstract={SFPMECA has chosen since decades to engage in Problem- and Project-Based Learning (PBL). In the framework of this orientation and as a part of a reflection on the enhancement of hybridization of teaching methods in the wake of COVID-19 crisis, our paper presents the first results of an ongoing study. This study aims to propose a virtual Design Office called “BE Virtual” as a solution to facilitate implementing PBL approaches in engineer curriculum. To reach our goal, a “Design Thinking” inspired methodology and the modeling language SysML are used.},
  keywords={COVID-19;Distance learning;Digital twin;Design methodology;Conferences;Market research;Reflection;PBL;SysML;COVID-19;design office;learning},
  doi={10.1109/EDUCON46332.2021.9454130},
  ISSN={2165-9567},
  month={April},}@INPROCEEDINGS{9208305,
  author={Möller, Dietmar P. F. and Jehle, Isabel A. and Hou, Weijan},
  booktitle={2020 IEEE International Conference on Electro Information Technology (EIT)}, 
  title={Engineering Education in Intelligent Manufacturing}, 
  year={2020},
  volume={},
  number={},
  pages={007-012},
  abstract={The age of digitization is changing the way universities need to educate their engineering graduates. Thus, universities must train their graduates with the skills required in the era of digitization. In this regard universities face significant pressure to overhaul their established sometimes traditional curriculums and expand them by focusing on methodologies and technologies required as skills in the 21st century. In this regard technology enhanced learning methods are essential while flexible to provide engineering students with the respective skills in complex system design in the manufacturing domain. This technology enhanced learning approach also helps to overcome education lags caused by the COVID 19 pandemic. The digital transformative impact on intelligent manufacturing also requires dealing with risk management with regard to vulnerability through cyber threat attacks. Thus, this paper describes an educational approach which refers to the essential skills required in engineering education in intelligent manufacturing.},
  keywords={Education;Business;Manufacturing processes;Cyber-physical systems;Computer security;Intelligent manufacturing systems},
  doi={10.1109/EIT48999.2020.9208305},
  ISSN={2154-0373},
  month={July},}@INPROCEEDINGS{11361605,
  author={Razi, Niloofar and Samsami, Reihaneh},
  booktitle={2025 IEEE 4th International Conference on Intelligent Reality (ICIR)}, 
  title={Extended Reality (XR) Applications in Civil Engineering Education: A Review}, 
  year={2025},
  volume={},
  number={},
  pages={1-7},
  abstract={Extended Reality (XR) technologies, including Virtual, Augmented, and Mixed Reality (VR/AR/MR), are increasingly transforming civil engineering education by providing immersive and interactive learning environments. This review focuses on studies from 2000 to 2025 that explore how XR is applied in civil engineering education, particularly in areas like safety training, BIM-based 4D visualization, structural analysis labs, remote teamwork, and game-like learning modules. Across these areas, most studies report clear short-term improvements in learning outcomes. One example is a VR-based site layout module that improved post-test scores from 61% to 75%, outperforming traditional approaches. Despite these encouraging results, few studies assess long-term retention or real-world skill transfer, and many rely on small sample sizes and varied evaluation methods. In addition, challenges such as high implementation costs, limited faculty readiness, and ergonomic concerns continue to restrict broader adoption. Recent advances, such as AI-driven personalization and cloud-based delivery, are beginning to offer practical solutions to these challenges. This review identifies current gaps and emerging opportunities to help guide the integration of XR in civil engineering education.},
  keywords={Headphones;Cloud computing;Reviews;Extended reality;Turnkey project;Ergonomics;Mixed reality;Safety;Civil engineering;Standards;Extended Reality (XR);Virtual Reality (VR);Augmented Reality (AR);Mixed Reality (MR);Civil-Engineering Education},
  doi={10.1109/ICIR68135.2025.11361605},
  ISSN={},
