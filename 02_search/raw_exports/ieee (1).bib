  month={March},}@INPROCEEDINGS{9597027,
  author={de Vries, E.W. and Wörtche, H.J.},
  booktitle={2021 44th International Convention on Information, Communication and Electronic Technology (MIPRO)}, 
  title={Remote Labs and their Didactics in Engineering Education: a Case Study}, 
  year={2021},
  volume={},
  number={},
  pages={1598-1600},
  abstract={Covid-19 made us realize that educational practices in higher education must change AND can change. A possible solution for practicing lab work is working in a remote lab: a real lab in which students and the equipment/instruments are physically apart. The concept of printed touchless electronics was taken as the leading principle for students in the Department of Electrical Engineering of a university of applied sciences. They got the assignment to write a programming code, with which they could control a robot. This robot was supposed to draw, with conductive ink, a pattern, that could function as a printed (light) sensor. The robot was situated in the lab, the students uploaded their code from home. Via a live stream, the students could follow the movements of the robot and the pen. From a didactical perspective, the goal was to find out if the selected didactical methods: teamwork and feedback via an internet platform and working with consultation hours, had the estimated effect. An interdisciplinary team of three lecturers was composed to guide the students. Students thought that the consultation hours were very helpful. The online teamwork between the students did not work so well. In the future, students would like to have more opportunities for testing and working with the remote lab.},
  keywords={Electrical engineering;COVID-19;Codes;Instruments;Ink;Robot sensing systems;Teamwork;remote labs;engineering education;distance learning;didactics;printed electronics},
  doi={10.23919/MIPRO52101.2021.9597027},
  ISSN={2623-8764},
  month={Sep.},}@INPROCEEDINGS{11256458,
  author={Fan, Huiming and Fan, Yuxi and Gong, Yu},
  booktitle={2025 World Engineering Education Forum - Global Engineering Deans Council (WEEF-GEDC)}, 
  title={Research on the Construction of Digital Competence Framework for Engineering Talents-Based on Literature Review Approach}, 
  year={2025},
  volume={},
  number={},
  pages={1-8},
  abstract={In order to further their digitalization objectives and encourage the growth of the manufacturing sector, nations all over the world are increasingly choosing to cultivate composite and inventive engineering talent with both professional and digital competencies. Nonetheless, there remains disagreement among academics over the meaning and components of digital competency. In order to analyze the three aspects of competence definition, element composition, and topic differences, the study employs the literature review technique and focuses on the definition and components of digital competence of engineering abilities. A five-dimensional consensus on technical hard skills, transversal soft skills, management coordination skills, cultural responsibility, and continuous learning and adaptability is formed by the elements of competence, according to the study, which also reveals that different framework developers have different priorities for the digital competency of engineering talents. Through the study, the article seeks to help the development of engineering talent's digital competency.},
  keywords={Ethics;Supply and demand;Digital transformation;Manufacturing;Cultural differences;Stakeholders;Digital intelligence;Engineering education;Standards;Systematic literature review;Engineering talent;digital competency;engineering education},
  doi={10.1109/WEEF-GEDC66748.2025.11256458},
  ISSN={2837-5025},
  month={Sep.},}@INPROCEEDINGS{10217291,
  author={Lu, Dandan and Liang, Shiyan and Wang, Min and Wang, Yinling and Han, Dongxuan and Cheng, Yao},
  booktitle={2023 2nd International Joint Conference on Information and Communication Engineering (JCICE)}, 
  title={Intelligent Manufacturing Education and Tutoring Experimental Platform Studies Based on Reconfigurable Module}, 
  year={2023},
  volume={},
  number={},
  pages={179-183},
  abstract={Given the disconnection between the experimental content and the theory in the experimental project in the field of control engineering education, and the experimental process only stays at the level of virtual simulation and small development kit, we propose an intelligent manufacturing teaching assistant experimental platform based on the reconfigurable module. The “intelligence + reconfigurable modularization” experimental module is designed by simulating the industrial production line, and a high-fidelity experimental platform for control engineering education is assembled. We describe in detail the design and implementation process of the teaching assistant experimental platform and expound on the experimental project’s task design, technological revolution, and program design through a case study, which shows that the teaching auxiliary experimental platform is closely integrated with engineering practice. It is proved that students can acquire industrial technical ability from the experimental platform and improve their systematic cognitive ability in the manufacturing system.},
  keywords={Systematics;Education;Process control;Production;Control engineering education;Task analysis;Manufacturing systems;control engineering education;intelligent manufacturing;assistant experimental platform;reconfigurable modularization},
  doi={10.1109/JCICE59059.2023.00044},
  ISSN={},
  month={May},}@INPROCEEDINGS{11190350,
  author={Fridman, Shlomi and Berenson, Shahar and Unkelos-Shpigel, Naomi},
  booktitle={2025 IEEE 33rd International Requirements Engineering Conference (RE)}, 
  title={Production Line Augmented Reality Application}, 
  year={2025},
  volume={},
  number={},
  pages={580-581},
  abstract={Augmented Reality (AR) is increasingly integral for enhancing industrial operations and educational training across various sectors, including manufacturing, engineering education, and digital twin systems [1] . As such, stakeholders such as system developers, educators, industrial operators, and students necessitate varying levels of interaction and visualization capabilities for production line systems to enhance their understanding, trust, and operational effectiveness. The growing reliance on AR as a bridge between physical and digital environments in these critical areas underscores the need for AR systems to be accessible, comprehensible to their users, ensuring their use is safe, educational, and operationally effective [2] .},
  keywords={Training;Surveys;Measurement;Prototypes;Production;Stakeholders;Requirements engineering;Augmented reality;Testing;Systematic literature review;digital twin;augmented reality;industrial internet of things},
  doi={10.1109/RE63999.2025.00069},
  ISSN={2332-6441},
  month={Sep.},}@INPROCEEDINGS{9698437,
  author={Santacruz, Alan F. and Villalobos, Jessica and Sanchez, Irma Y. and Paredes, Carlos A. and Martell, Fernando},
  booktitle={2021 International Conference on Electrical, Computer and Energy Technologies (ICECET)}, 
  title={Virtual SCARA Robot with Reduced Dynamics in a Real-Time Simulation Scheme for Robotics and Control Engineering Education}, 
  year={2021},
  volume={},
  number={},
  pages={1-6},
  abstract={Industry 4.0 has imposed new challenges and oppor-tunities to engineering education in robotics and control systems. The concept of the digital twin can be partially implemented with the use of virtual robots that incorporate 3D models and numerical simulations of the dynamical behaviour. This work presents the development of a virtual 3D SCARA robot which requires an external controller for the joint and kinematic motion control, this was implemented as a tool for teaching and learning robotics and control. The virtual 3D robot incorporates a novel numerical simulation that combines the Newton-Euler dynamic equations with the Rayleigh energy dissipation equation to consider the viscous friction. The developed virtual robot can be implemented in a real time simulation scheme connected to an external controller and used as an educational tool in a virtual robotics laboratory.},
  keywords={Solid modeling;Three-dimensional displays;Service robots;Computational modeling;Friction;Numerical simulation;Mathematical models;SCARA;Robot Dynamic Modeling;Robot Dynamics with Joint Friction;Hardware-in-the-loop simulation},
  doi={10.1109/ICECET52533.2021.9698437},
