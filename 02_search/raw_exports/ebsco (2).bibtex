@article{17753421320240601,
 abstract  = "This document is a summary of the special issues published in the journal Simulation to commemorate its 100th volume. The articles in these special issues were written by members of the journal's Editorial Board, who were chosen for their diverse expertise and perspectives. The articles cover a range of topics, including verification and validation in modeling and simulation, the integration of real-time data into simulations, the use of machine learning and artificial intelligence in verification and validation, the application of virtual reality in simulation, the connection between modeling and simulation and industrial needs, the use of differential equations in signal representation, the use of modeling and simulation in engineering education, research gaps in simulation interoperability, the use of large language models for modeling and simulation, and the role of digital twins and cyber-physical systems in the ongoing industrial revolution. The authors hope that these articles ",
 author    = "Giabbanelli, Philippe J and Wainer, Gabriel A",
 number    = "6",
 title     = "Commemorating SIMULATION's 100th volume: selected articles by Editorial Board members.",
 volume    = "100",
 url       = "https://research.ebsco.com/plink/7d68f556-23f1-3eb0-b8fb-11e361e80259",
