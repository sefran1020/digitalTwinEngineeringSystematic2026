 keywords  = "Cutting force; Machine tools; Machining; Cutting tools; Workpieces; Milling (Metalwork); Industrial Machinery and Equipment Merchant Wholesalers; Machine Tool Manufacturing; All other building equipment contractors; Cutting Tool and Machine Tool Accessory Manufacturing; Digital twin; Syncope",
 pages     = "N.PAG-N.PAG",
 note      = "",
}

@article{17593830620240101,
 abstract  = "As mentioned in Part 1, for product iterative design, the digital simulation method, as the product performance analysis method, has the problems of time cost and computing resources. To address this issue, a product performance rapid simulation approach driven by digital twin (DT) data for variable product structures in Part 1 was proposed, which could replace the digital simulation method. Meanwhile, for performance analysis under variable operating conditions during the product design and operation phase, digital simulation also has the above problems. Therefore, based on the method for variable product structures proposed in Part 1, a product performance rapid simulation approach driven by DT data for variable operating conditions is proposed in this paper. Firstly, the framework for variable operating conditions is designed based on the makeTwin reference architecture, including twin source data acquisition for the product under different operating conditions, twin data-driven pr",
 author    = "Dong, Lili and Hu, Tianliang and Li, Junrui and Meng, Qi and Ma, Songhua",
 number    = "null",
 title     = "A product performance rapid simulation approach driven by digital twin data: Part 2. For variable operating conditions.",
 volume    = "59",
 url       = "https://research.ebsco.com/plink/021d6176-4b38-3a5e-9ef3-28b7552bf035",
 year      = "2024",
 issn      = "14740346",
 journal   = "Advanced Engineering Informatics",
 keywords  = "Digital computer simulation; Bolted joints; Product design; Simulation methods & models; Industrial Design Services; Digital twin",
 pages     = "N.PAG-N.PAG",
 note      = "",
}

@article{18938782820250910,
 abstract  = "RWTH Aachen is integrating Dassault Systèmes' cloud-based 3DEXPERIENCE platform into the curricula of 13,000 mechanical engineering students to enhance engineering education and train highly qualified professionals. The partnership, which is set for ten years, focuses on Model-Based Systems Engineering (MBSE) and promotes hands-on learning as well as collaborative research activities. The goal is to strengthen the innovation capacity of the industry and close the skills gap in the field of systems engineering to accelerate industrial transformation in Germany.",
