 keywords  = "Distillation; Chemical process control; Real-time control; Programming languages; Process control systems; Process, Physical Distribution, and Logistics Consulting Services; Software Publishers; Software publishers (except video game publishers)",
 pages     = "31-35",
 note      = "",
}

@article{19318607320260423,
 abstract  = "In metal-based additive manufacturing, precise dimensional accuracy remains a challenge for manufacturers due to thermal distortion; moreover, complex geometries contribute to material waste and increase post-processing time. The current study proposes a novel control system called as supervisory control and data acquisition system that integrates an in-situ monitoring system with a digital twin to address these challenges. Weld pool image data is collected using a video camera mounted on a welding robot arm under in-situ monitoring, and image masks were generated by the segment anything model. A hybrid deep learning network is composed of ResNet50 and long short-term memory in the digital twin was trained with heterogeneous data, including process parameters (time, current, welding speed, wire feed speed), weld pool image, width of weld pool, and responses (height and width of weld bead). At regular time intervals, the hybrid deep learning network was trained with updated heterogeneo",
 author    = "Rao, Kaki Venkata and Kumar, Yekula Prasanna and Murthy, Perumalla Bala Guru Satya Narasimha and Kumar, Kaladari Adarsha and Reddy, Kumchala Balakrishna and Rambabu, Velamala",
 number    = "null",
 title     = "Vision-integrated supervisory control and data acquisition for weld bead control in wire arc additive manufacturing.",
 volume    = "null",
 url       = "https://research.ebsco.com/plink/4d4f7cc5-42a1-3668-88e4-e04e71a1611b",
 year      = "2026",
 issn      = "0268-3768",
 journal   = "International Journal of Advanced Manufacturing Technology",
 keywords  = "Supervisory control & data acquisition systems; Digital twin; Thermal strain; Deep learning; Process optimization; Real-time computing; Electric welding",
 pages     = "1-18",
 note      = "",
}

@article{19215137620260501,
 abstract  = "Flexible manufacturing has become a key paradigm in contemporary industry. Its characteristics of personalization and customization necessitate continual, dynamic optimization during operation. However, existing approaches still have limitations in the comprehensive description of production lines and in dynamic perception, which prevents optimization algorithms from responding to changes in a timely manner, thereby constraining the accuracy and applicability of the resulting solutions. To address these shortcomings, this paper leverages the virtual–physical dynamic consistency of digital twins and proposes a method for production-line dynamic operating-state prediction and optimization based on a digital twin model that integrates mechanistic and data components. The mechanistic model abstracts and classifies production-line equipment and introduces a state-transition mechanism for operational processes, thereby providing a comprehensive characterization of the line's structure and o",
 author    = "Meng, Qi and Hu, Tianliang and Zhou, Shuaichang and Li, Jingkai",
 number    = "null",
 title     = "Digital twin-driven dynamic prediction of operation status and process optimization for flexible production line.",
 volume    = "308",
 url       = "https://research.ebsco.com/plink/d20a2aa5-eb35-31e9-9162-6c5b44f709bd",
 year      = "2026",
 issn      = "09574174",
 journal   = "Expert Systems with Applications",
 keywords  = "Process optimization; Forecasting; Flexible manufacturing systems; Manufacturing industries; Finite state machines; Machine learning; Digital twin; Causal models",
 pages     = "N.PAG-N.PAG",
 note      = "",
}

@article{19163597920260405,
 abstract  = "In the Industry 4.0 era, improving energy efficiency and product quality is a key challenge for the manufacturing sector, with the aim of reducing both energy consumption and surface roughness. The present study proposed a supervisory control and data acquisition system to address these issues in laser beam machining of AISI 316 L stainless steel. A digital twin is integrated with supervisory control and data acquisition interface, forming a closed-loop connection between the physical system and its digital counterpart. The digital twin is a combination of a mathematical model and an artificial neural network. The mathematical models estimate the surface roughness and specific machining energy using the experimental data collected from the physical system. When the estimated surface roughness and the specific machining energy exceeded their target values, the digital twin optimizes and adjusts the input parameters such as laser power, laser frequency, and cutting speed. The process pa",
 author    = "Venkata Rao, K. and Venkata Vaneesha, K.",
 number    = "null",
 title     = "Updating digital twin in supervisory control and data acquisition for sustainable laser beam micro machining.",
 volume    = "71",
 url       = "https://research.ebsco.com/plink/ab25dff4-c461-321e-abe0-cdf58dc37eda",
 year      = "2026",
 issn      = "14740346",
 journal   = "Advanced Engineering Informatics",
 keywords  = "Supervisory control & data acquisition systems; Artificial neural networks; Surface roughness; Energy consumption; Process optimization; Digital twin; Laser machining; Industry 4.0",
 pages     = "N.PAG-N.PAG",
 note      = "",
}

@article{18912128920251001,
 abstract  = "The accelerated proliferation of industrial, agricultural, and municipal waste, in conjunction with the escalating global demand for energy, underscores the imperative for sustainable waste-to-energy (WtE) methodologies. This review scrutinizes contemporary advancements in nano-engineered catalysts that augment the selectivity, kinetics, and energy recovery associated with the conversion of waste into hydrogen, syngas, and value-added fuels. Attention is directed towards a variety of catalyst categories, including single-atom catalysts, metal-organic framework (MOF)-derived structures, biomass-derived carbon nanomaterials, and plasmonic nanoparticles, as well as their synthesis utilizing waste precursors. Unlike previous reviews, this investigation combines nanoscale catalyst design with techno-economic evaluations, environmentally friendly synthesis methodologies, and artificial intelligence (AI)-driven optimization, thereby offering a comprehensive perspective that interconnects mat",
 author    = "Nalla, Bhanu Teja and Choudhary, Binod Kr and Sunil Kumar, Muniraj and Ramachandra, Chamarajanagar Gopal and Vaghela, Divyesh Rameshbhai and Pradhan, Premananda and Smerat, Aseel and Kamakshi Priya, Kumar",
 number    = "null",
 title     = "Nanocatalyst-enabled waste-to-energy systems: from material innovation to techno-economic and sustainability pathways.",
 volume    = "null",
 url       = "https://research.ebsco.com/plink/f3d5f2cf-8c93-38b6-9fa5-fb102bc02fec",
 year      = "2025",
 issn      = "0193-4929",
 journal   = "Reviews in Inorganic Chemistry",
 keywords  = "Sustainability; Circular economy; Hydrogen production; Waste products as fuel; Cost benefit analysis; Artificial intelligence; Nanoparticles; Energy harvesting; Industrial Gas Manufacturing",
 pages     = "1-null",
 note      = "",
}

@article{17846877320240701,
 abstract  = "Connecting the chemical industry with the academic environment has created a unique opportunity to apply experiential learning in many areas of teaching. A new approach of using the existing operator training simulator, which is basically a digital twin of a new dicyclopentadiene plant, was used to educate and train students from technical universities. Using this simulator, students can gain adequate knowledge for control, process optimization, and problem solving under nonstandard operating conditions. Simulating a dynamic process in the Aspen HYSYS interface along with elements of a real industrial control system and control interface, and especially the online visualization of the results, helps students understand the physicochemical principles through their own intervention and experience of the consequences. The training simulator's ability to accurately reflect ongoing processes can be verified by students during a guided tour of a production plant. The experience with student",
 author    = "Bělohlav, Vojtěch and Jirout, Tomáš and Malecký, Miroslav and Herink, Tomáš",
 number    = "4",
 title     = "Effective application of operator training simulator in experiential education.",
 volume    = "32",
 url       = "https://research.ebsco.com/plink/5bd86185-ed75-3c38-9968-5b072ca8a7e9",
 year      = "2024",
 issn      = "10613773",
 journal   = "Computer Applications in Engineering Education",
 keywords  = "Chemical processes; Industrial controls manufacturing; Process optimization; Relay and Industrial Control Manufacturing; Switchgear and switchboard, and relay and industrial control apparatus manufacturing; Experiential learning; Synthetic training devices; Digital twin",
 pages     = "1-13",
 note      = "",
}

@article{17635585520240420,
 abstract  = "Digital twin (DT) technology, as one of the top strategic technology trends for 2020, has received widespread attention and has gradually been widely used in smart manufacturing equipment. However, there is a lack of systematic evaluation guidance, which accesses the applicability of DT technology for specific applications of smart manufacturing equipment. At the same time, CNC machine tool (CNCMT) as an essential part of smart manufacturing equipment also faces the above dilemma. Motivated by this need, a digital twin technology applicability evaluation method for CNCMT is proposed in this paper. This method firstly analyzes the application-oriented requirements of DT-based CNCMT to obtain the optimal evaluation index and structure model. And then, the DT technology applicability evaluation of CNCMT based on the optimal evaluation model as well as system engineering algorithms is researched. With this effort, DT technology applicability of CNCMT is quantified starting from the initia",
 author    = "Wei, Yongli and Hu, Tianliang and Wei, Shiyun and Ma, Songhua and Wang, Yanqing",
 number    = "11",
 title     = "Digital twin technology applicability evaluation method for CNC machine tool.",
 volume    = "131",
 url       = "https://research.ebsco.com/plink/56118d4c-a674-3d0a-841f-dd96db5d23c8",
 year      = "2024",
 issn      = "0268-3768",
 journal   = "International Journal of Advanced Manufacturing Technology",
 keywords  = "Numerical control of machine tools; Digital twin; Systems engineering; Digital technology; Cutting tools; Cutting Tool and Machine Tool Accessory Manufacturing",
 pages     = "5607-5623",
 note      = "",
}

@article{18300493620240101,
 abstract  = "The Unit Operations Laboratory (UOL) is a place where third-year chemical engineering students can apply their engineering and science concepts on pilot-scale equipment. However, the physical lab is resource-intensive, requiring protective equipment and constant supervision. In addition, due to limited units for large groups of students, students perform experiments according to the rolling program schedule, making alignment with lecture teaching and hands-on learning challenges. The research team focuses on increasing the accessibility of the UOL by using simulation gaming in standard, virtual reality and augmented reality modalities as an educational tool. The "Virtual Unit Ops Lab" application places students in an immersive simulated environment of the physical lab, where they can get practical experiences without the difficulties of an in-person lab by using specialized headsets and controllers, which allows the student to move and interact with various parts of the machine physi",
 author    = "Chan, Ariel and Liu, Jackie Anjie",
 number    = "null",
 title     = "WiP: Development of Multi-user enabled, Interactive and Responsive, Virtual/Augmented Reality based Laboratory Training System.",
 volume    = "null",
 url       = "https://research.ebsco.com/plink/43550808-a043-3173-8034-395117881afb",
 year      = "2024",
 issn      = "2153-5868",
 journal   = "Proceedings of the ASEE Annual Conference & Exposition",
 keywords  = "Virtual reality; Augmented reality; Simulation games; Chatbots; Chemical engineering education; Digital twin; Team learning approach in education",
 pages     = "1-7",
 note      = "",
}

@article{17626601820240401,
 abstract  = "In the workshop scheduling problem, frequent disturbances lead to continuous and frequent rescheduling. This is detrimental to the optimal utilization of production resources, the maximization of production efficiency, and the minimization of operational costs. Therefore, finding an effective method to reduce frequent rescheduling is crucial for stable and efficient workshop operations. This paper introduces digital twin (DT) technology. Serving as a digital replica of a physical system, DT establishes an interactive connection between the physical entity and its digital counterpart. It has been applied in multiple fields. A disturbance evaluation method for scheduling mechanisms based on DT technology is proposed and studied in this paper. Firstly, this method evaluates the impact of disturbances by using a causal factor chart (CFC) and convolutional neural networks (CNN). Then, corresponding scheduling mechanisms are proposed based on the degree of disturbance impact. DT technology ",
 author    = "Yue, Pengjun and Hu, Tianliang and Wei, Yongli and Dong, Lili and Meng, Qi and Ma, Songhua",
 number    = "7/8",
 title     = "A disturbance evaluation method for scheduling mechanisms in digital twin-based workshops.",
 volume    = "131",
 url       = "https://research.ebsco.com/plink/98edaac9-6d80-3945-a73b-c05922d2f75d",
 year      = "2024",
 issn      = "0268-3768",
 journal   = "International Journal of Advanced Manufacturing Technology",
 keywords  = "Convolutional neural networks; Digital twin; Electronic paper; Operating costs; Evaluation methodology",
 pages     = "4071-4088",
 note      = "",
}

@article{18164509320241116,
 abstract  = "The article discusses the progress meeting of the EU-funded CATCH_VR project, which aims to enhance engineering education by integrating Augmented Reality (AR) and Virtual Reality (VR) using digital twins. Four Pakistani universities participated in the meeting hosted by the Technical University of Sofia in Bulgaria. The meeting focused on curriculum development, lab infrastructure, establishing a Center of Excellence, quality assurance, capacity building, and dissemination strategies. The event showcased practical applications of AR/VR and digital twin technologies, fostering collaboration among international institutions to advance innovative engineering education.",
 author    = "",
 number    = "22",
