@article{16142118320230115,
 abstract  = "Advanced Design and Manufacturing in Industry 4.0 This Special Issue emphasized Industry I4.0 and, in particular, the advancement of design and manufacturing. 10.1515/mper-2016-0030 4 Wang S., Wan J., Zhang D., Li D., Zhang C. Towards smart factory for industry 4.0: A self-organized multi-agent system with big data based feedback and coordination. Industry 4.0 (I4.0) is the term used in the manufacturing world to denote the fourth industrial revolution [[1]], characterized by the use of cyber-physical systems [[2]]. Kwak et al. [[12]], in the paper titled "A Study on Semantic-Based Autonomous Computing Technology for Highly Reliable Smart Factory in Industry 4.0", proposed a methodology for the autonomous control of a smart factory on a digital twin.",
 author    = "Marannano, Giuseppe and Giallanza, Antonio",
 number    = "2",
