 number    = "null",
 title     = "Toward digital twins for high-performance manufacturing: Tool wear monitoring in high-speed milling of thin-walled parts using domain knowledge.",
 volume    = "88",
 url       = "https://research.ebsco.com/plink/6305d28c-0197-3e02-978b-4ecb4c518a8c",
 year      = "2024",
