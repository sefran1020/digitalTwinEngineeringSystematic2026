	volume = {59},
	issn = {24058971},
	url = {https://www.scopus.com/pages/publications/105029667754?origin=resultslist},
	doi = {10.1016/j.ifacol.2025.12.150},
	abstract = {The integration of predictive industrial agents into Industry 4.0 (I4.0) systems offers new possibilities for adaptive learning and intelligent control in industrial and educational contexts. This paper presents a framework leveraging predictive agents, developed using the Python Agent Development Environment (PADE), embedded within programmable logic controllers (PLCs) to enhance the predictability and interoperability of digital twin (DTs) environments. By incorporating Asset Administration Shells (AAS) and adhering to IEC 61131-3 and IEC 61499 standards into the various PLCs, the system enables seamless communication and integration between flexible manufacturing cells in a remotely operated I4.0 laboratory. The predictive agents utilize supervised learning algorithms to forecast operational outcomes and optimize system performance, adapting dynamically to process requirements. Experimental results demonstrate the frameworḱs ability to enhance interoperability, and usability. Additionally, the proposed system addresses the educational gap by equipping engineering students with practical experience in predictive control and industrial standards. This research advances the field of intelligent adaptive control systems and highlights the potential of integrating predictive agents with digital twins by agent-based AAS to meet the evolving demands of I4.0. © 2025 The Authors.},
	language = {English},
	number = {14},
	booktitle = {{IFAC}-{PapersOnLine}},
	publisher = {Elsevier B.V.},
	author = {Cruz Salazar, L.A. and Tovar, H.S. and Prada Salamanca, E.A. and Márquez Juárez, J.C. and Cruz, E.M.},
	year = {2025},
	keywords = {Machine learning, Learning systems, Industry 4.0, Engineering education, Intelligent agents, Adaptive learning, E-learning, Adaptive learning systems, Digital Twin, Learning algorithms, Industrial research, Case-studies, Digital twin, Adaptive control systems, Intelligent control, Predictive control systems, Programmable logic controllers, Programmed control systems, Flexible manufacturing systems, Autonomous agents, Industrial context, Agent based, Adaptive Learning System, Asset administration shell, Asset Administration Shell, IEC 61499, Logic controller, Predictive industrial agent, Predictive Industrial Agent, Programmable logic},
	pages = {202--207},
	annote = {Source DB: Scopus},
	file = {PDF:E\:\\Zotero\\storage\\LWUNQ5FG\\Cruz Salazar et al. - 2025 - Adaptive Learning and Interoperability in I4.0 A Case Study of Agent-based Digital Twin with Asset.pdf:application/pdf},
