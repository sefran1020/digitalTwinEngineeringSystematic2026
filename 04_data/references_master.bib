@inproceedings{hagedorn_project-based_2023,
	title = {{PROJECT}-{BASED} {LEARNING} {IN} {ENGINEERING} {EDUCATION} – {DEVELOPING} {DIGITAL} {TWINS} {IN} {A} {CASE} {STUDY}.},
