	keywords = {'current, Augmented reality, Augmented Reality (AR), Case-studies, E-learning, Education computing, Education systems, Educational technology, Educational Technology, Engineering education, Engineering research, Immersive learning, Immersive Learning, Interactivity, Knowledge transfer, Laboratories, Learning systems, Performance, Practical skill, Students, Technology in Education, Technology in educations, Virtual lab, Virtual Labs, Virtual reality},
	pages = {1143--1148},
