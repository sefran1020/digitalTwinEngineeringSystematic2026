@article{abdelrahman_what_2025,
	title = {What is a {Digital} {Twin} anyway? {Deriving} the definition for the built environment from over 15,000 scientific publications},
	volume = {274},
	issn = {03601323 (ISSN)},
	url = {https://www.scopus.com/pages/publications/85219499715?origin=resultslist},
	doi = {10.1016/j.buildenv.2025.112748},
	abstract = {The concept of Digital Twins (DT) has attracted significant attention across various domains, particularly within the built environment. However, there is a sheer volume of definitions and the terminological consensus remains out of reach. The lack of a universally accepted definition leads to ambiguities in their conceptualization and implementation, and may cause miscommunication for both researchers and practitioners. We employed Natural Language Processing (NLP) techniques to systematically extract and analyze definitions of DTs from a corpus of more than 15,000 full-text articles spanning diverse disciplines. The study compares these findings with insights from an expert survey that included 52 experts. The study identifies concurrence on the components that comprise a “Digital Twin” from a practical perspective across various domains, contrasting them with those that do not, to identify deviations. We investigate the evolution of digital twin definitions over time and across different scales, including manufacturing, building, and urban/geospatial perspectives. We extracted the main components of Digital Twins using Text Frequency Analysis and N-gram analysis. Subsequently, we identified components that appeared in the literature and conducted a Chi-square test to assess the significance of each component in different domains. Our analysis identified key components of digital twins and revealed significant variations in definitions based on application domains, such as manufacturing, building, and urban contexts. The analysis of DT components reveal two major groups of DT types: High-Performance Real-Time (HPRT) DTs, and Long-Term Decision Support (LTDS) DTs. Contrary to common assumptions, we found that components such as simulation, AI/ML, real-time capabilities, and bi-directional data flow are not yet fully mature in the digital twins of the built environment. We derived two definitions for the Building/Architecture DT and the City/Urban DTs. Both definitions have a must-have components (such as spatial and temporal data updates) and good-to-have components such as prediction, AI, bi-directional data flow, and Real-time data exchange. One of the key findings is that the definition of digital twins has not yet reached its equilibrium phase, highlighting the need for ongoing revisions as technologies emerge or existing ones become obsolete. To address this, we introduce a novel, reproducible methodology that enables researchers to refine and adapt the current definitions in response to technological advancements or deprecations. © 2025 The Authors},
	language = {English},
	journal = {Building and Environment},
	publisher = {Elsevier Ltd},
	author = {Abdelrahman, M. and Macatulad, E. and Lei, B. and Quintana, M. and Miller, C. and Biljecki, F.},
	year = {2025},
	keywords = {architectural design, Bi-directional, Building components, Building digital twin, Built environment, City digital twin, conceptual framework, Digital twin, digitization, Directional data, Language processing, literature review, LLM, LLMs, Metadata, Natural language processing, Natural language processing systems, Natural languages, Network security, NLP, real time, research work, technology adoption, terminology, Terminology, urban area, Urban digital twin, urban geography},
	annote = {Export Date: 30 May 2026; Cited By: 49; Correspondence Address: F. Biljecki; Department of Architecture, National University of Singapore, Singapore, 4 Architecture Drive, 117566, Singapore; email: filip@nus.edu.sg; CODEN: BUEND},
}

@article{aljumah_intelligent_2026,
	title = {Intelligent defense industry-based predictive maintenance framework: {Digital} {Twin} perspective},
	volume = {276},
	issn = {02632241 (ISSN)},
	url = {https://www.scopus.com/pages/publications/105035472283?origin=resultslist},
	doi = {10.1016/j.measurement.2026.121436},
	abstract = {Digital Twin (DT)-based predictive maintenance has emerged as an advanced approach for improving the reliability, availability, and operational readiness of military vehicles and defense equipment. Conventional maintenance strategies, which primarily rely on periodic inspection schedules and reactive fault handling, often face limitations in early fault localization, dynamic condition tracking, and uncertainty-aware decision support in mission-critical environments. To address these challenges, this study introduces an IoT-enabled DT framework for real-time condition monitoring and predictive fault detection in defense assets. By integrating sensor-driven IoT networks, the framework continuously collects multi-modal operational data to construct high-fidelity digital replicas of physical military systems. A quantum probability-inspired quantification model is incorporated to evaluate mechanical and functional anomalies under uncertain and dynamic operational conditions. Furthermore, Temporal Data Mining (TDM) techniques are employed to extract sequential behavioral patterns, enabling the estimation of an Asset Health Index through a statistically validated Multi-Scaled Gated Recurrent Unit (M-GRU) architecture. The framework incorporates a two-phase alert generation mechanism for early malfunction prediction and proactive maintenance scheduling. Experimental validation using an 80:20 train–test split with 5-fold cross-validation and five independent runs demonstrates that the proposed DT-driven approach achieves classification performance of precision: 88.21±0.37\%, specificity: 87.94±0.41\%, and sensitivity: 88.03±0.39\%. For severity prediction, the proposed M-GRU model achieves accuracy: 94.14±0.21\%, precision: 93.32±0.24\%, sensitivity: 93.74±0.23\%, and F-measure: 92.37±0.22\%, with statistically significant improvement over competing models (p{\textless}0.05). The system records an average latency of 50.33s and maintains a stability index of 0.77 across repeated executions, confirming robustness and deployment feasibility. © 2026 Elsevier Ltd},
	language = {English},
	journal = {Measurement: Journal of the International Measurement Confederation},
	publisher = {Elsevier B.V.},
	author = {Aljumah, A. and Ahanger, T.A.},
	year = {2026},
	keywords = {Condition monitoring, Decision support systems, Defence equipment, Defense Industry, Digital twin, Digital Twin, Fault detection, Industry based, Maintenance strategies, Military vehicle equipments, Military vehicles, Multi-scaled gated recurrent unit, Multi-Scaled Gated Recurrent Unit (M-GRU), Network security, Operational readiness, Predictive maintenance, Quantum probabilities, Quantum probability, Temporal data mining, Temporal Data Mining},
	annote = {Export Date: 30 May 2026; Cited By: 0; Correspondence Address: A. Aljumah; College of Computer Engineering and Sciences, Prince Sattam Bin Abdulaziz University, Saudi Arabia; email: aljumah@psau.edu.sa; CODEN: MSRMD},
}

@article{kabir_digital_2025,
	title = {Digital {Twin} {Tools} for {Smart} {Manufacturing}: {A} {Paradigm} {Shift} for {Industry} 4.0},
	volume = {6},
	issn = {26441284 (ISSN)},
	url = {https://www.scopus.com/pages/publications/105020952906?origin=resultslist},
	doi = {10.1109/OJIES.2025.3628531},
	abstract = {The convergence of digital twin (DT) technology with Internet of Things-driven smart manufacturing is driving a paradigm shift in Industry 4.0 and beyond. By enabling real-time cyber-physical integration, data-centric decision-making, and closed-loop optimization, DTs are becoming central to the evolution of manufacturing systems. This perspective article explores foundational concepts, emerging trends, and the market trajectory of DTs in manufacturing. We provide insights into the landscape of current tools and platforms supporting DT development, highlighting their capabilities and limitations. We also discuss the role, practical challenges, and future opportunities of the ISO 23247 standard in supporting interoperable and scalable DT frameworks in manufacturing. Finally, we discuss case studies with practical implementations, emphasizing the need for higher autonomy, artificial intelligence-enabled predictive analytics, robust lifecycle governance, and resilience in next-generation manufacturing ecosystems. © 2020 IEEE.},
