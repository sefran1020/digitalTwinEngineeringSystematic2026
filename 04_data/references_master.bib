	year = {2026},
	keywords = {Academic pursuit, Education computing, Energy, Engaging students, Engineering education, Growth and development, High educations, Industrial revolutions, Industry 4.0, Learning retention, Societal problems, Student engagement, Student motivation, Students},
	pages = {25--50},
