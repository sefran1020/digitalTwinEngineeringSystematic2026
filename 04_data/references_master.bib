	year = {2025},
	keywords = {Big data, Computer aided instruction, Cutting edge technology, Data analytics, Education 4.0, Education computing, Educational modelling, Educational robots, Engineering education, Ethical technology, High educations, Industrial revolutions, Industry 4.0, Learning environments, Learning experiences, Students, Teachers', Teaching, Technological advancement, Technological advancements},
	pages = {121--129},
	annote = {Export Date: 30 May 2026; Cited By: 0},
}

@article{menipaz_engineering_2026,
	title = {Engineering {Education} for {Industry} 5.0: {A} {Systemic} {Approach} to {AI}-{Driven} {Talent} {Development}},
	volume = {Part F1419},
	issn = {2731040X (ISSN)},
	url = {https://www.scopus.com/pages/publications/105029256173?origin=resultslist},
	doi = {10.1007/978-3-032-14489-8_3},
	abstract = {Industry 5.0 is reshaping industrial ecosystems through human–machine collaboration, advanced analytics, and sustainable, human-centric practices. As skilled personnel are the main asset of this transformation, higher education plays a pivotal role in preparing graduates who combine technical expertise with adaptability, ethical awareness, and innovation. Artificial Intelligence, as a disruptive technology, is transforming both industrial operations and educational processes. This paper examines the integration of AI into learning activities in engineering programs at the Holon Institute of Technology (Israel) within a structured institutional research and development initiative. Using a large-scale student survey grounded in validated theoretical frameworks, we analyzed how such integration influences AI-specific, general cognitive, and specialized professional capabilities, as well as self-perceived employability. Subgroup comparisons, mediation analysis, and regression modeling mapped the interrelationships between AI integration, capability development, and employability, and identified the effects of moderating factors such as AI proficiency, program level, employment status, and workplace AI use. Findings show that employability gains are driven mainly by reinforcing feedback loops linking the three capability domains, with their strength shaped by key background conditions. The weak direct link between AI integration and employability underscores the importance of aligning AI-integrated pedagogy with applied, real-world engagement to sustain capability growth. The study addresses a gap in the literature on AI integration in education by modeling it as a dynamic, complex adaptive system and provides a framework for designing effective, scalable, and contextually grounded AI implementation in higher education—supporting the alignment of graduate skills with evolving Industry 5.0 workforce needs. © The Author(s), under exclusive license to Springer Nature Switzerland AG 2026.},
	language = {English},
	journal = {Lecture Notes in Operations Research},
	publisher = {Springer Nature},
	author = {Menipaz, E. and Bukhshtaber, N. and Bulmash, B.},
	year = {2026},
	keywords = {AI Integration in Engineering Education, Industry 5.0 Skills Development, System Dynamics in Higher Education},
	pages = {27--36},
	annote = {Export Date: 30 May 2026; Cited By: 0; Correspondence Address: E. Menipaz; Holon Institute of Technology (HIT), Holon, Israel; email: ehudm@hit.ac.il},
}

@inproceedings{toth_bridging_2026,
	title = {Bridging {Skill} {Gaps} through {STEM}: {HR} {Risk} {Management} in {Higher} {Education} for {Industry} 4.0 and 5.0},
	isbn = {28360834 (ISSN); 979-833159163-2 (ISBN)},
	url = {https://www.scopus.com/pages/publications/105035502943?origin=resultslist},
	doi = {10.1109/SAMI68106.2026.11420348},
	abstract = {This study investigates human resource risks in the context of the machinery industry, focusing on gaps in professional knowledge and competencies that threaten operational stability. With the rise of Industry 4.0 and 5.0, companies face increasing demands for advanced technical skills and adaptability. The research emphasizes the role of STEM (Science, Technology, Engineering, and Mathematics) education in addressing these challenges, highlighting its potential to enhance critical thinking, problem-solving, collaboration, and digital literacy. Two structured questionnaires—one for instructors and one for students—were distributed at the Bánki Donát Faculty of Mechanical and Safety Engineering, Óbuda University. The analysis revealed significant correlations between the availability of STEM-related resources and perceived educational quality. Instructors reported limited access to laboratories and technical support, while students confirmed frequent use of digital tools and exposure to practical learning environments. Statistical methods, including Spearman’s rank correlation and Chi-square tests, were applied to explore relationships between variables. The findings underscore the importance of supporting educators with methodological and technical resources and aligning educational practices with labour market expectations. Recommendations include enhancing technical infrastructure, improving teaching strategies, and strengthening the connection between theory and practice to better prepare students for real-world challenges. ©2026 IEEE.},
	language = {English},
	number = {2026},
	booktitle = {Proc. {Int}. {Symp}. {Appl}. {Mach}. {Intell}. {Informatics}, {SAMI}},
	publisher = {Institute of Electrical and Electronics Engineers Inc.},
	author = {Tóth, G.N. and Drégelyi-Kiss, Á.},
	year = {2026},
	note = {Journal Abbreviation: Proc. Int. Symp. Appl. Mach. Intell. Informatics, SAMI},
