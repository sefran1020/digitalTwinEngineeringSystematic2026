	isbn = {979-833153607-7 (ISBN)},
	url = {https://www.scopus.com/pages/publications/105012092111?origin=resultslist},
	doi = {10.1109/ICCSAI64074.2025.11064019},
	abstract = {Technology has taken over education systems, and one of the most outstanding inventions is Augmented Reality abbreviated as AR, which enhances the practical skills to be gained. The current study explores the effects of integrating AR in the virtual labs as a response to typical issues, including low interactivity, rigidity, and lack of student's engagement. The study employed a comparative methodology that compares the effectiveness of augmented reality (AR)-based virtual labs versus traditional physical labs in enhancing practical learning, analyzing two undergraduate student groups: one who practiced augmented reality virtual labs and other who practiced regular physical ones. Specifically, performance rates of knowledge transferred and retained, the level of knowledge utilization, and compliance with the proper performance of the defined procedures were reviewed. In terms of improvement percentage, the knowledge gain was by 28 \% for the experimental group compared to 18\% for the control group in terms of retention rates. Lockwood and Middendorf's sample surveys implied that engagement with AR users created a 46\% increased satisfaction of users, and procedural accuracy increased by 17 percent. Such outcomes speak volumes about the effectiveness of AR in helping actual understanding and refinement of skills. However, many barriers such as high cost, technical restraints and the requirement for content personalization hinder the implementation of AR. It is vital to remove these barriers in order to bring about increased adoption. In the future, there is a need to study the combination of AR with artificial intelligence for learning and work collaboration to improve students' learning. This research strengthens the belief of a significant positive change in educational dynamics through the advancement of AR towards higher education implementation of other effective teaching strategies, and shifting perception of the learning process.  © 2025 IEEE.},
	language = {English},
	booktitle = {Int. {Conf}. {Commun}., {Secur}., {Artif}. {Intell}. {ICCSAI}},
	publisher = {Institute of Electrical and Electronics Engineers Inc.},
