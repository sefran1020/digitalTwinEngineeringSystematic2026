@article{alashwal_transforming_2026,
	title = {Transforming {Engineering} {Drawings} {Curriculum}: {The} {Integration} of {3D} {Printing} {Competencies}},
	volume = {15},
	issn = {19272677 (ISSN)},
	url = {https://www.scopus.com/pages/publications/105028851129?origin=resultslist},
	doi = {10.5430/jct.v15n1p183},
	abstract = {This study investigates the integration of 3D printing competencies into the undergraduate Engineering Drawing curriculum at a private Institution in Jeddah, Saudi Arabia. Despite the widespread use of computer-aided design in engineering education, many engineering drawing curriculums remain largely theoretical, offering limited opportunities for students to translate digital designs into physical prototypes and develop applied, industry-relevant competencies. The initiative aimed to bridge the gap between computer-aided design (CAD) skills and practical prototyping, addressing student concerns about the real-world applicability of engineering drawing. A mixed-method, longitudinal research design was adopted, combining pre- and post-intervention surveys with descriptive and inferential statistical analysis, as well as comparative analysis of performance metrics, to evaluate short-term learning gains and longer-term skill transfer across academic levels. A two-phase survey methodology was employed: the first phase was administered to 86 freshman students enrolled in MEN100 before and after a two-week 3D printing module, and the second phase was distributed to 83 sophomore students and four faculty members in design courses (IEN201/202) one year later. The key Results indicate that prior to training, fewer than 2\% of students had any knowledge of 3D printing, with 91\% perceiving it as difficult to use. Post-training, over 80\% demonstrated awareness, 91\% agreed that 3D printing supported engineering applications, and 95\% confirmed substantial hands-on learning. In sophomore design courses, 90\% of students reported that the skills gained in MEN100 directly supported prototyping and problem-solving, while instructors highlighted enhanced independence, creativity, and design confidence. Quantitative comparisons revealed a 28\% improvement in spatial visualization and a 34\% increase in drawing accuracy among students exposed to 3D printing versus traditional CAD-only instruction. These findings confirm that early exposure to 3D printing raises deeper comprehension, creativity, and applied engineering competencies, aligning curricula with Industry 4.0 demands. This study recommends that future research explore the systematic integration of foundational 3D printing modules into early engineering drawing curriculums to further align engineering education with Industry 4.0 demands. Copyright for this article is retained by the author(s), with first publication rights granted to the journal. This is an open-access article distributed under the terms and conditions of the Creative Commons Attribution license (http://creativecommons.org/licenses/by/4.0/).},
	language = {English},
	number = {1},
	journal = {Journal of Curriculum and Teaching},
	publisher = {Sciedu Press},
	author = {Alashwal, M.},
	year = {2026},
	keywords = {3D printing, additive manufacturing, engineering drawing, prototyping, spatial visualization},
	pages = {183--197},
	annote = {Export Date: 30 May 2026; Cited By: 0; Correspondence Address: M. Alashwal; Department of Computer Science and Information Technology, Jeddah International College, Jeddah, 23833, Saudi Arabia; email: m.alashwal@jicollege.edu.sa},
	file = {Full Text PDF:E\:\\Zotero\\storage\\8CPIWN6Q\\Alashwal - 2026 - Transforming Engineering Drawings Curriculum The Integration of 3D Printing Competencies.pdf:application/pdf},
}

@article{kovaleva_promoting_2026,
	title = {Promoting and {Developing} {Sustainable} {Behavior} among {Engineering} {Students}: {The} {Role} of {Higher} {Education} {Institutions}, {Digital} {Environments} and {Digital} {Technologies}},
	volume = {5},
	issn = {2696628X (ISSN)},
	url = {https://www.scopus.com/pages/publications/105039624248?origin=resultslist},
	doi = {10.54175/hsustain5010011},
	abstract = {Our research explores how higher education institutions (HEI) can effectively foster sustainable behavior and better wellbeing among engineering students, using digital technologies to enhance development of these life aspects. Engineering graduates, as future professionals, influence technological development and contribute to workplace cultures, yet often lack the knowledge to address sustainability challenges, thereby increasing the risk of developing unsus-tainable solutions and work-life habits. Universities offer powerful learning, social, and living environments that can influence long-term attitudes and habits. To understand how these environments shape sustainable behavior and how they can be improved, a narrative literature review was conducted across behavioral science, sustainability studies, engineering education, and digital technology research. The review synthesizes four key categories of behavioral factors: internal drivers, social pressure, environmental and infrastructural facilitators, and habit formation. Universities can address these categories through their curricula, institutional image, and campus infrastructure. The analysis highlights several effective educational strategies, including early exposure to sustainability concepts, problem-and project-based learning, interdisciplinarity, collaboration with industry and communities, and informal activities that extend beyond the classroom. A second contribution of this study is the integration of technological tools into the sustainability education discussion. As digital technologies become deeply embedded in students’ learning processes and increasingly shape how they access information and interact with systems and artificial intelligence tools to make decisions, Industry 4.0 and 5.0 tools serve as powerful mechanisms for promoting sustainable behavior. The review identifies four categories of digital tools that can support sustainable behavior development: visualization, simulation, gamification, and smart infrastructure. The study proposes an integrative conceptual framework that aligns pedagogical strategies, institutional image, and campus infrastructure to support the development of sustainable behavior among engineering students. We recommend follow-up studies on social media’s impact on mental health, virtual and metaverse technologies for wellbeing and soft skills development, especially in an era of increasing reliance on artificial intelligence (AI) tools for human work and thinking offloading. Additionally, linking technological tools with behavioral predictors to demonstrate how technology can improve learning has been shown to boost social and motivational factors and incorporate sustainable actions into daily routines. This presents strong opportunities to connect HEI education to Society 5.0 and Education 5.0 development. © 2026 Kovaleva et al.},
	language = {English},
	number = {1},
	journal = {Highlights of Sustainability},
	publisher = {Highlights of Science},
	author = {Kovaleva, Y. and Minu, R.I. and Happonen, A.},
	year = {2026},
	keywords = {accessibility, behavior, curriculum design, digital technologies, digitalization, Education 5.0, engineering studies, habit formation, HEI, higher education, Industry 5.0, psychological foundations, social pressure, Society 5.0, sustainability, wellbeing},
	pages = {147--164},
	annote = {Export Date: 30 May 2026; Cited By: 0; Correspondence Address: A. Happonen; LUT Software Engineering, LUT School of Engineering Sciences, LUT University, Lappeenranta, 53850, Finland; email: ari.happonen@lut.fi},
	file = {Full Text PDF:E\:\\Zotero\\storage\\P3K5PQGW\\Kovaleva et al. - 2026 - Promoting and Developing Sustainable Behavior among Engineering Students The Role of Higher Educati.pdf:application/pdf},
}

