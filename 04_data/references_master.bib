	year = {2020},
	keywords = {Students, Industry 4.0, Higher Education, Automation, Engineering education, Digital Twin, Education computing, Teaching-learning process, Recurrent neural networks, Manufacture, Undergraduate students, Engineering research, Innovative technology, Industrial revolutions, Educational Innovation, Product design, Risk perception, Manufacturing process, Digital twin, Technological forecasting, Programmable logic controllers, Industrial automation, Exchange of information, Digital Pyramid, Industrial Automation, Intelligent manufacturing system, Virtual Commissioning},
