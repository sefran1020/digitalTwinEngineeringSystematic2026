@article{scaravetti_mapping_2026,
	title = {Mapping of {Extended} {Reality} {Uses} to {Product} {Life} {Cycle} {Phases}, in {Engineering} {Education}: {Identification} of {Contributions} {Based} on {Educational} {Case} {Studies}},
	volume = {7},
	issn = {2662995X (ISSN)},
	url = {https://www.scopus.com/pages/publications/105031797951?origin=resultslist},
	doi = {10.1007/s42979-026-04840-w},
	abstract = {For several years, digital tools have been integrated into the professional environment of engineers in industry. Higher education has evolved to familiarize and train students in their use and in the integration of these tools at different stages of the product life cycle. The objective of this work is to identify relevant Extended Reality (XR) functionalities that can be used at various stages of the product life cycle and can contribute to improving processes. This article proposes a framework that maps the uses of XR—encompassing Virtual Reality (VR), Augmented Reality (AR), and Mixed Reality (MR)—to stages of the product life cycle processes, in a mechanical engineering education context. This comes from several case studies carried out with students, in order to identify the possible gains brought by these technologies. The work integrates established process models with a scoping review of XR affordances and eight case studies implemented in curricular activities. The methodology clarifies task–deliverable decomposition and derives job needs that are not fully addressed by conventional tools, then identifies XR features that can address those needs. Finally, an evaluation of the contributions of XR uses at various stages of the processes is proposed. The educational sequences and case studies presented here, use XR both as a teaching tool and also as a new vector for improving industrial performance. So, students are enable to understand the concepts, to experiment with the different uses, and to identify the interest for industrial uses. © The Author(s) 2026.},
	language = {English},
	number = {3},
	journal = {SN Computer Science},
	publisher = {Springer},
	author = {Scaravetti, D. and Magnin, F.},
	year = {2026},
	keywords = {AR, Higher education, Mechanical engineering, Product life cycle support, VR, XR},
	annote = {Export Date: 30 May 2026; Cited By: 0; Correspondence Address: D. Scaravetti; Arts et Métiers Institute of Technology, CNRS, Bordeaux University, Talence, Bordeaux INP, I2M, UMR 5295, 33400, France; email: dominique.scaravetti@ensam.eu},
	file = {Full Text PDF:E\:\\Zotero\\storage\\SR7S5X6B\\Scaravetti y Magnin - 2026 - Mapping of Extended Reality Uses to Product Life Cycle Phases, in Engineering Education Identificat.pdf:application/pdf},
}

@article{llanos-ruiz_virtual_2025,
	title = {Virtual {Reality} in {Higher} {Education}: {A} {Systematic} {Review} {Aligned} with the {Sustainable} {Development} {Goals}},
	volume = {15},
	issn = {20754698 (ISSN)},
	url = {https://www.scopus.com/pages/publications/105017088083?origin=resultslist},
	doi = {10.3390/soc15090251},
	abstract = {Virtual Reality (VR) has emerged as a transformative tool in higher education, enabling immersive and interactive learning environments that support the assimilation of complex concepts, hands-on training, and innovative pedagogical practices. This systematic literature review analyzes studies published between 2020 and 2025 that examined the integration of VR in higher education and its connection with the United Nations Sustainable Development Goals (SDGs). Following the PRISMA guidelines, twelve studies were selected from the Web of Science and Scopus databases and assessed using predefined quality criteria. The findings highlight the predominance of mixed-methods approaches, with applications spanning diverse disciplines such as engineering, medical sciences, architecture, teacher training, and sustainability. The results emphasize VR’s potential to enhance student motivation, engagement, and digital competencies, while also contributing to Quality Education (SDG 4), along with other SDGs such as Good Health and Well-Being (SDG 3), Affordable and Clean Energy (SDG 7), Decent Work and Economic Growth (SDG 8), Reducing Inequalities (SDG 10), Sustainable Cities and Communities (SDG 11), and Climate Action (SDG 13). However, persistent challenges include high implementation costs, limited accessibility and teacher training, lack of standardization, and small short-term study designs. This review underscores the need for broader, longitudinal, and interdisciplinary research that integrates underrepresented SDGs and addresses inclusivity, equity, and long-term effectiveness, consolidating VR as a catalyst for innovation and sustainable development in higher education. © 2025 by the authors.},
	language = {English},
	number = {9},
	journal = {Societies},
	publisher = {Multidisciplinary Digital Publishing Institute (MDPI)},
	author = {Llanos-Ruiz, D. and Abella-García, V. and Ausín-Villaverde, V.},
	year = {2025},
	keywords = {digital competencies, educational technology, higher education, immersive learning, pedagogical practices, Sustainable Development Goals, teaching and learning, virtual reality},
	annote = {Export Date: 30 May 2026; Cited By: 13; Correspondence Address: D. Llanos-Ruiz; Department of Educational Sciences, Faculty of Education, University of Burgos, Burgos, C/Villadiego 1, 09001, Spain; email: dlruiz@ubu.es},
}

@inproceedings{mattukoyya_virtual_2025,
	title = {Virtual {Reality} in {Education}: {Exploring} {Opportunities}, {Challenges}, and {Future} {Directions}},
	isbn = {979-833159610-1 (ISBN)},
	url = {https://www.scopus.com/pages/publications/105030045585?origin=resultslist},
	doi = {10.1109/ICCAMS65118.2025.11233873},
	abstract = {Virtual reality introduces an innovative learning methodology in the field of education.Virtual Reality is transforming the standard of education by offering new learning techniques that increase a student's interest and learning of abstract concepts. Reviewing the broad applications of this technology across various sectors including higher education, vocational training health care, engineering, or business disciplines is the study's objective. The immersive nature of VR enables students to interact with content in ways that traditional pedagogical methods cannot achieve, which in turn promotes active learning and collaboration. Underpinning the effective use of VR are key learning theories such as constructivism and experiential learning, promoting deeper cognitive engagement and retention of knowledge. However, the main challenges include high implementation costs, technical barriers, and the need for robust pedagogical frameworks. This paper synthesizes existing findings to highlight the benefits as well as the limitations of VR in education and consequently suggests pathways for future research and development. By addressing these challenges, educators can utilize the VR technology to produce even more engaging and personalized learning experiences that meet the requirements of a digital age. Meanwhile, the share of traditional education is still significant, but its combination with VR technology promises impressive student engagement, better retention of knowledge, and further development of useful skills.  © 2025 IEEE.},
