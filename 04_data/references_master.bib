@article{guo_rhl-butterfly_2025,
	title = {{RHL}-{Butterfly}: {A} {Scalable} {IoT}-{Based} {Digital} {Twinning} {Platform} for {Embedded} {Systems} and {Remote} {Laboratories}.},
