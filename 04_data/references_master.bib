@article{ryalat_research_2025,
	title = {Research and {Education} in {Robotics}: {A} {Comprehensive} {Review}, {Trends}, {Challenges}, and {Future} {Directions}},
	volume = {14},
	issn = {22242708 (ISSN)},
	url = {https://www.scopus.com/pages/publications/105014354056?origin=resultslist},
	doi = {10.3390/jsan14040076},
	abstract = {Robotics has emerged as a transformative discipline at the intersection of the engineering, computer science, and cognitive sciences. This state-of-the-art review explores the current trends, methodologies, and challenges in both robotics research and education. This paper presents a comprehensive review of the evolution of robotics, tracing its development from early automation to intelligent, autonomous systems. Key enabling technologies, such as Artificial Intelligence (AI), soft robotics, the Internet of Things (IoT), and swarm intelligence, are examined along with real-world applications in healthcare, manufacturing, agriculture, and sustainable smart cities. A central focus is placed on robotics education, where hands-on, interdisciplinary learning is reshaping curricula from K–12 to postgraduate levels. This paper analyzes instructional models including project-based learning, laboratory work, capstone design courses, and robotics competitions, highlighting their effectiveness in developing both technical and creative competencies. Widely adopted platforms such as the Robot Operating System (ROS) are briefly discussed in the context of their educational value and real-world alignment. Through case studies, institutional insights, and synthesis of academic and industry practices, this review underscores the vital role of robotics education in fostering innovation, systems thinking, and workforce readiness. The paper concludes by identifying the key challenges and future directions to guide researchers, educators, industry stakeholders, and policymakers in advancing robotics as both technological and educational frontiers. © 2025 by the authors.},
	language = {English},
	number = {4},
	journal = {Journal of Sensor and Actuator Networks},
	publisher = {Multidisciplinary Digital Publishing Institute (MDPI)},
	author = {Ryalat, M. and Almtireen, N. and Al-refai, G. and Elmoaqet, H. and Rawashdeh, N.},
	year = {2025},
	keywords = {artificial intelligence, autonomous systems, career development, engineering education, human–robot interaction, industry 4.0, mechatronics, project-based learning, robotics, robotics pedagogy, ROS, smart manufacturing, soft robotics, sustainability},
	annote = {Export Date: 30 May 2026; Cited By: 19; Correspondence Address: M. Ryalat; Mechatronics Engineering Department, German Jordanian University, Amman, 11180, Jordan; email: mutaz.ryalat@gju.edu.jo},
}

@article{joshi_digital_2026,
	title = {Digital twin and education: a revolutionary pathway to learning},
	issn = {978-044340678-2 (ISBN); 978-044340679-9 (ISBN)},
	url = {https://www.scopus.com/pages/publications/105033731533?origin=resultslist},
	doi = {10.1016/B978-0-443-40678-2.00004-0},
	abstract = {This chapter seeks to comprehend the transformative shifts in meaning and the intrinsic digital metamorphoses inside education, as well as the potential for the formation of a new educational network reality founded upon these changes. The discussion centers not on digital innovations and transformations in education per se, but on the necessity to comprehend the potential implications and outcomes of the alterations in social networks instigated by the forthcoming phase of the digital revolution in education. Digital twins (DTs) may be used across several educational environments, from primary and secondary schools to higher education institutions. The students can reproduce complex experiments in a laboratory in a school environment for security and access to resources through virtual representations developed using DT technology. With DT technology, instructors can create virtual field trips where students can see the world without leaving the school environment. With virtual replicas, students can access instructors and even subject matter professionals through virtual representations. It can be instrumental in distance learning when students cannot access a schoolroom or face-to-face instructors. This research examines the high use of DT technology in the educational system, including its technical, social, and ethical limitations. © 2026 Elsevier Inc. All rights reserved.},
