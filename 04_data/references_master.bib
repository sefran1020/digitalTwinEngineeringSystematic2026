	year = {2022},
	keywords = {Decisions makings, Design Quality, Digital twin, E-learning, Electric batteries, Emerging technologies, Enabling technologies, Enabling technology, Engineering education, Health monitoring, Health policy, Industry 4.0, Machine learning, Machine-learning, Optimisations, Optimization, Perspective, Review, Uncertainty analysis, Uncertainty quantifications},
