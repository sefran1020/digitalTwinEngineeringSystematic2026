	annote = {Export Date: 30 May 2026; Cited By: 0; Correspondence Address: X. Jiang; School of Yonyou Digital and Intelligence, Nantong Institute of Technology, Nantong, China; email: 20190083@ntit.edu.cn; M.G.M. Johar; Software Engineering and Digital Innovation Center, Management and Science University, Shah Alam, Selangor, Malaysia; email: mdgapar@msu.edu.my; CODEN: IJPIE},
