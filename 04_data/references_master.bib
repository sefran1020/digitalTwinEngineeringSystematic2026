@article{sills-jones_reimagining_2026,
	title = {Reimagining {Virtual} {Production} in {Higher} {Education}: {Balancing} {Technology}-{Enhanced} {Learning} with {Pedagogical} {Freedom} and {Institutional} {Challenges}},
	issn = {978-104055498-2 (ISBN); 978-104055498-2 (ISBN)},
	url = {https://www.scopus.com/pages/publications/105031697999?origin=resultslist},
	doi = {10.4324/9781003665472-16},
	abstract = {This chapter examines the establishment of a virtual production (VP) facility at Auckland University of Technology (AUT) as a case study in technology-enhanced learning, informed by the pedagogical thinking of bell hooks, Ivan Illich, Welby Ings, and Kevin Gannon, and by Friedrich Kittler’s media philosophy. While situating technologically advanced facilities such as VP studios in higher education offers opportunities for transdisciplinary collaboration and creative learning, it raises critical concerns about the influence of industry-driven models in educational contexts. Drawing on hooks’ vision of education as a practice of transformative freedom and experimentation, Illich’s call for decentralised and flexible learning, Ings’ advocacy of disobedient teaching, and Gannon’s ethic of radical hope, this chapter contends that a VP facility is educationally transformative only when it prioritises critical thinking, creativity, and experimental practice. The central challenge is to balance real-world relevance with pedagogical freedom, ensuring commercial imperatives do not dominate curricula, assessment, or student agency. Properly framed, the VP space enables students to interrogate conventional creative norms, collapse rigid production phases, and reimagine media-making in alignment with emancipatory educational philosophies. Ultimately, the question is how a technologically sophisticated environment can sustain human-centred teaching while equipping graduates with meaningful, industry-relevant skills. © 2026 selection and editorial matter, Ida Fatimawati Adi Badiozaman and Augustus Raymond Segar.},
	language = {English},
	journal = {Pedagogical Innovation Through Technology-Enhanced Learning Design: Global Case Studies and Implications for Practice},
	publisher = {Taylor and Francis},
	author = {Sills-Jones, D. and Bennett, G.},
	year = {2026},
	keywords = {Auckland, Case-studies, Creative-learning, E-learning, Education computing, Educational context, Engineering education, Facilities, High educations, Hooks, Kittler, Personnel, Production facility, Production studios, Students, Teaching, Technology enhanced learning, Virtual production, Virtual reality},
	pages = {232--249},
	annote = {Export Date: 30 May 2026; Cited By: 0},
}

@article{giussani_study_2025,
	title = {Study on the {Benefits} of {Virtual} {Reality} as a {Support} for {STEM} {Learning}},
	volume = {33},
	issn = {10613773 (ISSN)},
	url = {https://www.scopus.com/pages/publications/105010844995?origin=resultslist},
	doi = {10.1002/cae.70065},
	abstract = {The use of virtual reality (VR) in higher education and training has been widely explored in various fields, with divergent results. This study examines whether VR is a suitable learning support tool compared to traditional methods, such as 2D static slides or physical models, focusing on usability, workload, and learning effectiveness in an engineering education context. A total of 184 first-year BSc engineering students voluntarily participated in an experimental activity. Participants were divided into three groups, each experiencing a different learning condition: slides-based, VR-based, and physical model-based. The study design ensured comparability across conditions using 3 out of 4 levels provided by the ICAP (Interactive, Constructive, Active, Passive) framework. Usability was assessed using the System Usability Scale, workload via the NASA Task Load Index, and learning outcomes through a task-based test. The study found no significant differences in test scores across the three conditions. However, participants in the VR-based and physical model-based conditions reported significantly higher usability and lower perceived workload compared to the slides-based condition. The VR-based condition provided an immersive environment while maintaining comparability in cognitive engagement. The findings demonstrate that VR can serve as an effective alternative to traditional learning methods, particularly for enhancing usability and reducing cognitive workload. However, its integration must be carefully designed to ensure cognitive engagement and optimize learning outcomes. This study highlights VR's potential in engineering education and underscores the importance of aligning tools with pedagogical goals. © 2025 Wiley Periodicals LLC.},
	language = {English},
	number = {4},
	journal = {Computer Applications in Engineering Education},
	publisher = {John Wiley and Sons Inc},
	author = {Giussani, R. and Dozio, N. and Becattini, N. and Cascini, G. and Ferrise, F. and Morosi, F.},
	year = {2025},
	keywords = {Condition, Divergents, E-learning, engineering education, Engineering education, Higher education and trainings, learning, Learning, Learning outcome, Learning systems, Model-based OPC, NASA, Physical modelling, Slide-based, STEM (science, technology, engineering and mathematics), usability, Usability, Usability engineering, virtual reality, Virtual reality, workload, Workload},
	annote = {Export Date: 30 May 2026; Cited By: 1; Correspondence Address: N. Dozio; Department of Mechanical Engineering, Politecnico di Milano, Milan, Italy; email: nicolo.dozio@polimi.it; CODEN: CAPEE},
}

@article{espinoza_virtual_2025,
