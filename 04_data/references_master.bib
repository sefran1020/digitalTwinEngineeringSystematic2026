	keywords = {Big data, E-learning, Economic and social effects, Education 4.0, Educational technology, Educational transformation, Educational Transformation, Emerging technologies, Emerging Technologies, Engineering education, Formative dialog research, Formative Dialogue Research, High educations, Industrial economics, Industry 4.0, Institutional change, Learning Design, Learning designs, Operational level, Organisational, Tacticals},
