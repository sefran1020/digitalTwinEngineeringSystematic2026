	file = {Full Text PDF:E\:\\Zotero\\storage\\DCRP8LV5\\Cuperman y Raveh - 2026 - Academic Faculty Perceptions of Incorporating Industry 4.0 Technologies in Engineering Higher Educat.pdf:application/pdf},
