@inproceedings{fu_computer_2025,
	title = {Computer technology-enhanced digital twin-driven innovation and practice of talent training mode of new engineering experimental and training},
	issn = {979-840071430-6 (ISBN)},
	url = {https://www.scopus.com/pages/publications/105025549177?origin=resultslist},
	doi = {10.1145/3764206.3764314},
	abstract = {In the era of globalization and digital transformation, the new engineering education model faces significant challenges in cultivating compound engineering and technical talents that meet the requirements of future industrial development. This study focuses on leveraging digital twin technology integrated with advanced computer technologies including cloud computing, artificial intelligence, and virtual reality to address the problems of insufficient resources, limited practical opportunities, and inadequate innovation capability cultivation in traditional engineering experimental training. We propose a computer simulation-based and data-driven algorithmic digital twin-driven “One-Body, Three-Stage, Four-Step” talent cultivation model for new engineering experimental training. Taking the experimental teaching of the “Industrial Networked Manufacturing and Applications” course as an example, we designed and implemented a comprehensive experimental training program based on an intelligent manufacturing workshop platform that integrates Internet of Things (IoT) technology, edge computing, and machine learning algorithms to enhance students' hands-on abilities and complex engineering problem-solving capabilities. The results demonstrate that the multi-integrated computer technology-based digital twin teaching model significantly enhances students' practical skills and innovation capabilities, particularly in areas of computer programming, algorithmic thinking, big data analytics, system integration, and artificial intelligence applications. This research provides novel approaches and methodologies for new engineering talent cultivation, offering substantial theoretical significance and practical value in bridging the gap between traditional engineering education and modern computational intelligence requirements. © 2025 Copyright held by the owner/author(s).},
	language = {English},
	booktitle = {Proceedings of {The} 2nd {International} {Conference} on {Intelligent} {Education} and {Computer} {Technology}, {IECT} 2025},
