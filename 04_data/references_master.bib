	year = {2023},
	keywords = {In-buildings, Students, Engineering education, E-learning, Sustainable development, Virtual reality, Computer aided instruction, virtual reality, Learning outcome, Learning environments, learning environment, Services engineering, Vocational education, Safety engineering, Maintenance, Air conditioning, Continuing education, continuing education, maintenance, Physical devices, vocational education, Building services, Maintenance procedures, Safety issues},
