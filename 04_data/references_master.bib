	publisher = {American Chemical Society},
	author = {Hunpinyo, P. and Narataruksa, P. and Ampaipisut, A. and Nonbudsri, A. and Inthapattha, C. and Chokkhanapitak, C. and Kanchanathanaseth, K. and Sangthong, N. and Petiraksakul, P. and Meechai, A. and Saranuttee, P. and Naknon, A.},
	year = {2026},
