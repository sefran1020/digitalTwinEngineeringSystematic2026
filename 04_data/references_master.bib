	year = {2021},
	keywords = {Augmented reality, Students, Internet of things, IoT, Industry 4.0, 3D printing, Engineering education, E-learning, Software testing, Data visualization, Digital technologies, 3-D printing, 3D-printing, 3D printers, Practical training, System variables, Augment reliaty, Augment Reliaty, Demonstrator systems, Digital manufacturing, Pump speed, Training equipments},
