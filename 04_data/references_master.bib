	keywords = {High educations, Higher education, Immersive virtual reality, Immersive Virtual reality, Inclusion and exclusions, Learning, Learning outcome, Students, Systematic review, Systematic Review, Virtual reality, Virtual reality devices, Virtual reality Devices, Virtual reality tools, Virtual-reality headsets, Virtualization, Web of Science},
	pages = {104--110},
	annote = {Export Date: 30 May 2026; Cited By: 1; Correspondence Address: X. Zhang; Anhui Technical College of Mechanical and Electrical Engineering, Wuhu, Anhui, China; email: xmxmmm@shu.edu.cn; Conference name: 2024 5th International Conference on Big Data Economy and Information Management, BDEIM 2024; Conference date: 13 December 2024 through 15 December 2024; Conference code: 209097},
}

