	annote = {Export Date: 30 May 2026; Cited By: 40; Correspondence Address: T. Ruppert; ELKH-PE Complex Systems Monitoring Research Group, Department of Process Engineering, University of Pannonia, Veszprem, Egyetem u. 10, POB 158, H-8200, Hungary; email: ruppert@abonyilab.com},
}

