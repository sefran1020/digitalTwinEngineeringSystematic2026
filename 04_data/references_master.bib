	title = {Skill {Gap} {Analysis} {Using} {AI} in {Industry} 4.0},
	isbn = {979-833155621-1 (ISBN)},
	url = {https://www.scopus.com/pages/publications/105037443162?origin=resultslist},
	doi = {10.1109/ICCCES62661.2026.11436391},
	abstract = {The swift progress of technology has transformed the skill demands in workplaces, within the scope of Industry 4.0. However a continuous discrepancy exists between the skills individuals have and what employers need creating a skill gap that impacts employability, job effectiveness and company productivity. Traditional recruiting and training methods often fail to evaluate the abilities of each applicant or provide personalized development guidance. This paper introduces a Skill Gap Analysis System designed to identify an individuals skill set and evaluate it against the requirements of a specific job role through a resume analyzer. The system employs Natural Language Processing (NLP) to retrieve education, experience and skills from the resumes submitted by users. Subsequently these details are aligned with predefined job-role- skill frameworks stored within an organized database. The system provides personalized learning recommendations, such as online course materials, practice platforms, reference materials, and guided project suggestions, based on this comparison, highlighting both current and deficient skills. The system, which was created using HTML, CSS, JavaScript, and Python with SQL for backend processing, provides learners with an effective and user-friendly way to close skill gaps and increase their employability in a job market that is changing quickly. © 2026 IEEE.},
	language = {English},
